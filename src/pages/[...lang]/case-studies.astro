---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const features = [
  { title: 'Product Quality:', desc: 'Automatically syncs across all your devices. You can also access them anywhere.' },
  { title: 'On Demand Design:', desc: 'Images, videos, PDFs and audio files are supported.' },
  { title: 'Choice of Service:', desc: 'Whatever your business needs, you can choose a service.' },
];

const meta = [
  { label: 'Industry', value: 'Fintech solutions' },
  { label: 'Company size', value: '5,000 – 10,000 employees' },
  { label: 'Founded', value: 'Since 1999' },
];
---

<Layout title="Case Studies — Zylo" description="How Zylo created a complete application management system for their fellowship programme in Saas.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Hero */}
      <Reveal class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-24">
        <div>
          <h1 class="text-3xl sm:text-5xl font-semibold text-ink font-heading tracking-tight leading-tight mb-8">
            Zylo created a complete application management system for their fellowship programme in Saas
          </h1>
          <p class="text-lg text-steel leading-relaxed mb-12">
            “Thanks to Stacker, the Zylo Fellows team each gets 8 hours or roughly one working day – back per week”
          </p>
          <div class="flex flex-wrap gap-2">
            <div class="rounded-lg bg-canvas-dark text-on-dark px-8 py-7">
              <div class="text-3xl font-semibold font-heading mb-2 tracking-tight">55,000+</div>
              <p class="text-sm">Managed tasks with ERP</p>
            </div>
            <div class="rounded-lg bg-primary text-on-primary px-8 py-7">
              <div class="text-3xl font-semibold font-heading mb-2 tracking-tight">8hrs/week</div>
              <p class="text-sm">Saved for each user</p>
            </div>
          </div>
        </div>
        <div class="rounded-lg border border-hairline bg-canvas p-3 shadow-[var(--shadow-card)] relative overflow-hidden">
          <img src="/home/zylo-hero.png" alt="Zylo case study" class="w-full rounded-md block" />
          <div class="absolute bottom-8 left-8 right-8 rounded-md bg-canvas-dark/70 backdrop-blur-md px-7 py-6 text-on-dark">
            <p class="text-lg font-semibold font-heading mb-1">Leonie Hoerster</p>
            <p class="text-sm text-on-dark-muted">Saved for each user</p>
          </div>
        </div>
      </Reveal>

      {/* 2. Details */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        {/* Sidebar */}
        <Reveal delay={100} class="lg:col-span-1">
          <div class="lg:sticky lg:top-28 rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] space-y-8">
            <div>
              <h2 class="text-xl font-semibold text-ink font-heading mb-3">About</h2>
              <p class="text-sm text-steel leading-relaxed">
                Zylo is a modern SaaS platform built to simplify business operations and accelerate growth. We help teams manage data, automate workflows, and make smarter decisions with a confidence. From startups to our enterprises, Zylo grows with your business.
              </p>
            </div>
            {meta.map((m) => (
              <div class="pt-6 border-t border-hairline-soft">
                <p class="text-xs font-semibold text-stone uppercase tracking-wider mb-2">{m.label}</p>
                <p class="text-base font-semibold text-ink font-heading">{m.value}</p>
              </div>
            ))}
            <div class="pt-6 border-t border-hairline-soft">
              <p class="text-xs font-semibold text-stone uppercase tracking-wider mb-3">Share</p>
              <div class="flex items-center gap-3 text-stone">
                <a href="#" aria-label="LinkedIn" class="hover:text-brand transition-colors"><Icon name="lucide:linkedin" class="w-4 h-4" /></a>
                <a href="#" aria-label="Twitter" class="hover:text-brand transition-colors"><Icon name="lucide:twitter" class="w-4 h-4" /></a>
                <a href="#" aria-label="Facebook" class="hover:text-brand transition-colors"><Icon name="lucide:facebook" class="w-4 h-4" /></a>
              </div>
            </div>
          </div>
        </Reveal>

        {/* Content */}
        <Reveal delay={150} class="lg:col-span-2 space-y-12 text-steel leading-relaxed">
          <section class="space-y-4">
            <h2 class="text-2xl md:text-3xl font-semibold text-ink font-heading">Measure conversion performance</h2>
            <p class="text-base">
              IT company content is important for a number of reasons. First, it can help you attract potential customers. When you create content that is relevant to your target audience, you position yourself as an expert in your field and increase the chances that potential customers will find you. IT company content can help you educate potential customers about your products and services.
            </p>
            <p class="text-base">
              We are committed to providing our clients with the highest quality IT services and support. We understand that IT is essential for your business, and we will work tirelessly to help you achieve your business goals.
            </p>
          </section>

          <section>
            <h3 class="text-xl md:text-2xl font-semibold text-ink font-heading mb-6">Going Beyond the Usual</h3>
            <ul class="space-y-4">
              {features.map((f) => (
                <li class="flex items-start gap-3 text-base">
                  <Icon name="lucide:check-circle" class="w-4 h-4 text-brand shrink-0 mt-1.5" />
                  <span><span class="font-semibold text-ink">{f.title}</span> {f.desc}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="space-y-6">
            <h2 class="text-2xl md:text-3xl font-semibold text-ink font-heading">The Challange</h2>
            <p class="text-base">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas interdum, orci at dapibus massa ante pharetra tellus. Maecenas interdum, orci at euismod dapibus. Lorem ipsum dolor sit amet.
            </p>
            <blockquote class="rounded-lg border border-hairline bg-canvas p-8 md:p-10 shadow-[var(--shadow-subtle)]">
              <p class="text-xl md:text-2xl font-medium text-ink font-heading leading-snug mb-6">
                We're committed to changing the way of mobile UX. We believe that mobile UX has the power to make a real difference in people's lives.
              </p>
              <footer class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-canvas-dark text-on-dark text-sm font-semibold flex items-center justify-center font-heading">R</div>
                <div>
                  <p class="text-sm font-semibold text-ink">Ralph Edwards</p>
                  <p class="text-xs text-steel">New York</p>
                </div>
              </footer>
            </blockquote>
          </section>

          <section class="space-y-4">
            <h2 class="text-2xl md:text-3xl font-semibold text-ink font-heading">Clarity across the supply chain</h2>
            <p class="text-base">
              IT company content is important for a number of reasons. First, it can help you attract potential customers. When you create content that is relevant to your target audience, you position yourself as an expert in your field and increase the chances that potential customers will find you. IT company content can help you educate potential customers about your products and services.
            </p>
            <p class="text-base">
              We are committed to providing our clients with the highest quality IT services and support. We understand that IT is essential for your business, and we will work tirelessly to help you achieve your business goals.
            </p>
            <ul class="space-y-4 pt-2">
              {features.map((f) => (
                <li class="flex items-start gap-3 text-base">
                  <Icon name="lucide:check-circle" class="w-4 h-4 text-brand shrink-0 mt-1.5" />
                  <span><span class="font-semibold text-ink">{f.title}</span> {f.desc}</span>
                </li>
              ))}
            </ul>
          </section>
        </Reveal>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
