---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const features = [
  { title: 'Workflow Automation:', desc: 'Automatically syncs applicant data across all your connected databases and communication channels.' },
  { title: 'Visual Canvas:', desc: 'Build, test, and debug pipelines with a visual drag-and-drop builder without writing custom scripts.' },
  { title: 'Granular Permissions:', desc: 'Secure workspaces with role-based access control, keeping candidate data private and compliant.' },
];

const meta = [
  { label: 'Industry', value: 'Education & Non-Profit' },
  { label: 'Company size', value: '1,000 – 5,000 employees' },
  { label: 'Founded', value: 'Since 2012' },
];

const stats = [
  { value: '55,000+', label: 'Managed applications synced' },
  { value: '8hrs/week', label: 'Saved for each coordinator' },
  { value: '1,000 – 5,000', label: 'Members on the platform' },
];
---

<Layout title="Case Studies — Zylo" description="How Zylo built a unified operations dashboard for global enterprise teams.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-16">
        <span class="eyebrow mb-4 block">Case study</span>
        <h1 class="h1 mb-5">
          Zylo built a unified application management system for global fellowship programs
        </h1>
        <p class="subtitle">
          &ldquo;Thanks to Zylo, the fellows operations team each gets 8 hours &ndash; roughly one working day &ndash; back per week&rdquo;
        </p>
      </Reveal>

      <Reveal delay={80}>
        <img
          src="/placeholder.png"
          alt="Zylo application management case study"
          loading="lazy"
          class="mb-16 aspect-[16/9] w-full rounded-lg border border-hairline-soft bg-surface object-contain p-4"
        />
      </Reveal>

      {/* 2. Stat row */}
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-20">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80} class="text-center">
            <div class="display-lg mb-2">{s.value}</div>
            <p class="p-sm">{s.label}</p>
          </Reveal>
        ))}
      </div>

      {/* 3. Story detail */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-8">
        {/* Sidebar */}
        <Reveal delay={100} class="lg:col-span-1">
          <div class="lg:sticky lg:top-28 rounded-lg border border-hairline bg-canvas p-6 space-y-6">
            <div>
              <h2 class="h5 mb-3">About</h2>
              <p class="p-sm">
                Zylo is a modern SaaS platform built to simplify business operations and accelerate growth. We help teams manage data, automate workflows, and make smarter decisions with confidence. From startups to enterprises, Zylo grows with your business.
              </p>
            </div>
            {meta.map((m) => (
              <div class="pt-6 border-t border-hairline-soft">
                <p class="eyebrow mb-2">{m.label}</p>
                <p class="h6">{m.value}</p>
              </div>
            ))}
            <div class="pt-6 border-t border-hairline-soft">
              <p class="eyebrow mb-3">Share</p>
              <div class="flex items-center gap-3 text-stone">
                <a href="#" aria-label="LinkedIn" class="hover:text-ink transition-colors"><Icon name="lucide:linkedin" class="w-4 h-4" /></a>
                <a href="#" aria-label="Twitter" class="hover:text-ink transition-colors"><Icon name="lucide:twitter" class="w-4 h-4" /></a>
                <a href="#" aria-label="Facebook" class="hover:text-ink transition-colors"><Icon name="lucide:facebook" class="w-4 h-4" /></a>
              </div>
            </div>
          </div>
        </Reveal>

        {/* Content */}
        <Reveal delay={150} class="lg:col-span-2 space-y-12">
          <section class="space-y-4">
            <h2 class="h3">Measure operational performance</h2>
            <p class="p-rg">
              Managing applicant data and coordination across dozens of hosts used to take days of manual tracking. By implementing Zylo's workflow automation, the fellows team was able to sync application submissions directly with their CRM and internal databases. This eliminated manual data entry completely, ensuring that updates are reflected in real-time across all systems.
            </p>
            <p class="p-rg">
              The operations team can now monitor the status of every application from a single dashboard. Automated triggers send notifications to internal reviewers as soon as new submissions arrive, keeping the evaluation process moving smoothly.
            </p>
          </section>

          <section>
            <h3 class="h4 mb-6">Going Beyond the Usual</h3>
            <ul class="space-y-4">
              {features.map((f) => (
                <li class="flex items-start gap-3 p-rg">
                  <Icon name="lucide:check-circle" class="w-4 h-4 text-brand shrink-0 mt-1.5" />
                  <span><span class="font-semibold text-ink">{f.title}</span> {f.desc}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="space-y-6">
            <h2 class="h3">The Challenge</h2>
            <p class="p-rg">
              Prior to using Zylo, the team relied on a fragmented stack of spreadsheets, form builders, and manual email alerts. Reviewers frequently missed notification deadlines, and candidate data became out-of-sync between recruitment and operations boards. They needed a secure, unified platform that could automate data syncs and trigger alerts programmatically.
            </p>
            <blockquote class="rounded-lg border border-hairline bg-canvas p-8">
              <p class="h4 mb-6 leading-snug">
                We're committed to simplifying operational complexity. We believe that automation has the power to free teams from repetitive manual work, allowing them to focus on high-impact initiatives.
              </p>
              <footer class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-surface text-ink text-sm font-semibold flex items-center justify-center">R</div>
                <div>
                  <p class="h6">Ralph Edwards</p>
                  <p class="p-lt">Program Director</p>
                </div>
              </footer>
            </blockquote>
          </section>

          <section class="space-y-4">
            <h2 class="h3">Clarity across the operational pipeline</h2>
            <p class="p-rg">
              With Zylo, every step of the fellowship lifecycle is automated. From candidate intake to onboarding and final evaluations, data flows seamlessly between Slack, Notion, and their custom database. The team has full visibility and control over who has access to private applicant records.
            </p>
            <p class="p-rg">
              By centralizing operations, the Zylo Fellows program scaled their intake by 40% without hiring additional coordinators, proving that automated systems are the key to efficient scaling.
            </p>
            <ul class="space-y-4 pt-2">
              {features.map((f) => (
                <li class="flex items-start gap-3 p-rg">
                  <Icon name="lucide:check-circle" class="w-4 h-4 text-brand shrink-0 mt-1.5" />
                  <span><span class="font-semibold text-ink">{f.title}</span> {f.desc}</span>
                </li>
              ))}
            </ul>
          </section>
        </Reveal>
      </div>
    </section>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline mt-20">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">Run the same playbook</h2>
          <p class="p-rg mb-8">
            Map your process once in Zylo and let the workflows handle the rest — most teams are live in a week.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">Get started</a>
            <a href="/customer" class="btn-secondary btn-lg">See more customers</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
