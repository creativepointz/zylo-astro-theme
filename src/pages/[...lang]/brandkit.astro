---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const channels = [
  { label: 'X (Twitter)', icon: 'lucide:twitter' },
  { label: 'Facebook', icon: 'lucide:facebook' },
  { label: 'Instagram', icon: 'lucide:instagram' },
  { label: 'YouTube', icon: 'lucide:youtube' },
  { label: 'LinkedIn', icon: 'lucide:linkedin' },
  { label: 'GitHub', icon: 'lucide:github' },
];

const kitDesc =
  'This kit contains the more commonly used horizontal Zylo Track logo in both PNG and SVG formats';

const kitOptions = [
  'Pink (can be used for light and dark backgrounds)',
  'Dark purple (for light backgrounds)',
];

const kits = [
  { title: 'Zylo track horizontal logo', desc: kitDesc, options: kitOptions },
  { title: 'Zylo track stacked logo', desc: kitDesc, options: kitOptions },
  { title: 'Zylo track icons', desc: kitDesc, options: kitOptions },
];
---

<Layout title="Brandkit — Logos & Brand Assets" description="Brand assets and guidelines for Zylo Track. Download official logos, icons, and usage rules.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-5xl mx-auto px-4">
      {/* 1. A bit about Zylo track */}
      <Reveal class="mb-16">
        <h1 class="text-4xl sm:text-5xl font-semibold text-ink font-heading tracking-tight mb-6 leading-tight">
          A bit about Zylo track
        </h1>
        <p class="text-lg text-steel leading-relaxed mb-6">
          Zylo Track provides time tracking and productivity tools to help businesses move away
          from traditional work models towards flexible and remote work. Companies use Zylo
          Track data to manage projects across teams and make better business decisions, from
          project estimates and team planning, to profitability analysis, to accurate and
          transparent client billing.
        </p>
        <p class="text-lg text-steel leading-relaxed">
          We integrate with 100+ commonly used business applications and sync time entry data
          across our mobile and desktop apps, Chrome, Firefox and Edge extensions, and
          website. We are a bootstrapped, fully remote company with 120+ team members working
          from 30+ countries, serving users from 160+ countries.
        </p>
      </Reveal>

      {/* 2. Official Zylo track channels */}
      <Reveal delay={80} class="mb-16">
        <h2 class="text-2xl font-semibold text-ink font-heading tracking-tight mb-3">
          Official Zylo track channels
        </h2>
        <p class="text-steel leading-relaxed mb-6">
          We believe simplicity drives impact. By stripping away unnecessary clutter, we help
          teams focus on what truly matters, making decisions faster and creating solutions
          that are easy to understand and use.
        </p>
        <div class="flex flex-wrap gap-3">
          {channels.map((c) => (
            <a
              href="#"
              class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-5 py-2.5 text-sm font-semibold text-steel hover:border-brand/40 hover:text-brand transition-colors shadow-[var(--shadow-subtle)]"
            >
              <Icon name={c.icon} class="w-4 h-4" />
              {c.label}
            </a>
          ))}
        </div>
      </Reveal>

      {/* 3. Brand assets and guidelines */}
      <Reveal delay={120} class="mb-10">
        <h2 class="text-2xl font-semibold text-ink font-heading tracking-tight mb-3">
          Brand assets and guidelines
        </h2>
        <p class="text-steel leading-relaxed">
          Below, you will find Zylo Track assets. Please use the logos or icons as is. Please do not
          modify or use them in a confusing way, including suggesting endorsement by Zylo
          Track or collaboration with Zylo Track, unless previously approved by us.
        </p>
      </Reveal>

      {/* 4. Download kits */}
      <div class="space-y-6 mb-16">
        {kits.map((k, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] hover:border-brand/40 hover:shadow-[var(--shadow-subtle)] transition-all">
              <h2 class="text-xl font-semibold text-ink font-heading mb-3">{k.title}</h2>
              <p class="text-steel text-sm leading-relaxed mb-4">{k.desc}</p>
              <ul class="space-y-2 mb-6">
                {k.options.map((o) => (
                  <li class="flex items-start gap-2 text-sm text-steel">
                    <Icon name="lucide:check" class="w-4 h-4 text-brand mt-0.5 flex-none" />
                    <span>{o}</span>
                  </li>
                ))}
              </ul>
              <a
                href="#"
                class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-canvas-dark px-6 text-xs font-semibold text-on-dark hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]"
              >
                Download Kit <Icon name="lucide:download" class="w-4 h-4" />
              </a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
