---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const stats = [
  { badge: 'Growth', value: '95%', desc: 'Achieved an impressive 95% year over increase in active users' },
  { badge: 'Experience', value: '10+', desc: 'Built on more than 10 years of the financial technology expertise' },
  { badge: 'Revenue', value: '$24m', desc: 'Secured $12 million yearly revenue highlighting steady performance' },
  { badge: 'Users', value: '60k+', desc: 'Active user all over the world and they are happy to use this task' },
];

const values = [
  { icon: 'lucide:layout-dashboard', title: 'Custom workspace', desc: 'Work together effortlessly follow progress hypes' },
  { icon: 'lucide:trending-up', title: 'Track your success', desc: 'Work together effortlessly follow progress hypess' },
  { icon: 'lucide:blocks', title: 'Build in integration', desc: 'Work together effortlessly follow progress hypes' },
  { icon: 'lucide:users', title: 'Time collaboration', desc: 'Work together effortlessly follow progress hypes' },
];

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX', 'HyperLogistics'];

const integrations = ['Slack', 'Notion', 'HubSpot', 'Salesforce', 'Zapier', 'Google Drive', 'Shopify', 'Intercom'];
---

<Layout title="About Us — Zylo Platform" description="Learn about Zylo mission, core values, team metrics, and company growth.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">

      {/* 1. Inner Hero Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Innovation meets intent
        </span>
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-bold text-slate-900 font-heading tracking-tight leading-[1.05] mb-8">
          Where teams move <br class="hidden sm:inline" /> faster &amp; work gets done
        </h1>

        {/* 3D Preview Image Container */}
        <div class="rounded-3xl border border-slate-200 bg-white p-3 shadow-2xl overflow-hidden mt-8 max-w-4xl mx-auto">
          <img src="/home/zylo-hero.png" alt="Zylo Platform" class="w-full rounded-2xl block" />
        </div>
      </Reveal>

      {/* 2. Brand Marquee */}
      <Reveal delay={100} class="py-12 text-center border-y border-slate-200/80 mb-20">
        <p class="text-sm font-medium text-slate-500 mb-8 uppercase tracking-wider">Trusted by <span class="font-bold text-slate-900">10,000+</span> businesses worldwide</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14 opacity-70">
          {brands.map((b) => (
            <span class="text-lg md:text-xl font-bold font-heading text-slate-700 tracking-tight">{b}</span>
          ))}
        </div>
      </Reveal>

      {/* 3. Mission Highlight */}
      <Reveal delay={120} class="text-center max-w-4xl mx-auto mb-20">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6">
          Know more about us
        </span>
        <h2 class="text-3xl sm:text-5xl font-medium text-slate-900 font-heading leading-tight tracking-tight">
          When teams are stretched thin, our <span class="text-brand font-bold underline">AI support coordinator</span> takes care of the tasks so your staff can take care of people. More clients care by AI.
        </h2>
      </Reveal>

      {/* 4. Funfact Stats Cards */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-all h-full flex flex-col justify-between">
              <div>
                <span class="inline-block border border-dashed border-slate-300 rounded-full px-3 py-1 text-xs font-semibold text-slate-700 mb-8">
                  {s.badge}
                </span>
                <div class="text-5xl font-bold text-slate-900 font-heading mb-3 tracking-tight">{s.value}</div>
              </div>
              <p class="text-xs text-slate-600 leading-relaxed font-normal">{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 5. Core Values Container Card */}
      <Reveal delay={150} class="rounded-3xl bg-slate-900 text-white p-10 md:p-16 mb-20 shadow-2xl relative overflow-hidden">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="inline-block border border-white/20 bg-white/10 px-4 py-1.5 rounded-full text-xs font-semibold text-white uppercase tracking-wider mb-4 backdrop-blur-md">
            Core values guide everything
          </span>
          <h2 class="text-3xl md:text-5xl font-bold font-heading tracking-tight">Core values guide everything</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map((v) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-md hover:bg-white/10 transition-colors">
              <div class="w-12 h-12 rounded-xl bg-brand text-white flex items-center justify-center mb-6 shadow-md">
                <Icon name={v.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold font-heading mb-3">{v.title}</h3>
              <p class="text-slate-300 text-sm leading-relaxed">{v.desc}</p>
            </div>
          ))}
        </div>
      </Reveal>

      {/* 6. Integrations */}
      <Reveal delay={120} class="text-center max-w-5xl mx-auto mb-20">
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-10 leading-tight">
          Seamless integration <br class="hidden sm:inline" /> with your entire tech stack
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
          {integrations.map((i) => (
            <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all text-sm font-semibold text-slate-800 font-heading">
              {i}
            </div>
          ))}
        </div>
        <a href="/integrations" class="inline-flex h-11 items-center justify-center gap-2 rounded-full border border-slate-200 bg-white px-7 text-xs font-semibold text-slate-900 hover:border-brand hover:text-brand transition-colors shadow-sm">
          See all integrations <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </Reveal>

      {/* 7. Final CTA */}
      <Reveal class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-6 leading-tight">
          Start planning smarter and more <br class="hidden sm:inline" /> meaningful user experiences
        </h2>
        <p class="text-slate-600 text-base mb-8 leading-relaxed">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <a href="/pricing" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-brand px-8 text-base font-semibold text-white hover:bg-brand-hover transition-colors shadow-lg">
          Subscribe now <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
      </Reveal>

    </div>
  </main>

  <Footer />
</Layout>
