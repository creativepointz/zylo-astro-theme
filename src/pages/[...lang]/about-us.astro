---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const stats = [
  { badge: 'Growth', value: '95%', desc: 'Achieved an impressive 95% year-over-year increase in active workflows.' },
  { badge: 'Experience', value: '10+', desc: 'Built on more than 10 years of enterprise workflow automation expertise.' },
  { badge: 'Revenue', value: '$24m', desc: 'Secured $24 million yearly recurring revenue, highlighting our steady market performance.' },
  { badge: 'Users', value: '60k+', desc: 'Active users worldwide who scale their daily operations with Zylo.' },
];

const values = [
  { icon: 'lucide:layout-dashboard', title: 'Custom workspace', desc: 'Tailor your automated pipelines and layout exactly to your team\'s operational needs.' },
  { icon: 'lucide:trending-up', title: 'Track your success', desc: 'Monitor task execution health, cost savings, and active runs in real-time dashboards.' },
  { icon: 'lucide:blocks', title: 'Build in integration', desc: 'Plug directly into Notion, Slack, Jira, and 100+ tools with a few simple clicks.' },
  { icon: 'lucide:users', title: 'Time collaboration', desc: 'Coordinate with team members with clear permissions, audit logs, and shared workspaces.' },
];

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX'];

const integrations = ['Slack', 'Notion', 'HubSpot', 'Salesforce', 'Zapier', 'Google Drive', 'Shopify', 'Intercom'];
---

<Layout title="About Us — Zylo Platform" description="Learn about Zylo mission, core values, team metrics, and company growth.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] bg-canvas">
    {/* 1. Centered hero */}
    <div class="container-page pb-16 md:pb-20">
      <Reveal class="text-center max-w-4xl mx-auto">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Innovation meets intent
        </span>
        <h1 class="hero-display mb-6">
          Where teams move <br class="hidden sm:inline" /> faster &amp; work gets done
        </h1>
        <p class="subtitle max-w-2xl mx-auto">
          Zylo is a workflow automation platform. We build the connective layer that moves work between the tools your
          team already runs on.
        </p>

        <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden mt-12">
          <img src="/placeholder.png" alt="Zylo Platform" class="w-full rounded-md block" />
        </div>
      </Reveal>
    </div>

    {/* 2. Logo wall — 6-up */}
    <div class="container-page pb-16 md:pb-24">
      <Reveal delay={100} class="border-y border-hairline py-12 text-center">
        <p class="eyebrow mb-8">Trusted by <span class="text-ink">10,000+</span> businesses worldwide</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 items-center">
          {brands.map((b) => (
            <span class="text-base font-medium text-steel tracking-tight py-2">{b}</span>
          ))}
        </div>
      </Reveal>
    </div>

    {/* 3. Stat row */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80}>
            <div class="h-full">
              <span class="eyebrow mb-5 inline-block rounded-full border border-hairline bg-surface px-3 py-1">
                {s.badge}
              </span>
              <div class="display-lg mb-3">{s.value}</div>
              <p class="p-sm">{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 4. Value cards — 4-up */}
    <div class="container-page pb-16 md:pb-24">
      <Reveal class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow mb-4 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Core values guide everything
        </span>
        <h2 class="h2">Core values guide everything</h2>
      </Reveal>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((v, idx) => (
          <Reveal delay={idx * 60}>
            <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
              <span class="icon-tile mb-5">
                <Icon name={v.icon} class="w-5 h-5" />
              </span>
              <h3 class="h5 mb-2">{v.title}</h3>
              <p class="p-sm">{v.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 5. Story row — text left, image right */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <Reveal>
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Know more about us
          </span>
          <h2 class="h2">
            When teams are stretched thin, our <span class="text-brand-annotate">AI support coordinator</span> takes
            care of the tasks so your staff can take care of people. More clients care by AI.
          </h2>
        </Reveal>
        <Reveal delay={100}>
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
            <img src="/placeholder.png" alt="Zylo AI coordinator" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </div>

    {/* 6. Story row — grid left, text right */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <Reveal class="lg:order-2">
          <h2 class="h2 mb-4">Seamless integration with your entire tech stack</h2>
          <p class="p-rg mb-8">
            Connect the tools your team already uses and let Zylo pass work between them without manual handoffs.
          </p>
          <a href="/integrations" class="btn-secondary btn-md">
            See all integrations <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>
        <Reveal delay={100} class="lg:order-1">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {integrations.map((i) => (
              <div class="rounded-md border border-hairline bg-canvas p-4 text-sm font-medium text-ink text-center">
                {i}
              </div>
            ))}
          </div>
        </Reveal>
      </div>
    </div>

    {/* 7. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page section">
        <Reveal class="text-center max-w-3xl mx-auto">
          <h2 class="h2 mb-6">
            Start planning smarter and more <br class="hidden sm:inline" /> meaningful user experiences
          </h2>
          <p class="p-rg mb-8">
            Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual
            and interactive effects all in one platform.
          </p>
          <a href="/pricing" class="btn-accent btn-lg">
            Subscribe now <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
