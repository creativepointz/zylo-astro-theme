---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const stats = [
  { badge: 'Growth', value: '95%', desc: 'Achieved an impressive 95% year over increase in active users' },
  { badge: 'Experience', value: '10+', desc: 'Built on more than 10 years of the financial technology expertise' },
  { badge: 'Revenue', value: '$24m', desc: 'Secured $12 million yearly revenue highlighting steady performance' },
  { badge: 'Users', value: '60k+', desc: 'Active user all over the world and they are happy to use this task' },
];

const values = [
  { icon: 'lucide:layout-dashboard', title: 'Custom workspace', desc: 'Work together effortlessly follow progress hypes' },
  { icon: 'lucide:trending-up', title: 'Track your success', desc: 'Work together effortlessly follow progress hypess' },
  { icon: 'lucide:blocks', title: 'Build in integration', desc: 'Work together effortlessly follow progress hypes' },
  { icon: 'lucide:users', title: 'Time collaboration', desc: 'Work together effortlessly follow progress hypes' },
];

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX', 'HyperLogistics'];

const integrations = ['Slack', 'Notion', 'HubSpot', 'Salesforce', 'Zapier', 'Google Drive', 'Shopify', 'Intercom'];
---

<Layout title="About Us — Zylo Platform" description="Learn about Zylo mission, core values, team metrics, and company growth.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page max-w-[1280px]">

      {/* 1. Inner Hero Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Innovation meets intent
        </span>
        <h1 class="hero-display mb-8">
          Where teams move <br class="hidden sm:inline" /> faster &amp; work gets done
        </h1>

        {/* 3D Preview Image Container */}
        <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden mt-8 max-w-4xl mx-auto">
          <img src="/home/zylo-hero.png" alt="Zylo Platform" class="w-full rounded-md block" />
        </div>
      </Reveal>

      {/* 2. Brand Marquee */}
      <Reveal delay={100} class="py-12 text-center border-y border-hairline mb-20">
        <p class="eyebrow mb-8">Trusted by <span class="text-ink">10,000+</span> businesses worldwide</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14">
          {brands.map((b) => (
            <span class="text-base font-medium text-steel tracking-tight">{b}</span>
          ))}
        </div>
      </Reveal>

      {/* 3. Mission Highlight */}
      <Reveal delay={120} class="text-center max-w-4xl mx-auto mb-20">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Know more about us
        </span>
        <h2 class="display-lg">
          When teams are stretched thin, our <span class="text-brand-annotate">AI support coordinator</span> takes care of the tasks so your staff can take care of people. More clients care by AI.
        </h2>
      </Reveal>

      {/* 4. Funfact Stats Cards */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80}>
            <div class="card h-full flex flex-col justify-between p-8">
              <div>
                <span class="eyebrow mb-8 inline-block rounded-full border border-hairline bg-surface px-3 py-1">
                  {s.badge}
                </span>
                <div class="display-lg mb-3">{s.value}</div>
              </div>
              <p class="p-sm">{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 5. Core Values Container Card */}
      <Reveal delay={150} class="rounded-lg bg-canvas-dark text-on-dark p-10 md:p-16 mb-20">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="eyebrow mb-4 inline-block rounded-full border border-hairline-dark bg-canvas/5 px-3 py-1 text-on-dark-muted">
            Core values guide everything
          </span>
          <h2 class="h2 text-on-dark">Core values guide everything</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map((v) => (
            <div class="rounded-lg border border-hairline-dark bg-canvas/5 p-6">
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-hairline-dark bg-canvas/5 text-brand mb-6">
                <Icon name={v.icon} class="w-5 h-5" />
              </div>
              <h3 class="h5 text-on-dark mb-2">{v.title}</h3>
              <p class="text-sm leading-[1.5] text-on-dark-muted">{v.desc}</p>
            </div>
          ))}
        </div>
      </Reveal>

      {/* 6. Integrations */}
      <Reveal delay={120} class="text-center max-w-5xl mx-auto mb-20">
        <h2 class="h2 mb-10">
          Seamless integration <br class="hidden sm:inline" /> with your entire tech stack
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
          {integrations.map((i) => (
            <div class="rounded-lg border border-hairline bg-canvas p-6 text-sm font-semibold text-ink">
              {i}
            </div>
          ))}
        </div>
        <a href="/integrations" class="btn-secondary btn-md">
          See all integrations <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </Reveal>

      {/* 7. Final CTA */}
      <Reveal class="text-center max-w-3xl mx-auto">
        <h2 class="h2 mb-6">
          Start planning smarter and more <br class="hidden sm:inline" /> meaningful user experiences
        </h2>
        <p class="p-rg mb-8">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <a href="/pricing" class="btn-accent btn-lg">
          Subscribe now <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </Reveal>

    </div>
  </main>

  <Footer />
</Layout>
