---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const definition =
  'An exercise used to organise a large number of data and ideas, sorting them into groups based on their natural relationships and into more meaningful categories. Affinity Diagramming is frequently used following brainstorming sessions.';

const termNames = [
  'AB testing',
  'Affinity diagramming',
  'Active listening',
  'Accessibility',
  'Affordance',
];
---

<Layout title="Web accessibility glossary — Zylo" description="Web accessibility is the inclusive practice of ensuring that people with disabilities do not face barriers that prevent interaction or access to websites on the World Wide Web.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-5xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl sm:text-6xl font-semibold text-ink font-heading tracking-tight mb-5">
          Web accessibility glossary
        </h1>
        <p class="text-lg text-steel leading-relaxed">
          Web accessibility is the inclusive practice of ensuring that people with disabilities
          do not face barriers that prevent interaction or access to websites on
          the World Wide Web.
        </p>
      </Reveal>

      {/* 2. A–Z letter filter */}
      <Reveal delay={80} class="mb-10">
        <div
          id="glossary-tabs"
          class="rounded-lg border border-hairline bg-canvas py-5 px-3 flex gap-2.5 justify-center flex-wrap shadow-[var(--shadow-subtle)]"
        >
          {letters.map((l, idx) => (
            <button
              type="button"
              data-letter={l}
              class:list={[
                'glossary-tab w-9 h-9 inline-flex justify-center items-center rounded-md text-lg font-semibold transition-all duration-300',
                idx === 0 ? 'bg-primary text-on-primary' : 'bg-surface-soft text-steel hover:text-brand',
              ]}
            >
              {l}
            </button>
          ))}
        </div>
      </Reveal>

      {/* 3. Glossary accordions */}
      <div class="mb-16">
        {letters.map((l, idx) => (
          <div class="glossary-panel" data-panel={l} hidden={idx !== 0}>
            <div class="rounded-lg border border-hairline bg-canvas p-6 md:p-10 shadow-[var(--shadow-subtle)]">
              <div class="flex flex-col gap-6">
                {termNames.map((t) => (
                  <details class="group rounded-lg border border-hairline overflow-hidden transition-all open:shadow-[var(--shadow-subtle)] open:bg-canvas">
                    <summary class="cursor-pointer list-none flex px-6 py-5 justify-between gap-4 items-center w-full">
                      <span class="font-semibold text-left text-lg text-ink font-heading flex items-center gap-4 flex-wrap">
                        <span class="font-semibold text-base bg-primary text-on-primary w-9 h-9 inline-flex justify-center items-center rounded-md flex-none">
                          {l}
                        </span>
                        {t}
                      </span>
                      <span class="flex-none w-8 h-8 border border-hairline inline-flex justify-center items-center rounded-full text-stone transition-transform duration-300 group-open:rotate-45">
                        <Icon name="lucide:plus" class="w-4 h-4" />
                      </span>
                    </summary>
                    <div class="px-6 pb-6 pl-[76px] max-sm:pl-6">
                      <p class="text-steel text-base leading-relaxed">{definition}</p>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.glossary-tab');
  const panels = document.querySelectorAll<HTMLElement>('.glossary-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const letter = tab.dataset.letter;

      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('bg-primary', active);
        t.classList.toggle('text-on-primary', active);
        t.classList.toggle('bg-surface-soft', !active);
        t.classList.toggle('text-steel', !active);
        t.classList.toggle('hover:text-brand', !active);
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== letter;
      });
    });
  });
</script>
