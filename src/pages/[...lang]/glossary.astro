---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const definition =
  'An exercise used to organise a large number of data and ideas, sorting them into groups based on their natural relationships and into more meaningful categories. Affinity Diagramming is frequently used following brainstorming sessions.';

const termNames = [
  'AB testing',
  'Affinity diagramming',
  'Active listening',
  'Accessibility',
  'Affordance',
];
---

<Layout title="Web accessibility glossary — Zylo" description="Web accessibility is the inclusive practice of ensuring that people with disabilities do not face barriers that prevent interaction or access to websites on the World Wide Web.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow mb-4 block">Glossary</span>
        <h1 class="h1 mb-5">
          Web accessibility glossary
        </h1>
        <p class="subtitle">
          Web accessibility is the inclusive practice of ensuring that people with disabilities
          do not face barriers that prevent interaction or access to websites on
          the World Wide Web.
        </p>
      </Reveal>

      {/* 2. A–Z pill filter row */}
      <Reveal delay={60} class="mb-12">
        <div id="glossary-tabs" class="flex flex-wrap justify-center gap-2">
          {letters.map((l, idx) => (
            <button
              type="button"
              data-letter={l}
              class:list={[
                'glossary-tab inline-flex h-9 w-9 items-center justify-center rounded-full text-sm font-medium transition-colors',
                idx === 0
                  ? 'bg-primary text-on-primary border border-primary'
                  : 'bg-canvas text-steel border border-hairline',
              ]}
            >
              {l}
            </button>
          ))}
        </div>
      </Reveal>

      {/* 3. Term card grid */}
      <div class="mb-24">
        {letters.map((l, idx) => (
          <div class="glossary-panel" data-panel={l} hidden={idx !== 0}>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {termNames.map((t) => (
                <div class="rounded-lg border border-hairline bg-canvas p-6 h-full">
                  <p class="p-lt mb-3">{l}</p>
                  <h2 class="h5 mb-3">{t}</h2>
                  <p class="p-sm">{definition}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">Put the terms to work</h2>
          <p class="p-rg mb-8">
            Zylo turns accessibility checks into automated workflow steps, so the standards above stay enforced on every release.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">Get started</a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to us</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.glossary-tab');
  const panels = document.querySelectorAll<HTMLElement>('.glossary-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const letter = tab.dataset.letter;

      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('bg-primary', active);
        t.classList.toggle('text-on-primary', active);
        t.classList.toggle('border-primary', active);
        t.classList.toggle('bg-canvas', !active);
        t.classList.toggle('text-steel', !active);
        t.classList.toggle('border-hairline', !active);
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== letter;
      });
    });
  });
</script>
