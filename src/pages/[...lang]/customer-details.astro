---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const meta = [
  { label: 'Industry', value: 'Fintech solutions' },
  { label: 'Company size', value: '5,000 – 10,000 employees' },
  { label: 'Founded', value: 'Since 1999' },
];

const socials = [
  { icon: 'lucide:facebook', label: 'Facebook' },
  { icon: 'lucide:instagram', label: 'Instagram' },
  { icon: 'lucide:twitter', label: 'Twitter' },
  { icon: 'lucide:linkedin', label: 'LinkedIn' },
];

const highlights = [
  { title: 'Product Quality:', desc: 'Automatically syncs across all your devices. You can also access them anywhere.' },
  { title: 'On Demand Design:', desc: 'Images, videos, PDFs and audio files are supported.' },
  { title: 'Choice of Service:', desc: 'Whatever your business needs, you can choose a service.' },
];
---

<Layout title="Customer Details — How Zensai Closed More Than USD 300K in ARR" description="How Zensai closed more than USD 300K in ARR within months of adding Zylo integrations.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-[240px_minmax(0,1fr)] xl:gap-16">
        {/* Left rail: meta panel */}
        <aside class="lg:block">
          <div class="flex flex-col gap-6 lg:sticky lg:top-28 lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto lg:pb-8">
            <a href="/customer" class="inline-flex items-center gap-2 text-sm font-medium text-steel transition-colors hover:text-ink">
              <Icon name="lucide:arrow-left" class="h-4 w-4" /> Customer
            </a>

            <div class="flex flex-col border-t border-hairline-soft">
              {meta.map((m) => (
                <div class="flex flex-col gap-1 border-b border-hairline-soft py-4">
                  <span class="eyebrow">{m.label}</span>
                  <span class="text-sm font-medium text-ink">{m.value}</span>
                </div>
              ))}
              <div class="flex flex-col gap-2 border-b border-hairline-soft py-4">
                <span class="eyebrow">Share</span>
                <div class="flex items-center gap-1.5">
                  {socials.map((s) => (
                    <a
                      href="#"
                      aria-label={s.label}
                      class="flex h-8 w-8 items-center justify-center rounded-sm border border-hairline bg-canvas text-steel transition-colors hover:bg-surface hover:text-ink"
                    >
                      <Icon name={s.icon} class="h-4 w-4" />
                    </a>
                  ))}
                </div>
              </div>
            </div>

            <a href="/contact" class="btn-primary btn-md w-full">
              Contact Us <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </aside>

        {/* Center: prose column */}
        <article class="w-full max-w-[720px]">
          <Reveal class="mb-10 border-b border-hairline pb-8">
            <h1 class="h1">
              How Zensai closed more than USD 300K in ARR within months of adding Zylo integrations
            </h1>
          </Reveal>

          <Reveal delay={80}>
            <img
              src="/placeholder.png"
              alt="Zensai customer story"
              loading="lazy"
              class="mb-10 aspect-[16/9] w-full rounded-lg border border-hairline-soft bg-surface object-contain p-4"
            />
          </Reveal>

          <Reveal delay={100} class="mb-10 flex flex-col gap-3 border-b border-hairline-soft pb-10">
            <h2 class="eyebrow">About</h2>
            <p class="p-rg">
              Zylo is a modern SaaS platform built to simplify business operations and accelerate growth. We help teams manage data, automate workflows, and make smarter decisions with a confidence. From startups to our enterprises, Zylo grows with your business.
            </p>
          </Reveal>

          <Reveal delay={150} class="flex flex-col gap-6">
            <section class="flex flex-col gap-4">
              <h2 class="h3">About Zensai</h2>
              <p class="p-rg">
                Zensai is an AI-powered clinical platform that helps physicians identify medical conditions and streamline their daily workflows. Leveraging proprietary algorithms, Regard reviews the complete patient record to surface key insights, strengthen documentation accuracy, and simplify routine clinical tasks. The platform improves communication across care teams and ensures documentation supports accurate reimbursement. By connecting clinical and operational processes, Regard enables health systems to unlock more value from their data, reduce administrative burden, enhance patient care, and improve financial performance reimagining the healthcare experience, one note at a time.
              </p>
            </section>

            <section class="mt-8 flex flex-col gap-4 border-t border-hairline-soft pt-8">
              <h2 class="h3">The Challenge: Delayed invoicing slowed month-end closes</h2>
              <p class="p-rg">
                Regard&rsquo;s finance workflows relied on spreadsheets, scattered inputs, and manual cross referencing. Tina Cui, VP of Finance, had to track contract terms, implementation changes, and rev rec schedules across different files and Slack threads.
              </p>

              <blockquote class="rounded-lg border border-hairline bg-surface-soft p-6">
                <Icon name="lucide:quote" class="mb-4 h-8 w-8 text-brand" />
                <p class="h5 mb-4 leading-[1.4]">
                  We're committed to changing the way of mobile UX. We believe that mobile UX has the power to make a real difference in people's lives.
                </p>
                <footer class="p-sm">
                  <span class="font-medium text-ink">Ralph Edwards</span>
                  <span class="text-stone"> &mdash; New York</span>
                </footer>
              </blockquote>
            </section>

            <section class="mt-8 flex flex-col gap-4 border-t border-hairline-soft pt-8">
              <h2 class="h3">Clarity across the supply chain</h2>
              <p class="p-rg">
                IT company content is important for a number of reasons. First, it can help you attract potential customers. When you create content that is relevant to your target audience, you position yourself as an expert in your field and increase the chances that potential customers will find you. IT company content can help you educate potential customers about your products and services.
              </p>
              <p class="p-rg">
                We are committed to providing our clients with the highest quality IT services and support. We understand that IT is essential for your business, and we will work tirelessly to help you achieve your business goals.
              </p>

              <div class="flex flex-col gap-4 pt-2">
                {highlights.map((h) => (
                  <div class="flex items-start gap-3">
                    <Icon name="lucide:check-circle" class="mt-0.5 h-5 w-5 shrink-0 text-brand" />
                    <p class="p-rg">
                      <span class="font-medium text-ink">{h.title}</span> {h.desc}
                    </p>
                  </div>
                ))}
              </div>
            </section>
          </Reveal>
        </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
