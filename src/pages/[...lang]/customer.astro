---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const filters = [
  { label: 'Product', options: ['Workflow Builder', 'AI Agent Builder', 'Database Connectors', 'API Orchestrator', 'Telemetry Logs'] },
  { label: 'Category', options: ['Operations', 'Development', 'Productivity', 'Finance', 'Analytics'] },
  { label: 'Use case', options: ['Task Automation', 'Data Syncing', 'Alert Systems', 'Incident Response', 'Reporting'] },
  { label: 'Industry', options: ['Technology', 'Logistics', 'Retail', 'Education', 'Healthcare'] },
];

const stories = [
  { title: 'How CloudScale addresses integration issues', tag: 'HRIS' },
  { title: 'How DataPivot closed more than USD 300K in ARR', tag: 'HRIS' },
  { title: 'VentureLab boosts team communication workflows', tag: 'HRIS' },
  { title: 'SaaSify simplifies project documentation', tag: 'HRIS' },
  { title: 'SecureBank automates marketing campaigns', tag: 'HRIS' },
  { title: 'FintechX enhances remote collaboration tools', tag: 'HRIS' },
  { title: 'HyperLogistics organizes daily workflow management', tag: 'HRIS' },
  { title: 'CloudScale streamlines task tracking systems', tag: 'HRIS' },
  { title: 'DataPivot improves customer relationship data', tag: 'HRIS' },
  { title: 'VentureLab powers agile business operations', tag: 'HRIS' },
  { title: 'SaaSify accelerates creative design processes', tag: 'HRIS' },
  { title: 'FintechX centralizes team productivity systems', tag: 'HRIS' },
];

const customerQuote = "This platform completely changed how our support team operates. From intelligent workflows to real-time analytics everything is designed to scale. We now handle more than double the number of support tickets with the same team without compromising service quality.";

const customerVoices = [
  { name: 'Richard Lee', role: 'Operations Director at CloudScale' },
  { name: 'Oliver Vance', role: 'Tech Lead at Fintech Flow' },
  { name: 'Rudra Ghosh', role: 'VP of Operations at HyperLogistics' },
  { name: 'Amelia Chen', role: 'VP of Product at VentureLab' },
];
---

<Layout title="Customer — Zylo Customers Are Reducing Churn" description="See how teams use Zylo to reduce churn and scale customer operations.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow mb-4 block">Customer</span>
        <h1 class="h1 mb-5">
          Zylo customers are reducing churn
        </h1>
        <p class="subtitle">
          Teams across support, revenue, and operations use Zylo to automate the work behind every account.
        </p>
      </Reveal>

      {/* 2. Filter row + search */}
      <Reveal delay={60} class="flex flex-wrap gap-3 justify-center mb-12">
        {filters.map((f) => (
          <select
            aria-label={f.label}
            class="h-10 w-[190px] max-w-full rounded-md border border-hairline bg-canvas px-4 text-sm text-steel focus:border-brand focus:outline-none"
          >
            <option>{f.label}</option>
            {f.options.map((o) => <option>{o}</option>)}
          </select>
        ))}
        <form class="relative w-full max-w-[280px]" action="#">
          <label class="sr-only" for="customer-search">Search...</label>
          <input
            id="customer-search"
            type="search"
            name="q"
            placeholder="Search..."
            class="h-10 w-full rounded-md border border-hairline bg-canvas pl-4 pr-10 text-sm text-ink placeholder:text-stone focus:border-brand focus:outline-none"
          />
          <button type="submit" aria-label="Search" class="absolute right-3 top-1/2 -translate-y-1/2 text-stone hover:text-ink transition-colors">
            <Icon name="lucide:search" class="w-4 h-4" />
          </button>
        </form>
      </Reveal>

      {/* 3. Customer story card grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
        {stories.map((s, idx) => (
          <Reveal delay={idx * 40}>
            <a href="/case-studies" class="group rounded-lg border border-hairline bg-canvas overflow-hidden h-full flex flex-col justify-between">
              <img
                src="/placeholder.png"
                alt={s.title}
                loading="lazy"
                class="aspect-[16/9] w-full border-b border-hairline-soft bg-surface object-contain p-4"
              />
              <h2 class="h5 mb-8 px-6 pt-6">{s.title}</h2>
              <div class="flex items-center justify-between px-6 pb-6">
                <span class="p-lt">{s.tag}</span>
                <span class="w-7 h-7 rounded-full border border-hairline bg-canvas text-ink flex items-center justify-center">
                  <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
                </span>
              </div>
            </a>
          </Reveal>
        ))}
      </div>

      {/* 4. Customer voices */}
      <Reveal class="text-center max-w-3xl mx-auto mb-10">
        <span class="eyebrow mb-4 block">Testimonials</span>
        <h2 class="h2">
          Experiences shared by our customers
        </h2>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-4">
        {customerVoices.map((c, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-lg border border-hairline bg-canvas p-6 h-full">
              <div class="flex items-center gap-3 mb-5">
                <img
                  src="/placeholder.png"
                  alt={c.name}
                  loading="lazy"
                  class="w-10 h-10 shrink-0 rounded-full border border-hairline bg-surface object-cover"
                />
                <div>
                  <h3 class="h6">{c.name}</h3>
                  <p class="p-lt">{c.role}</p>
                </div>
              </div>
              <p class="p-sm">&ldquo;{customerQuote}&rdquo;</p>
            </div>
          </Reveal>
        ))}
      </div>
    </section>

    {/* 5. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline mt-20">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">What workflows are you ready to scale?</h2>
          <p class="p-rg mb-8">
            Walk through a Zylo workflow with our team and see how we help you streamline operations.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/contact" class="btn-primary btn-lg">See how Zylo works</a>
            <a href="/case-studies" class="btn-secondary btn-lg">Read a case study</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
