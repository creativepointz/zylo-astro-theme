---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const testimonials = [
  { name: 'Richard Lee', role: 'Operations Director at CloudScale', rating: '5.0', quote: 'This platform completely changed how our support team operates. We now handle more than double the tickets with the same team.' },
  { name: 'Oliver Vance', role: 'Tech Lead at Fintech Flow', rating: '4.9', quote: 'Connecting our custom endpoints and databases took literally minutes. The execution reliability is unmatched.' },
  { name: 'Amelia Chen', role: 'VP of Product at VentureLab', rating: '4.8', quote: 'We saved over 150 hours per team member per month. The visual workflow canvas is extremely intuitive.' },
  { name: 'Noah Miller', role: 'Co-Founder at SaaSify', rating: '5.0', quote: 'Onboarding new teammates used to take days of training. Now, they can build and deploy working automations on day one.' },
  { name: 'George Wright', role: 'Director of Support at SecureBank', rating: '4.9', quote: 'Zylo has eliminated all manual data entry between our CRM and task tracking tools. Absolute lifesaver!' },
  { name: 'Ravi Ganatra', role: 'VP Operations at HyperLogistics', rating: '5.0', quote: 'The real-time trace logs let us debug broken API webhooks instantly. Our uptime has never been better.' },
  { name: 'Imdat Cimsit', role: 'CTO at DataPivot', rating: '4.9', quote: 'Zylo pays for itself in weeks. We automated all billing sync tasks and reduced custom scripting costs.' },
  { name: 'Trian Dominguez', role: 'Engineering Manager at Lovable', rating: '4.9', quote: 'We integrated Slack, Notion, and Jira with custom conditional alerts. Setup was completely code-free.' },
  { name: 'Sarah Jenkins', role: 'Product Lead at VentureLab', rating: '4.8', quote: 'The visual canvas and conditional logic triggers let us coordinate multi-step workflows without complex coding.' }
];
---

<Layout title="Testimonials — Experiences Shared by Our Customers" description="Read what customers say about Zylo AI automation platform.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow mb-4 block">Testimonials</span>
        <h1 class="h1 mb-5">
          Experiences shared by our customers
        </h1>
        <p class="subtitle">
          Operators, founders, and support leads on what changed after they automated their workflows with Zylo.
        </p>
      </Reveal>

      {/* 2. Four-column quote wall — one card promoted to the orange signature treatment */}
      <div class="columns-1 md:columns-2 lg:columns-4 gap-6 mb-24">
        {testimonials.map((t, idx) => (
          <Reveal class="break-inside-avoid mb-6 block">
            <div
              class={`rounded-lg p-6 ${
                idx === 4
                  ? 'bg-testimonial-orange text-on-dark'
                  : 'bg-canvas border border-hairline'
              }`}
            >
              <div class="flex items-center gap-3 mb-5">
                <img
                  src="/placeholder.png"
                  alt={t.name}
                  loading="lazy"
                  class={`w-10 h-10 shrink-0 rounded-full object-cover ${
                    idx === 4 ? 'border border-on-dark/30 bg-on-dark/20' : 'border border-hairline bg-surface'
                  }`}
                />
                <div>
                  <h2 class={`h6 ${idx === 4 ? 'text-on-dark' : ''}`}>{t.name}</h2>
                  <p class={`p-lt ${idx === 4 ? 'text-on-dark/80' : ''}`}>{t.role}</p>
                </div>
              </div>

              <p class={`p-sm mb-6 ${idx === 4 ? 'text-on-dark' : ''}`}>&ldquo;{t.quote}&rdquo;</p>

              <div class={`pt-5 border-t flex items-center gap-2 ${idx === 4 ? 'border-on-dark/25' : 'border-hairline'}`}>
                <div class={`flex items-center gap-1 ${idx === 4 ? 'text-on-dark' : 'text-brand'}`}>
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                </div>
                <span class={`text-sm font-semibold ${idx === 4 ? 'text-on-dark' : 'text-ink'}`}>{t.rating}</span>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </section>

    {/* 3. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">
            Start automating your team's workflow operations today
          </h2>
          <p class="p-rg mb-8">
            Zylo delivers a visually intuitive workflow builder, providing your team with smooth tool connections and reliable execution logs all in one platform.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">Subscribe now</a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to us</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
