---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const mainQuote = "Our growth plateaued until we started using Zylo. The AI spotted trends we never saw and guided us with actionable tips. With improved targeting, our customer acquisition cost dropped by 20%. Zylo pays for itself within weeks.";

const testimonials = [
  { name: 'Richard', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Oliver', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Richard', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Amelia', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Noah', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'George', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Ravi Ganatra', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Imdat Cimsit', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Trian Dominguez', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
];
---

<Layout title="Testimonials — Experiences Shared by Our Customers" description="Read what customers say about Zylo AI automation platform.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page max-w-6xl">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="eyebrow mb-4 block">
          Testimonials
        </span>
        <h1 class="h1">
          Experiences shared by our customers
        </h1>
      </Reveal>

      {/* 2. Testimonial Cards Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
        {testimonials.map((t, idx) => (
          <Reveal delay={idx * 60}>
            <div
              class={`rounded-lg p-8 h-full flex flex-col justify-between ${
                idx === 4
                  ? 'bg-testimonial-orange text-on-dark'
                  : 'bg-canvas border border-hairline'
              }`}
            >
              <div class="flex items-center gap-3 mb-6">
                <div
                  class={`w-10 h-10 rounded-full font-semibold flex items-center justify-center text-sm ${
                    idx === 4 ? 'bg-on-dark/20 text-on-dark' : 'bg-surface text-ink'
                  }`}
                >
                  {t.name[0]}
                </div>
                <div>
                  <h4 class={`font-semibold text-sm ${idx === 4 ? 'text-on-dark' : 'text-ink'}`}>{t.name}</h4>
                  <p class={`text-[13px] leading-[1.4] ${idx === 4 ? 'text-on-dark/80' : 'text-stone'}`}>{t.role}</p>
                </div>
              </div>

              <p class={`text-sm leading-[1.5] mb-6 ${idx === 4 ? 'text-on-dark' : 'text-steel'}`}>&ldquo;{t.quote}&rdquo;</p>

              <div class={`pt-6 border-t flex items-center gap-2 ${idx === 4 ? 'border-on-dark/25' : 'border-hairline'}`}>
                <div class={`flex items-center gap-1 ${idx === 4 ? 'text-on-dark' : 'text-brand'}`}>
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                </div>
                <span class={`text-sm font-semibold ${idx === 4 ? 'text-on-dark' : 'text-ink'}`}>{t.rating}</span>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Bottom CTA Banner */}
      <Reveal class="rounded-lg border border-hairline-dark bg-canvas-dark p-10 md:p-16 text-center">
        <h2 class="h2 text-on-dark mb-6">
          Start planning smarter and more meaningful user experiences
        </h2>
        <p class="text-base leading-[1.5] text-on-dark-muted mb-10 max-w-2xl mx-auto">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <form class="flex flex-wrap justify-center gap-3" action="#">
          <label class="sr-only" for="testimonial-email">Enter your email..</label>
          <input
            id="testimonial-email"
            type="email"
            name="email"
            placeholder="Enter your email.."
            class="h-10 w-full max-w-[300px] rounded-md bg-canvas px-4 text-sm text-ink placeholder:text-muted border border-hairline-dark focus:border-brand focus:outline-none"
          />
          <button type="submit" class="btn-on-dark btn-md">
            Subscribe now
          </button>
        </form>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
