---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const mainQuote = "Our growth plateaued until we started using Zylo. The AI spotted trends we never saw and guided us with actionable tips. With improved targeting, our customer acquisition cost dropped by 20%. Zylo pays for itself within weeks.";

const testimonials = [
  { name: 'Richard', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Oliver', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Richard', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Amelia', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Noah', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'George', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Ravi Ganatra', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Imdat Cimsit', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
  { name: 'Trian Dominguez', role: 'CEO SPX', rating: '4.9', quote: mainQuote },
];
---

<Layout title="Testimonials — Experiences Shared by Our Customers" description="Read what customers say about Zylo AI automation platform.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Testimonials
        </span>
        <h1 class="text-4xl sm:text-6xl font-bold text-slate-900 font-heading tracking-tight">
          Experiences shared by our customers
        </h1>
      </Reveal>

      {/* 2. Testimonial Cards Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
        {testimonials.map((t, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-all h-full flex flex-col justify-between">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full bg-brand text-white font-bold flex items-center justify-center font-heading text-sm">
                  {t.name[0]}
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 font-heading text-sm">{t.name}</h4>
                  <p class="text-xs text-slate-500">{t.role}</p>
                </div>
              </div>

              <p class="text-slate-700 text-sm leading-relaxed mb-6">&ldquo;{t.quote}&rdquo;</p>

              <div class="pt-6 border-t border-slate-100 flex items-center gap-2">
                <div class="flex items-center gap-1 text-amber-400">
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                  <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                </div>
                <span class="text-sm font-semibold text-slate-900">{t.rating}</span>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Bottom CTA Banner */}
      <Reveal class="rounded-3xl bg-slate-900 text-white p-10 md:p-16 shadow-2xl text-center">
        <h2 class="text-3xl md:text-5xl font-bold font-heading mb-6">
          Start planning smarter and more meaningful user experiences
        </h2>
        <p class="text-slate-300 text-base leading-relaxed mb-10 max-w-2xl mx-auto">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <form class="flex flex-wrap justify-center gap-3" action="#">
          <label class="sr-only" for="testimonial-email">Enter your email..</label>
          <input
            id="testimonial-email"
            type="email"
            name="email"
            placeholder="Enter your email.."
            class="h-12 w-full max-w-[300px] rounded-full bg-white px-6 text-sm text-slate-900 placeholder:text-slate-400 border border-transparent focus:border-brand focus:outline-none"
          />
          <button type="submit" class="inline-flex h-12 items-center justify-center rounded-full bg-brand px-8 text-xs font-semibold text-white hover:bg-brand-hover transition-colors">
            Subscribe now
          </button>
        </form>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
