---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const badges = [
  { icon: 'lucide:award', title: 'Rated #1 SaaS solution for business growth' },
  { icon: 'lucide:trending-up', title: 'Leader position winter 2026' },
  { icon: 'lucide:clock', title: 'Paid once a referral stays active for 30+ days' },
];

const steps = [
  {
    icon: 'lucide:send',
    title: 'Share referral link',
    desc: 'Share the unique referral link in your customer portal with your friends and family',
  },
  {
    icon: 'lucide:user-plus',
    title: 'Referral Sign up',
    desc: 'Each new unique customer you refer qualifies for bonus!',
  },
  {
    icon: 'lucide:wallet',
    title: 'Receive a payout',
    desc: 'You will earn pay-outs for each verified new referral',
  },
];

const faqs = [
  {
    q: 'How do I track my referrals?',
    a: 'You can track clicks, signups, and payout status in real-time directly from your referral dashboard.',
  },
  {
    q: 'Is there a limit on referrals?',
    a: 'No! You can refer as many companies and teams as you like. There are no earning caps on Zylo referrals.',
  },
  {
    q: 'How long must a referral stay active?',
    a: 'Referrals must remain active on a paid plan for at least 30 days to qualify for the payout.',
  },
  {
    q: 'What payout methods are supported?',
    a: 'We pay out earned referral rewards via PayPal or direct bank transfer at the end of each month.',
  },
  {
    q: 'Can I refer my own company?',
    a: 'No, self-referrals are not permitted and will not qualify for payouts.',
  },
];
---

<Layout title="Referral Program — Make up to $69.85 in commission" description="Make up to $69.85 in commission on every referred sale.">
  <Navbar />

  <main id="main" class="bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <span class="eyebrow mb-4 block">Referral program</span>
          <h1 class="h1 mb-5">Make up to $69.85 in commission on every referred sale.</h1>
          <p class="subtitle mx-auto max-w-xl">
            It's always easy to contact our top-rated support team.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/register" class="btn-primary btn-lg">
              Get your referral link <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
            <a href="#how-it-works" class="btn-secondary btn-lg">How it works</a>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Perk grid */}
    <section class="pb-20">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          {badges.map((b, idx) => (
            <Reveal delay={idx * 60}>
              <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
                <span class="icon-tile mb-4">
                  <Icon name={b.icon} class="h-4 w-4" />
                </span>
                <h2 class="h5">{b.title}</h2>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 3. How it works — numbered step row */}
    <section id="how-it-works" class="pb-24">
      <div class="container-page">
        <Reveal class="mx-auto mb-12 max-w-2xl text-center">
          <h2 class="h2 mb-4">How it works</h2>
          <p class="p-rg">
            Tell a friend about Zylo and earn money when they are active for 30+ days.
          </p>
        </Reveal>

        <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-hairline bg-hairline md:grid-cols-3">
          {steps.map((s, idx) => (
            <div class="bg-canvas p-6">
              <div class="mb-4 flex items-center gap-3">
                <span class="icon-tile">
                  <Icon name={s.icon} class="h-4 w-4" />
                </span>
                <span class="eyebrow">Step {idx + 1}</span>
              </div>
              <h3 class="h5 mb-2">{s.title}</h3>
              <p class="p-sm">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* 4. FAQ */}
    <section class="pb-24">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
          <Reveal class="lg:col-span-5">
            <h2 class="h2 mb-3">Need help?</h2>
            <p class="p-rg">Get quick answers and friendly assistance anytime you need.</p>
          </Reveal>

          <div class="space-y-3 lg:col-span-7">
            {faqs.map((f, idx) => (
              <Reveal delay={idx * 60}>
                <details class="group rounded-md border border-hairline-soft bg-canvas p-6">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                    <span class="h5">{f.q}</span>
                    <span class="shrink-0 text-stone transition-transform group-open:rotate-180">
                      <Icon name="lucide:chevron-down" class="h-4 w-4" />
                    </span>
                  </summary>
                  <p class="p-rg pt-4">{f.a}</p>
                </details>
              </Reveal>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* 5. Closing CTA band */}
    <section class="bg-surface-soft py-16 md:py-20">
      <div class="container-page">
        <Reveal class="mx-auto max-w-2xl text-center">
          <h2 class="h3 mb-4">Start referring today</h2>
          <p class="p-rg mb-8">
            Your referral link lives in the customer portal. Sign in, copy it and share it with your network.
          </p>
          <a href="/sign-in" class="btn-primary btn-lg">Open your portal</a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
