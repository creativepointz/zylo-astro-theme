---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const tiers = [
  {
    name: 'Starter affiliates',
    subtitle: 'New affiliate benefits:',
    items: ['Up to $25 per signup', 'Resource guide', 'Exclusive affiliate assets'],
  },
  {
    name: 'Advanced partners',
    subtitle: 'Send 100 signups in a month:',
    items: ['10% discount offer', 'Bonus Opportunities'],
  },
  {
    name: 'Premier partners',
    subtitle: 'Send 200 new signups in a month:',
    items: ['Custom reporting and creative', 'Dedicated landing pages', '1x1 account support'],
  },
];

const faqs = [
  {
    q: 'How does an AI resume builder work?',
    a: 'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.',
  },
  {
    q: 'Can the AI customize resumes for different jobs?',
    a: 'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.',
  },
  {
    q: 'Does it improve my chances of getting hired?',
    a: 'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.',
  },
  {
    q: 'Does it have templates for different industries?',
    a: 'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.',
  },
  {
    q: 'What file formats can I download (PDF, TXT, DOCX)?',
    a: 'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.',
  },
];
---

<Layout title="Affiliate Program — Let’s join our Zylo’s Affiliate program" description="Become an affiliate and get rewarded for sharing the world's fastest-growing productivity platform with your network.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Affiliate hero */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center mb-24">
        <Reveal class="lg:col-span-7">
          <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-6 leading-tight">
            Let’s join our Zylo’s Affiliate program
          </h1>
          <p class="text-lg text-slate-600 leading-relaxed mb-10">
            Become an affiliate and get rewarded for sharing the world's fastest-growing productivity platform with your network.
          </p>
          <a href="/register" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-brand px-8 text-sm font-semibold text-white hover:bg-brand-hover transition-colors shadow-lg">
            Join now <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>

        <Reveal delay={100} class="lg:col-span-5">
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="w-12 h-12 rounded-2xl bg-brand/10 text-brand flex items-center justify-center mb-6">
              <Icon name="lucide:dollar-sign" class="w-6 h-6" />
            </div>
            <p class="text-sm font-semibold text-slate-900 font-heading mb-2">Up to $25 per signup</p>
            <p class="text-xs text-slate-600 leading-relaxed">
              Share your link, track every referral and get paid for the workspaces you bring to Zylo.
            </p>
          </div>
        </Reveal>
      </div>

      {/* 2. Payment details */}
      <Reveal class="text-center max-w-3xl mx-auto mb-24">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Payment details
        </span>
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-4 leading-tight">
          Earn by helping others boost productivity
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          Get up to $25 for every new free workspace referral — no confusing conditions, just results.
        </p>
      </Reveal>

      {/* 3. Tiered Structure */}
      <Reveal class="text-center mb-10">
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight">
          Tiered Structure
        </h2>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24 items-stretch">
        {tiers.map((t, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm hover:border-brand/40 hover:shadow-lg transition-all h-full">
              <div class="border-b border-slate-100 pb-5 mb-7">
                <h3 class="text-xl font-bold text-slate-900 font-heading mb-2">{t.name}</h3>
                <p class="text-xs text-slate-500 font-medium">{t.subtitle}</p>
              </div>
              <ul class="space-y-3">
                {t.items.map((i) => (
                  <li class="flex items-center gap-2.5 text-xs text-slate-700 font-medium">
                    <Icon name="lucide:check" class="w-4 h-4 text-brand shrink-0" />
                    <span>{i}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 4. FAQ */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <Reveal class="lg:col-span-5">
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 font-heading tracking-tight mb-3">
            Need help?
          </h2>
          <p class="text-slate-600 leading-relaxed">
            Get quick answers and friendly assistance anytime you need.
          </p>
        </Reveal>

        <div class="lg:col-span-7 space-y-3">
          {faqs.map((f, idx) => (
            <Reveal delay={idx * 60}>
              <details class="group rounded-3xl border border-slate-200 bg-white px-7 py-5 shadow-sm">
                <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
                  <span class="text-base font-semibold text-slate-900 font-heading">{f.q}</span>
                  <span class="shrink-0 w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center text-slate-500 group-open:bg-slate-900 group-open:text-white transition-colors">
                    <Icon name="lucide:plus" class="w-4 h-4 group-open:hidden" />
                    <Icon name="lucide:minus" class="w-4 h-4 hidden group-open:block" />
                  </span>
                </summary>
                <p class="pt-4 text-sm text-slate-600 leading-relaxed">{f.a}</p>
              </details>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
