---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const perks = [
  {
    icon: 'lucide:dollar-sign',
    title: 'Up to $25 per signup',
    desc: 'Share your link, track every referral and get paid for the workspaces you bring to Zylo.',
  },
  {
    icon: 'lucide:bar-chart-3',
    title: 'A dashboard you can check',
    desc: 'Clicks, signups and pending payouts update daily, so you always know what a campaign earned.',
  },
  {
    icon: 'lucide:image',
    title: 'Assets ready to publish',
    desc: 'Copy blocks, screenshots and logos prepared for newsletters, videos and landing pages.',
  },
];

const steps = [
  {
    title: 'Apply in a few minutes',
    desc: 'Tell us where your audience is. Most applications are reviewed within two business days.',
  },
  {
    title: 'Share your link',
    desc: 'Drop your tracked link into posts, tutorials or newsletters and use the assets we supply.',
  },
  {
    title: 'Get paid monthly',
    desc: 'Verified signups are approved at the end of each month and paid out on your chosen method.',
  },
];

const tiers = [
  {
    name: 'Starter affiliates',
    subtitle: 'New affiliate benefits:',
    items: ['Up to $25 per signup', 'Resource guide', 'Exclusive affiliate assets'],
  },
  {
    name: 'Advanced partners',
    subtitle: 'Send 100 signups in a month:',
    items: ['10% discount offer', 'Bonus Opportunities'],
  },
  {
    name: 'Premier partners',
    subtitle: 'Send 200 new signups in a month:',
    items: ['Custom reporting and creative', 'Dedicated landing pages', '1x1 account support'],
  },
];

const faqs = [
  {
    q: 'How do I sign up?',
    a: 'Simply apply on our portal. Most applications are reviewed and approved within two business days.',
  },
  {
    q: 'How are payouts calculated?',
    a: 'You earn up to $25 for every new workspace referred to Zylo that stays active for 30+ days.',
  },
  {
    q: 'How often are payouts made?',
    a: 'Payouts are processed at the end of each month via PayPal or direct bank transfer.',
  },
  {
    q: 'Do you provide marketing assets?',
    a: 'Yes, we provide pre-built copy blocks, screenshots, logos, and banners to help you promote Zylo.',
  },
  {
    q: 'Can I offer discounts to my audience?',
    a: 'Advanced partners (sending 100+ signups/month) can get custom discount codes for their audience.',
  },
];
---

<Layout title="Affiliate Program — Let’s join our Zylo’s Affiliate program" description="Become an affiliate and get rewarded for sharing the world's fastest-growing productivity platform with your network.">
  <Navbar />

  <main id="main" class="bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <span class="eyebrow mb-4 block">Affiliate program</span>
          <h1 class="h1 mb-5">Let’s join our Zylo’s Affiliate program</h1>
          <p class="subtitle mx-auto max-w-2xl">
            Become an affiliate and get rewarded for sharing the world's fastest-growing productivity platform with your network.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/register" class="btn-primary btn-lg">
              Join now <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
            <a href="#tiers" class="btn-secondary btn-lg">See the tiers</a>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Perk grid */}
    <section class="pb-20">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          {perks.map((p, idx) => (
            <Reveal delay={idx * 60}>
              <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
                <span class="icon-tile mb-4">
                  <Icon name={p.icon} class="h-4 w-4" />
                </span>
                <h2 class="h5 mb-2">{p.title}</h2>
                <p class="p-sm">{p.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 3. Payment details + steps */}
    <section class="pb-20">
      <div class="container-page">
        <Reveal class="mx-auto mb-12 max-w-2xl text-center">
          <span class="eyebrow mb-4 block">Payment details</span>
          <h2 class="h2 mb-4">Earn by helping others boost productivity</h2>
          <p class="p-rg">
            Get up to $25 for every new free workspace referral — no confusing conditions, just results.
          </p>
        </Reveal>

        <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-hairline bg-hairline md:grid-cols-3">
          {steps.map((s, idx) => (
            <div class="bg-canvas p-6">
              <span class="eyebrow mb-3 block">Step {idx + 1}</span>
              <h3 class="h5 mb-2">{s.title}</h3>
              <p class="p-sm">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Tiered Structure */}
    <section id="tiers" class="pb-24">
      <div class="container-page">
        <Reveal class="mx-auto mb-10 max-w-2xl text-center">
          <h2 class="h2">Tiered Structure</h2>
        </Reveal>

        <div class="grid grid-cols-1 items-stretch gap-4 md:grid-cols-3">
          {tiers.map((t, idx) => (
            <Reveal delay={idx * 60}>
              <div class="flex h-full flex-col rounded-lg border border-hairline bg-canvas p-6">
                <div class="mb-6 border-b border-hairline-soft pb-5">
                  <h3 class="h5 mb-1">{t.name}</h3>
                  <p class="p-lt">{t.subtitle}</p>
                </div>
                <ul class="space-y-3">
                  {t.items.map((i) => (
                    <li class="flex items-start gap-2 p-sm">
                      <Icon name="lucide:check" class="mt-1 h-3.5 w-3.5 flex-none text-brand" />
                      <span>{i}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 5. FAQ */}
    <section class="pb-24">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
          <Reveal class="lg:col-span-5">
            <h2 class="h2 mb-3">Need help?</h2>
            <p class="p-rg">Get quick answers and friendly assistance anytime you need.</p>
          </Reveal>

          <div class="space-y-3 lg:col-span-7">
            {faqs.map((f, idx) => (
              <Reveal delay={idx * 60}>
                <details class="group rounded-md border border-hairline-soft bg-canvas p-6">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                    <span class="h5">{f.q}</span>
                    <span class="shrink-0 text-stone transition-transform group-open:rotate-180">
                      <Icon name="lucide:chevron-down" class="h-4 w-4" />
                    </span>
                  </summary>
                  <p class="p-rg pt-4">{f.a}</p>
                </details>
              </Reveal>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* 6. Closing CTA band */}
    <section class="bg-surface-soft py-16 md:py-20">
      <div class="container-page">
        <Reveal class="mx-auto max-w-2xl text-center">
          <h2 class="h3 mb-4">Ready to start sharing?</h2>
          <p class="p-rg mb-8">
            Create an account, grab your link and send your first referral today.
          </p>
          <a href="/register" class="btn-accent btn-lg">
            Join now <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
