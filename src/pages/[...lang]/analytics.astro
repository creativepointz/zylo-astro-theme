---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'HyperLogistics'];

const bodyOne =
  'Operations analytics and data visibility are critical to scaling your workflows. With Zylo, you get a centralized control plane for all your automated pipelines, helping your team identify bottlenecks and optimize resource usage across every connected tool. Keep your teams aligned with real-time dashboards.';

const bodyTwo =
  'We are committed to helping organizations run error-free automation at scale. We understand that data reliability and transparency are essential for your daily operations, and our analytics suite provides the insights needed to keep your business running smoothly.';

/* 5-up feature grid */
const featureGrid = [
  { icon: 'lucide:badge-check', title: 'Real-time Metrics', desc: 'Monitor task execution status, cost-savings, and run logs as they happen.' },
  { icon: 'lucide:palette', title: 'Custom Dashboards', desc: 'Create reports and visualize operational efficiency across multiple workspaces.' },
  { icon: 'lucide:settings-2', title: 'Flexible Integrations', desc: 'Connect database, CRM, and task data to build comprehensive performance reports.' },
  { icon: 'lucide:wallet', title: 'Error Tracking', desc: 'Instantly get notified of workflow failures and trace errors to specific API calls.' },
  { icon: 'lucide:sparkles', title: 'Resource Optimization', desc: 'Analyze run patterns to find bottlenecks and optimize cost-per-execution.' },
];

const serviceCards = [
  { icon: 'lucide:search-code', title: 'Deep Trace Logs', desc: 'Inspect every step of a workflow run. View inputs, outputs, and exact API response payloads to debug failures in seconds.' },
  { icon: 'lucide:bell-ring', title: 'Automated Alerting', desc: 'Set up real-time webhooks or Slack notifications to alert your engineering team when high-priority tasks fail.' },
  { icon: 'lucide:database', title: 'Custom Connectors', desc: 'Aggregate data from databases, webhooks, and third-party APIs into one unified metrics feed.' },
];

const visibilityPoints = [
  { icon: 'lucide:badge-check', title: 'Real-time Metrics:', desc: 'Monitor task execution status, cost-savings, and run logs as they happen.' },
  { icon: 'lucide:palette', title: 'Custom Dashboards:', desc: 'Create reports and visualize operational efficiency across multiple workspaces.' },
  { icon: 'lucide:settings-2', title: 'Error Tracking:', desc: 'Instantly get notified of workflow failures and trace errors to specific API calls.' },
];

const stats = [
  { value: '1 dashboard', label: 'Every source in one place' },
  { value: '40+', label: 'Data connectors available' },
  { value: 'Real time', label: 'Reports refresh as work happens' },
];
---

<Layout title="Your business. All your data. One powerful dashboard. — Zylo Analytics" description="Analytics and reporting built for visibility across your business data.">
  <Navbar />

  <main id="main" class="bg-canvas">

    {/* 1. Centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-4xl mx-auto">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Analytics
          </span>
          <h1 class="hero-display mb-6">
            Your business. All your data.<br class="hidden sm:inline" /> One powerful dashboard.
          </h1>
          <p class="subtitle max-w-2xl mx-auto mb-8">
            This section provides clear, helpful answers so users can resolve issues quickly without contacting support saving valuable time.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to sales</a>
          </div>
        </Reveal>

        <Reveal delay={120} class="mt-12 md:mt-16">
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden max-w-5xl mx-auto">
            <img src="/placeholder.png" alt="Zylo analytics dashboard" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Social proof strip */}
    <section class="border-y border-hairline py-12">
      <div class="container-page text-center">
        <Reveal>
          <p class="eyebrow mb-8">
            Reporting for <span class="text-ink">10,000+</span> teams across every plan
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center justify-items-center">
            {brands.map((b) => (
              <span class="p-lg font-medium tracking-tight text-steel">{b}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Feature grid — 5-up */}
    <section class="section">
      <div class="container-page">
        <Reveal class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="h2">Built for visibility</h2>
        </Reveal>
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
          {featureGrid.map((f, idx) => (
            <Reveal delay={idx * 60}>
              <div class="card h-full">
                <span class="icon-tile mb-5">
                  <Icon name={f.icon} class="w-5 h-5" />
                </span>
                <h3 class="h5 mb-2">{f.title}</h3>
                <p class="p-sm">{f.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Alternating feature rows */}
    <section class="pb-16 md:pb-24">
      <div class="container-page space-y-16 md:space-y-24">

        {/* Row 1 — text left */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal>
            <h2 class="h2 mb-5">Designed to adapt to your team.</h2>
            <p class="p-sm mb-4">{bodyOne}</p>
            <p class="p-sm">{bodyTwo}</p>
          </Reveal>
          <Reveal delay={100}>
            <div class="card space-y-7 p-8">
              {visibilityPoints.map((p) => (
                <div class="flex items-start gap-4">
                  <span class="icon-tile shrink-0">
                    <Icon name={p.icon} class="w-5 h-5" />
                  </span>
                  <div>
                    <h3 class="h5 mb-1">{p.title}</h3>
                    <p class="p-sm">{p.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </Reveal>
        </div>

        {/* Row 2 — text right */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal class="lg:order-2">
            <h2 class="h2 mb-5">The Challenge</h2>
            <p class="p-rg">
              Every growing team hits the same wall: data scattered across tools, reports that arrive too late, and decisions made on gut feel instead of evidence. Visibility is the fix.
            </p>
          </Reveal>
          <Reveal delay={100} class="lg:order-1">
            <div class="space-y-4">
              {serviceCards.map((c) => (
                <div class="card flex items-start gap-4">
                  <span class="icon-tile shrink-0">
                    <Icon name={c.icon} class="w-5 h-5" />
                  </span>
                  <div>
                    <h3 class="h5 mb-1 leading-snug">{c.title}</h3>
                    <p class="p-sm">{c.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </Reveal>
        </div>

        {/* Row 3 — text left */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal>
            <h2 class="h2 mb-5">Clarity across the supply chain</h2>
            <p class="p-sm mb-4">{bodyOne}</p>
            <p class="p-sm">{bodyTwo}</p>
          </Reveal>
          <Reveal delay={100}>
            <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
              <img src="/placeholder.png" alt="Zylo reporting view" class="w-full rounded-md block" />
            </div>
          </Reveal>
        </div>

      </div>
    </section>

    {/* 5. Stat row */}
    <section class="border-y border-hairline py-16">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          {stats.map((s, idx) => (
            <Reveal delay={idx * 80}>
              <div class="display-lg mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7. Closing CTA band */}
    <section class="section bg-surface-soft">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <h2 class="h2 mb-5">See the whole business in one view</h2>
          <p class="p-rg mb-8">
            Connect your tools, let Zylo do the reporting, and give every team the same numbers to work from.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to sales</a>
          </div>
        </Reveal>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
