---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const bodyOne =
  'IT company content is important for a number of reasons. First, it can help you attract potential customers. When you create content that is relevant to your target audience, you position yourself as an expert in your field and increase the chances that potential customers will find you. IT company content can help you educate potential customers about your products and services.';

const bodyTwo =
  'We are committed to providing our clients with the highest quality IT services and support. We understand that IT is essential for your business, and we will work tirelessly to help you achieve your business goals.';

const visibilityPoints = [
  { icon: 'lucide:badge-check', title: 'Product Quality:', desc: 'Automatically syncs across all your devices. You can also access your work offline.' },
  { icon: 'lucide:palette', title: 'On Demand Design:', desc: 'Images, videos, PDFs and audio files are supported.' },
  { icon: 'lucide:settings-2', title: 'Choice of Service:', desc: 'Whatever your business needs, you can choose a service.' },
];

const serviceCards = [
  { icon: 'lucide:bitcoin', title: 'Buy bitcoin with low fees', desc: 'Buy and sell instantly, stack with no-fee recurring purchases, or set target orders. Withdraw to cold storage anytime, for free.' },
  { icon: 'lucide:landmark', title: 'Borrow against bitcoin', desc: 'Access your wealth without selling. Get fast, flexible loans backed by bitcoin, with market-leading terms from Strike Lending.' },
  { icon: 'lucide:gem', title: 'Discover, buy, and Sell unique digital assets.', desc: 'Access and Interact with Multiple Blockchains Effortlessly.' },
];

const solutions = [
  { icon: 'lucide:wallet', title: 'All Wallets, One Hub', desc: 'One place to manage all your chains and wallets.' },
  { icon: 'lucide:sparkles', title: 'Wealth planning', desc: 'Use AI to tailor and automate your investments.' },
];
---

<Layout title="Your business. All your data. One powerful dashboard. — Zylo Analytics" description="Analytics and reporting built for visibility across your business data.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-24">
        <h1 class="text-4xl sm:text-6xl font-bold text-slate-900 font-heading tracking-tight leading-[1.08] mb-6">
          Your business. All your data.<br class="hidden sm:block" /> One powerful dashboard.
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
          This section provides clear, helpful answers so users can resolve issues quickly without contacting support saving valuable time.
        </p>
      </Reveal>

      {/* 2. Designed to adapt to your team. */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-24">
        <Reveal>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-6 leading-tight">
            Designed to adapt to your team.
          </h2>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">{bodyOne}</p>
          <p class="text-slate-600 text-sm leading-relaxed">{bodyTwo}</p>
        </Reveal>

        <Reveal delay={100} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10 shadow-sm">
          <h3 class="text-xl font-bold text-slate-900 font-heading mb-8">Built for visibility</h3>
          <div class="space-y-7">
            {visibilityPoints.map((p) => (
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-2xl bg-brand/10 text-brand flex items-center justify-center shrink-0">
                  <Icon name={p.icon} class="w-5 h-5" />
                </div>
                <div>
                  <h4 class="text-base font-bold text-slate-900 font-heading mb-1">{p.title}</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </Reveal>
      </div>

      {/* 3. The Challenge */}
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-5">
          The Challenge
        </h2>
        <p class="text-base text-slate-600 leading-relaxed">
          Every growing team hits the same wall: data scattered across tools, reports that arrive too late, and decisions made on gut feel instead of evidence. Visibility is the fix.
        </p>
      </Reveal>

      {/* 4. Service cards */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {serviceCards.map((c, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm hover:border-brand/40 hover:shadow-lg transition-all h-full">
              <div class="w-12 h-12 rounded-2xl bg-brand/10 text-brand flex items-center justify-center mb-6">
                <Icon name={c.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold text-slate-900 font-heading mb-3 leading-snug">{c.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{c.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 5. Solutions */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
        {solutions.map((s, idx) => (
          <Reveal delay={idx * 100}>
            <div class="rounded-3xl bg-slate-900 text-white p-8 md:p-10 shadow-xl h-full">
              <div class="w-12 h-12 rounded-2xl bg-white/10 text-brand flex items-center justify-center mb-6">
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-2xl font-bold font-heading mb-2">{s.title}</h3>
              <p class="text-slate-300 text-sm leading-relaxed">{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 6. Clarity across the supply chain */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <Reveal>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-6 leading-tight">
            Clarity across the supply chain
          </h2>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">{bodyOne}</p>
          <p class="text-slate-600 text-sm leading-relaxed">{bodyTwo}</p>
        </Reveal>

        <Reveal delay={100} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10 shadow-sm">
          <div class="space-y-7">
            {visibilityPoints.map((p) => (
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-2xl bg-brand/10 text-brand flex items-center justify-center shrink-0">
                  <Icon name={p.icon} class="w-5 h-5" />
                </div>
                <div>
                  <h3 class="text-base font-bold text-slate-900 font-heading mb-1">{p.title}</h3>
                  <p class="text-slate-600 text-sm leading-relaxed">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </Reveal>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
