---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const benefits = [
  'A collaborative environment where your voice matters',
  'Opportunities for growth and career development',
  'Vision benefits for you and your family',
  'Competitive salary and equity options',
  'Flexible (Unlimited) Paid Time Off',
  'Parental Leave',
];

const tabs = ['All', 'Bellevue, WA', 'UK, London'];

const departments = [
  {
    name: 'Design',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'Engineering',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Principal product engineer', location: 'Bethlehem PA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Product design engineer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'GTM',
    roles: [
      { title: 'Full Stack engineer', location: '19 Woronora Ave' },
      { title: 'Site reliability engineer', location: 'Bowen Island BC' },
    ],
  },
  {
    name: 'Recruiting',
    roles: [
      { title: 'Senior GTM engineer', location: 'Inglewood VIC' },
    ],
  },
  {
    name: "Can't find the role you're looking for?",
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
    ],
  },
];
---

<Layout title="Career — Join Us to Grow Your Career" description="Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page max-w-5xl">
      {/* 1. Hero Header */}
      <Reveal class="text-center max-w-4xl mx-auto mb-20">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Career
        </span>
        <h1 class="hero-display mb-6">
          Join us to grow your career
        </h1>
        <p class="subtitle max-w-2xl mx-auto">
          Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.
        </p>
      </Reveal>

      {/* 2. About Zylo */}
      <Reveal delay={100} class="mb-16">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          About Zylo
        </span>
        <h2 class="h2 mb-8">
          For enterprise leaders facing critical decisions, Zylo is the <span class="text-brand-annotate">Decision-Grade AI Platform</span> that delivers verified analysis at AI scale
        </h2>
        <p class="p-rg max-w-3xl">
          By connecting financial and operational signals into a single, governed model and applying AI agents for real-time analysis, Zylo provides executives with the clarity and speed needed to lead in the AI era.
        </p>
      </Reveal>

      {/* 3. Benifits */}
      <Reveal delay={120} class="card p-8 md:p-12 mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <h2 class="h4">Benifits</h2>
          <ul class="lg:col-span-2 space-y-4">
            {benefits.map((b) => (
              <li class="flex items-start gap-3 text-base leading-[1.5] text-ink">
                <Icon name="lucide:check-circle" class="w-4 h-4 text-brand shrink-0 mt-1" />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </Reveal>

      {/* 4. Open Roles */}
      <Reveal delay={150} class="card p-8 md:p-12">
        <div class="flex flex-wrap justify-between items-start gap-4 mb-12">
          <div class="flex flex-wrap gap-2" id="career-tabs">
            {tabs.map((t, i) => (
              <button
                type="button"
                class:list={[
                  'career-tab cursor-pointer rounded-full border px-4 py-2 text-sm font-medium transition',
                  i === 0 ? 'bg-primary border-primary text-on-primary' : 'border-hairline bg-canvas text-steel',
                ]}
              >
                {t}
              </button>
            ))}
          </div>
          <div class="relative">
            <Icon name="lucide:search" class="w-4 h-4 text-stone absolute left-3 top-1/2 -translate-y-1/2" />
            <input
              type="search"
              placeholder="Search..."
              class="h-10 w-full sm:w-64 rounded-md border border-hairline bg-canvas pl-9 pr-4 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none"
            />
          </div>
        </div>

        <div class="space-y-12">
          {departments.map((dept) => (
            <div>
              <h2 class="h4 mb-6">{dept.name}</h2>
              <div class="flex flex-col">
                {dept.roles.map((r) => (
                  <a href="/career-details" class="group flex flex-wrap gap-3 justify-between items-center py-4 border-b border-hairline-soft transition-colors hover:bg-surface-soft">
                    <span class="p-sm group-hover:text-ink transition-colors">{r.title}</span>
                    <div class="flex flex-wrap items-center gap-6">
                      <span class="p-sm">{r.location}</span>
                      <span class="inline-flex items-center gap-2 text-sm font-medium text-ink">
                        Apply now <Icon name="lucide:arrow-right" class="w-3 h-3" />
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll('#career-tabs .career-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#career-tabs .career-tab').forEach((b) => {
        b.classList.remove('bg-primary', 'border-primary', 'text-on-primary');
        b.classList.add('border-hairline', 'bg-canvas', 'text-steel');
      });
      btn.classList.remove('border-hairline', 'bg-canvas', 'text-steel');
      btn.classList.add('bg-primary', 'border-primary', 'text-on-primary');
    });
  });
</script>
