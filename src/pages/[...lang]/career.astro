---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const stats = [
  { value: '10', label: 'Open roles across four teams' },
  { value: '2', label: 'Hubs — Bellevue, WA and London, UK' },
  { value: '30+', label: 'Countries our teammates work from' },
];

const benefits = [
  { icon: 'lucide:users', title: 'A collaborative environment where your voice matters' },
  { icon: 'lucide:trending-up', title: 'Opportunities for growth and career development' },
  { icon: 'lucide:eye', title: 'Vision benefits for you and your family' },
  { icon: 'lucide:badge-dollar-sign', title: 'Competitive salary and equity options' },
  { icon: 'lucide:calendar', title: 'Flexible (Unlimited) Paid Time Off' },
  { icon: 'lucide:heart', title: 'Parental Leave' },
];

const tabs = ['All', 'Bellevue, WA', 'UK, London'];

const departments = [
  {
    name: 'Design',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'Engineering',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Principal product engineer', location: 'Bethlehem PA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Product design engineer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'GTM',
    roles: [
      { title: 'Full Stack engineer', location: '19 Woronora Ave' },
      { title: 'Site reliability engineer', location: 'Bowen Island BC' },
    ],
  },
  {
    name: 'Recruiting',
    roles: [
      { title: 'Senior GTM engineer', location: 'Inglewood VIC' },
    ],
  },
];
---

<Layout title="Career — Join Us to Grow Your Career" description="Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.">
  <Navbar />

  <main id="main" class="bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <span class="eyebrow mb-4 block">Career</span>
          <h1 class="h1 mb-5">Join us to grow your career</h1>
          <p class="subtitle mx-auto max-w-2xl">
            Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="#open-roles" class="btn-primary btn-lg">See open roles</a>
            <a href="/about-us" class="btn-secondary btn-lg">About Zylo</a>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Stat row */}
    <section class="pb-16">
      <div class="container-page">
        <Reveal class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-hairline bg-hairline sm:grid-cols-3">
          {stats.map((s) => (
            <div class="bg-canvas p-6 text-center">
              <div class="h2 mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </div>
          ))}
        </Reveal>
      </div>
    </section>

    {/* 3. About Zylo */}
    <section class="pb-16">
      <div class="container-page">
        <Reveal class="grid grid-cols-1 gap-10 lg:grid-cols-12">
          <div class="lg:col-span-5">
            <span class="eyebrow mb-4 block">About Zylo</span>
            <h2 class="h3">
              For enterprise leaders facing critical decisions, Zylo is the <span class="text-brand-annotate">Decision-Grade AI Platform</span> that delivers verified analysis at AI scale
            </h2>
          </div>
          <div class="lg:col-span-7 lg:pt-10">
            <p class="p-rg">
              By connecting financial and operational signals into a single, governed model and applying AI agents for real-time analysis, Zylo provides executives with the clarity and speed needed to lead in the AI era.
            </p>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 4. Benefit grid */}
    <section class="pb-20">
      <div class="container-page">
        <Reveal class="mb-8">
          <h2 class="h3">Benifits</h2>
        </Reveal>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {benefits.map((b, idx) => (
            <Reveal delay={idx * 60}>
              <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
                <span class="icon-tile mb-4">
                  <Icon name={b.icon} class="h-4 w-4" />
                </span>
                <h3 class="h5">{b.title}</h3>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 5. Open roles — filter tabs + grouped listing rows */}
    <section id="open-roles" class="pb-24">
      <div class="container-page">
        <Reveal class="mb-10 flex flex-wrap items-start justify-between gap-4">
          <div class="flex flex-wrap gap-2" id="career-tabs">
            {tabs.map((t, i) => (
              <button
                type="button"
                class:list={[
                  'career-tab cursor-pointer rounded-full border px-4 py-2 text-sm font-medium transition',
                  i === 0 ? 'bg-primary border-primary text-on-primary' : 'border-hairline bg-canvas text-steel',
                ]}
              >
                {t}
              </button>
            ))}
          </div>
          <div class="relative">
            <Icon name="lucide:search" class="w-4 h-4 text-stone absolute left-3 top-1/2 -translate-y-1/2" />
            <input
              type="search"
              placeholder="Search..."
              class="h-10 w-full sm:w-64 rounded-md border border-hairline bg-canvas pl-9 pr-4 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none"
            />
          </div>
        </Reveal>

        <div class="space-y-12">
          {departments.map((dept, idx) => (
            <Reveal delay={idx * 60}>
              <h2 class="h5 mb-2 text-steel">{dept.name}</h2>
              <div class="flex flex-col border-t border-hairline-soft">
                {dept.roles.map((r) => (
                  <a href="/career-details" class="group flex flex-wrap items-center justify-between gap-3 border-b border-hairline-soft py-4 transition-colors hover:bg-surface-soft">
                    <span class="text-base font-medium text-ink">{r.title}</span>
                    <div class="flex flex-wrap items-center gap-6">
                      <span class="p-sm">{r.location}</span>
                      <span class="inline-flex items-center gap-2 text-sm font-medium text-ink">
                        Apply now <Icon name="lucide:arrow-right" class="w-3 h-3" />
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 6. Closing CTA band */}
    <section class="bg-surface-soft py-16 md:py-20">
      <div class="container-page">
        <Reveal class="mx-auto max-w-2xl text-center">
          <h2 class="h3 mb-4">Can't find the role you're looking for?</h2>
          <p class="p-rg mb-8">
            Send us a note about the work you want to do. We open new roles across product, engineering and go-to-market throughout the year.
          </p>
          <a href="/contact" class="btn-primary btn-lg">Get in touch</a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll('#career-tabs .career-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#career-tabs .career-tab').forEach((b) => {
        b.classList.remove('bg-primary', 'border-primary', 'text-on-primary');
        b.classList.add('border-hairline', 'bg-canvas', 'text-steel');
      });
      btn.classList.remove('border-hairline', 'bg-canvas', 'text-steel');
      btn.classList.add('bg-primary', 'border-primary', 'text-on-primary');
    });
  });
</script>
