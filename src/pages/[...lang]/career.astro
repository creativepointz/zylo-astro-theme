---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const benefits = [
  'A collaborative environment where your voice matters',
  'Opportunities for growth and career development',
  'Vision benefits for you and your family',
  'Competitive salary and equity options',
  'Flexible (Unlimited) Paid Time Off',
  'Parental Leave',
];

const tabs = ['All', 'Bellevue, WA', 'UK, London'];

const departments = [
  {
    name: 'Design',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'Engineering',
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Principal product engineer', location: 'Bethlehem PA' },
      { title: 'Senior product designer', location: 'Netherlands WA' },
      { title: 'Product design engineer', location: 'Netherlands WA' },
    ],
  },
  {
    name: 'GTM',
    roles: [
      { title: 'Full Stack engineer', location: '19 Woronora Ave' },
      { title: 'Site reliability engineer', location: 'Bowen Island BC' },
    ],
  },
  {
    name: 'Recruiting',
    roles: [
      { title: 'Senior GTM engineer', location: 'Inglewood VIC' },
    ],
  },
  {
    name: "Can't find the role you're looking for?",
    roles: [
      { title: 'Senior product designer', location: 'Netherlands WA' },
    ],
  },
];
---

<Layout title="Career — Join Us to Grow Your Career" description="Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-5xl mx-auto px-4">
      {/* 1. Hero Header */}
      <Reveal class="text-center max-w-4xl mx-auto mb-20">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Career
        </span>
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-bold text-slate-900 font-heading tracking-tight leading-[1.05] mb-6">
          Join us to grow your career
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed font-normal">
          Join us to work with passionate people who are shaping smarter, faster, and more impactful digital products.
        </p>
      </Reveal>

      {/* 2. About Zylo */}
      <Reveal delay={100} class="mb-16">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          About Zylo
        </span>
        <h2 class="text-2xl sm:text-4xl font-medium text-slate-900 font-heading tracking-tight leading-snug mb-8">
          For enterprise leaders facing critical decisions, Zylo is the <span class="text-brand font-bold">Decision-Grade AI Platform</span> that delivers verified analysis at AI scale
        </h2>
        <p class="text-base text-slate-600 leading-relaxed max-w-3xl">
          By connecting financial and operational signals into a single, governed model and applying AI agents for real-time analysis, Zylo provides executives with the clarity and speed needed to lead in the AI era.
        </p>
      </Reveal>

      {/* 3. Benifits */}
      <Reveal delay={120} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-12 shadow-sm mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <h2 class="text-2xl font-bold text-slate-900 font-heading">Benifits</h2>
          <ul class="lg:col-span-2 space-y-4">
            {benefits.map((b) => (
              <li class="flex items-start gap-3 text-base font-medium text-slate-900">
                <Icon name="lucide:check-circle" class="w-4 h-4 text-emerald-500 shrink-0 mt-1" />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </Reveal>

      {/* 4. Open Roles */}
      <Reveal delay={150} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-12 shadow-sm">
        <div class="flex flex-wrap justify-between items-start gap-4 mb-12">
          <div class="flex flex-wrap gap-2" id="career-tabs">
            {tabs.map((t, i) => (
              <button
                type="button"
                class:list={[
                  'career-tab px-7 py-3 border text-sm rounded-full font-medium transition cursor-pointer',
                  i === 0 ? 'bg-brand border-brand text-white' : 'border-slate-200 text-slate-900 hover:border-brand',
                ]}
              >
                {t}
              </button>
            ))}
          </div>
          <div class="relative">
            <Icon name="lucide:search" class="w-4 h-4 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2" />
            <input
              type="search"
              placeholder="Search..."
              class="h-12 w-full sm:w-64 rounded-full border border-slate-200 pl-10 pr-4 text-sm text-slate-900 focus:border-brand focus:outline-none"
            />
          </div>
        </div>

        <div class="space-y-12">
          {departments.map((dept) => (
            <div>
              <h2 class="text-2xl md:text-3xl font-medium text-slate-900 font-heading mb-6">{dept.name}</h2>
              <div class="flex flex-col">
                {dept.roles.map((r) => (
                  <a href="/career-details" class="group flex flex-wrap gap-3 justify-between items-center py-5 border-b border-slate-200 hover:bg-slate-50 transition-colors">
                    <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">{r.title}</span>
                    <div class="flex flex-wrap items-center gap-6">
                      <span class="text-sm text-slate-600">{r.location}</span>
                      <span class="inline-flex items-center gap-2 text-base font-medium text-brand">
                        Apply now <Icon name="lucide:arrow-right" class="w-3 h-3" />
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll('#career-tabs .career-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#career-tabs .career-tab').forEach((b) => {
        b.classList.remove('bg-brand', 'border-brand', 'text-white');
        b.classList.add('border-slate-200', 'text-slate-900', 'hover:border-brand');
      });
      btn.classList.remove('border-slate-200', 'text-slate-900', 'hover:border-brand');
      btn.classList.add('bg-brand', 'border-brand', 'text-white');
    });
  });
</script>
