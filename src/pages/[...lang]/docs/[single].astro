---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import { Icon } from 'astro-icon/components';
import { categories, type DocCategory } from '@/lib/data/docs';
import { generateEntryPaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generateEntryPaths(
    categories,
    (doc) => ({ single: doc.slug }),
    (doc) => ({ doc }),
  );
}

const { doc } = Astro.props as { doc: DocCategory };

// Left sidebar navigation
const nav = [
  {
    label: 'Getting Started',
    icon: 'lucide:circle-arrow-right',
    open: true,
    items: [
      { label: 'Build Your First Agent' },
      { label: 'Invite Your Team', active: true },
      { label: 'Connect a Tool' }
    ]
  },
  { label: 'Settings', icon: 'lucide:settings' },
  { label: 'Ask and Search', icon: 'lucide:map-pin' },
  { label: 'Building Agents', icon: 'lucide:bot' },
  { label: 'Collaboration', icon: 'lucide:message-square' },
  { label: 'Templates', icon: 'lucide:layout-template', leaf: true },
  { label: 'Workflows & Triggers', icon: 'lucide:workflow' },
  { label: 'Import & Export', icon: 'lucide:arrow-down-up' },
  { label: 'API & Integrations', icon: 'lucide:box' },
  { label: 'Security', icon: 'lucide:shield-check' },
  { label: 'Monitoring & Logs', icon: 'lucide:activity' },
  { label: 'Pricing & Billing', icon: 'lucide:circle-dollar-sign' },
  { label: 'Support & Bug Reports', icon: 'lucide:life-buoy' }
];

const roles = [
  'Owners: Every workspace has a single owner who has full permission to manage all settings in a workspace, including deleting the workspace.',
  'Admins: Admins can access most workspace settings, including updating the billing options, and adding or removing workspace members. After the owner, every additional workspace member in a Free workspace is an admin by default.',
  'Creators (paid plans only): Creators can build, edit, and run agents, but can’t access workspace settings or add new members.',
  'Commenters (paid plans only): Commenter is a user role for members of Pro and Business workspaces that allows them to browse the workspace, and open, view, and comment on agents without extra cost.'
];

// Right "On this page" table of contents
const toc = [
  { label: 'Getting started', id: 'getting-started' },
  { label: 'Install the GitHub App', id: 'install-app', sub: true },
  { label: 'Authorize your GitHub account', id: 'authorize', sub: true },
  { label: 'Editing workflows', id: 'editing-workflows' },
  { label: 'Code-based workflow', id: 'code-workflow' },
  { label: 'Install the CLI', id: 'install-cli', sub: true },
  { label: 'Edit the documentation', id: 'edit-docs', sub: true },
  { label: 'Preview the changes', id: 'preview', sub: true },
  { label: 'Push the changes', id: 'push', sub: true },
  { label: 'Web editor workflow', id: 'web-editor' },
  { label: 'Access the web editor', id: 'access-editor', sub: true },
  { label: 'Edit the documentation', id: 'edit-docs-2', sub: true },
  { label: 'Publish your changes', id: 'publish', sub: true },
  { label: 'Adding a custom domain', id: 'custom-domain' },
  { label: 'Next steps', id: 'next-steps', active: true },
  { label: 'Troubleshooting', id: 'troubleshooting' }
];
---

<Layout title={`${doc.name} — Zylo Docs`} description={doc.description}>
  <Navbar />
  <main id="main" class="relative bg-canvas pt-24 md:pt-[120px] pb-8">
    <div class="w-full px-6 md:px-12">
      <div class="grid gap-10 lg:grid-cols-[260px_minmax(0,1fr)_286px] xl:gap-16">
        <!-- Left: doc navigation -->
        <aside class="hidden lg:block">
          <div class="sticky top-28 flex max-h-[calc(100vh-8rem)] flex-col gap-6 overflow-y-auto pb-8">
            <!-- Search -->
            <label class="flex h-10 items-center gap-2 rounded-md border border-hairline bg-canvas px-3 transition focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/30">
              <Icon name="lucide:search" class="h-5 w-5 shrink-0 text-stone" />
              <input
                type="text"
                placeholder="How can we help?"
                class="min-w-0 flex-1 bg-transparent text-sm text-ink placeholder:text-stone focus:outline-none"
              />
            </label>

            <!-- Nav tree -->
            <nav class="flex flex-col gap-1 text-sm">
              {nav.map((group) => (
                <div>
                  <button
                    type="button"
                    class="flex w-full items-center justify-between rounded-md px-2 py-2 text-ink transition-colors hover:bg-surface-soft"
                  >
                    <span class="flex items-center gap-2">
                      <Icon name={group.icon} stroke-width={1.75} class="h-5 w-5 text-brand" />
                      {group.label}
                    </span>
                    {!group.leaf && (
                      <Icon
                        name="lucide:chevron-down"
                        class={`h-4 w-4 text-stone transition-transform ${group.open ? 'rotate-180' : ''}`}
                      />
                    )}
                  </button>
                  {group.items && (
                    <div class="mt-1 flex flex-col">
                      {group.items.map((item) => (
                        <a
                          href="#"
                          class={`rounded-md py-2 pl-9 pr-2 transition-colors hover:text-brand ${
                            item.active ? 'font-medium text-brand' : 'text-steel'
                          }`}
                        >
                          {item.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Center: article -->
        <article class="mx-auto w-full max-w-[720px]">
          <!-- Breadcrumb -->
          <nav class="mb-12 flex items-center gap-2 text-sm text-stone">
            <a href="/docs" class="flex items-center gap-1.5 transition-colors hover:text-brand">
              <Icon name="lucide:circle-arrow-right" class="h-5 w-5" />
              Docs
            </a>
            <span class="text-on-dark-muted">/</span>
            <span class="text-ink">{doc.name}</span>
          </nav>

          <!-- Title -->
          <header class="mb-10 flex flex-col gap-2">
            <h1 class="h4 text-ink">{doc.name}</h1>
            <p class="p-rg text-stone">{doc.description}</p>
          </header>

          <div class="article-body flex flex-col gap-6">
            <!-- Premium note -->
            <p class="p-rg text-steel">
              ⭐️ This is a premium feature.
              <a href="/pricing" class="font-medium text-ink underline underline-offset-2 hover:text-brand">
                Find out more about our paid plans
              </a>
            </p>

            <p class="p-rg text-steel">
              Workspace roles allow each workspace to set up granular controls that manage what users have
              access to. With roles you can set up permissions for agents, folders, billing settings,
              and workspace management.
            </p>

            <p class="p-rg text-steel">Workspaces have five types of users:</p>

            <!-- Roles list -->
            <ul class="flex flex-col gap-3">
              {roles.map((role) => (
                <li class="flex gap-3">
                  <Icon name="lucide:chevron-right" class="mt-1 h-4 w-4 shrink-0 text-brand" />
                  <span class="p-rg text-steel">{role}</span>
                </li>
              ))}
            </ul>

            <!-- Image placeholder -->
            <div class="aspect-[700/437] w-full overflow-hidden rounded-md border border-hairline bg-gradient-to-br from-surface to-hairline"></div>

            <!-- Section -->
            <section id="edit-docs" class="mt-6 flex scroll-mt-28 flex-col gap-4">
              <h2 class="h6 text-ink">Change the workspace role</h2>
              <p class="p-rg text-steel">
                If you're the owner or an admin in a Pro workspace, navigate to the
                <strong class="font-semibold text-ink">Workspace members</strong> page, which is
                accessible from the workspace drop-down menu (next to the name of your workspace). Next to each
                member you'll find the option to change their role from an admin to creator and vice versa. As
                the owner, you'll also have the option to change the owner role from yourself to another member.
                Please note that notifications will not be sent when a user's role has been changed.
              </p>
              <div class="aspect-[656/358] w-full overflow-hidden rounded-md border border-hairline bg-gradient-to-br from-surface to-hairline"></div>
            </section>

            <section id="next-steps" class="mt-6 flex scroll-mt-28 flex-col gap-4">
              <h2 class="h6 text-ink">Change the workspace role</h2>
              <p class="p-rg text-steel">
                If you're the owner or an admin in a Pro workspace, navigate to the
                <strong class="font-semibold text-ink">Workspace members</strong> page, which is
                accessible from the workspace drop-down menu (next to the name of your workspace). Next to each
                member you'll find the option to change their role from an admin to creator and vice versa. As
                the owner, you'll also have the option to change the owner role from yourself to another member.
                Please note that notifications will not be sent when a user's role has been changed.
              </p>
            </section>

            <!-- Feedback card -->
            <div class="mt-6 flex flex-col gap-4 rounded-md border border-hairline p-6">
              <div class="flex items-center gap-2">
                <Icon name="lucide:mail" class="h-6 w-6 shrink-0 text-stone" />
                <p class="flex-1 text-sm text-ink">
                  Still Stuck?
                  <a href="#" class="text-brand hover:underline">How can we Help?</a>
                </p>
                <span class="text-sm text-stone">Updated on February 17, 2022</span>
              </div>
              <hr class="border-hairline" />
              <div class="flex items-center justify-between">
                <p class="text-sm text-ink">Was this article helpful to you?</p>
                <div class="flex items-center gap-4">
                  <button type="button" aria-label="Yes" class="text-stone transition-colors hover:text-brand">
                    <Icon name="lucide:thumbs-up" class="h-6 w-6" />
                  </button>
                  <button type="button" aria-label="No" class="text-stone transition-colors hover:text-brand">
                    <Icon name="lucide:thumbs-down" class="h-6 w-6" />
                  </button>
                </div>
              </div>
            </div>

            <!-- Prev / Next -->
            <div class="mt-6 flex items-center justify-between gap-4">
              <a href="#" class="flex items-center gap-2.5 text-sm text-ink transition-colors hover:text-brand">
                <Icon name="lucide:arrow-left" class="h-5 w-5 shrink-0" />
                <span class="truncate">Build Your First Agent</span>
              </a>
              <a href="#" class="flex items-center gap-2.5 text-sm text-brand transition-colors hover:underline">
                <span class="truncate">Connect a Tool</span>
                <Icon name="lucide:arrow-right" class="h-5 w-5 shrink-0" />
              </a>
            </div>
          </div>
        </article>

        <!-- Right: on this page -->
        <aside class="hidden lg:block">
          <nav class="sticky top-28 flex max-h-[calc(100vh-8rem)] flex-col gap-6 overflow-y-auto rounded-md border border-hairline-soft bg-canvas px-8 py-5">
            <div class="flex items-center gap-3 text-sm text-ink">
              <Icon name="lucide:list" class="h-4 w-4 text-brand" />
              On this page
            </div>
            <ul class="flex flex-col">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class={`block border-l py-1 text-sm transition-colors hover:text-brand ${
                      item.sub ? 'pl-8' : 'pl-4'
                    } ${
                      item.active
                        ? 'border-brand font-medium text-ink'
                        : 'border-hairline-soft ' + (item.sub ? 'text-stone' : 'text-ink')
                    }`}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
