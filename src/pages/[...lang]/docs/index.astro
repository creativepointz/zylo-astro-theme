---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import { Icon } from 'astro-icon/components';
import { categories } from '@/lib/data/docs';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}
---

<Layout
  title="Documentation — Zylo"
  description="Everything you need to set up, customize, and get the most out of Zylo."
>
  <Navbar />
  <main id="main">
    <!-- Hero -->
    <section
      class="relative overflow-hidden pt-40 pb-24 md:pt-48"
      style="background: radial-gradient(46.71% 46.71% at 50% 0%, rgba(79, 70, 229, 0.20) 0%, rgba(167, 136, 217, 0.20) 21.11%, rgba(255, 202, 205, 0.20) 42.23%, rgba(255, 255, 255, 0) 100%), #FFF;"
    >
      <div class="container-page">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <h1 class="h1 mb-7">Documentation</h1>
          <p class="p-xl mx-auto max-w-2xl">
            Everything you need to set up, customize, and get the most out of our tools.
          </p>
        </div>

        <!-- Search -->
        <div class="mx-auto mt-14 w-full max-w-[500px]" data-reveal>
          <label
            class="flex items-center gap-4 rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm transition focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/30"
          >
            <Icon name="lucide:search" class="h-6 w-6 shrink-0 text-slate-400" />
            <input
              type="text"
              placeholder="Search for topic or questions"
              class="min-w-0 flex-1 bg-transparent text-base text-slate-900 placeholder:text-slate-400 focus:outline-none"
            />
            <kbd
              class="shrink-0 font-sans text-base text-slate-400"
            >⌘K</kbd>
          </label>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="bg-white pb-24">
      <div class="container-page">
        <div
          class="mx-auto grid max-w-[1200px] grid-cols-1 gap-px overflow-hidden rounded-xl border border-slate-200 bg-slate-200 sm:grid-cols-2 lg:grid-cols-3"
        >
          {categories.map((cat) => (
            <a
              href={`/docs/${cat.slug}`}
              class="group relative flex flex-col gap-6 bg-white p-10"
            >
              <div class="flex items-start justify-between">
                <span
                  class="flex h-[72px] w-[72px] items-center justify-center rounded-full"
                  style={`background:${cat.tileBg}`}
                >
                  <Icon name={cat.icon} class={`h-7 w-7 ${cat.iconColor}`} />
                </span>
                <Icon
                  name="lucide:arrow-up-right"
                  stroke-width="1.5"
                  class="h-8 w-8 text-brand opacity-0 transition-opacity group-hover:opacity-100"
                />
              </div>

              <div class="flex flex-col gap-2">
                <h3 class="h6">{cat.name}</h3>
                <p class="p-rg text-slate-500">{cat.description}</p>
              </div>

              <span class="mt-auto text-sm font-medium text-brand underline">
                {cat.articles} Articles
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
