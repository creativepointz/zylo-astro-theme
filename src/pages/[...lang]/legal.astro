---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

const presentation = [
  {
    label: 'Owner:',
    value:
      'Zylo – 32 rue des jeuneurs 75002 Paris – SIREN Paris 394 148 167 Zylo USA & CBI Telecommunications 437 44th St SW, Grand Rapids, MI 49548',
  },
  { label: 'Publication manager:', value: 'Charles DEPLANQUE' },
  { label: 'Website creation & design:', value: 'Belal Mahmud' },
  { label: 'Web host:', value: 'OVH – 2 rue Kellermann – 59100 Roubaix' },
];

const dataManagement = [
  'In France, personal data is protected by law no. 78-87 of January 6, 1978, law no. 2004-801 of August 6, 2004, article L. 226-13 of the Criminal Code and the European Directive of October 24, 1995..',
  'When using the Zylo site, the following information may be collected: the URL of the links via which the user has accessed the site, the user’s access provider, the user’s Internet protocol (IP) address.',
  'No personal data of the site user is published without the user’s knowledge, exchanged, transferred, assigned or sold on any medium whatsoever to third parties. Only the assumption of the purchase of Zylo and its rights would allow the transmission of the said information to the eventual purchaser who would in turn be bound by the same obligation of conservation and modification of the data with respect to the user of the site.',
];

// Table of contents derived from the document's own clause headings.
const toc = [
  { id: 'website-presentation', title: '1. Website presentation' },
  { id: 'description-of-provided-services', title: '2. Description of provided services' },
  { id: 'personal-data-management', title: '3. Personal data management' },
];
---

<Layout title="Zylo legal notice" description="Legal notice for the Zylo website: website presentation, description of provided services, and personal data management.">
  <Navbar />

  <main id="main" class="bg-canvas pt-24 md:pt-[120px]">
    {/* Compact hero */}
    <section class="border-b border-hairline-soft pb-10">
      <div class="container-page">
        <Reveal class="max-w-[720px]">
          <h1 class="h1 mb-4">Zylo legal notice</h1>
          <p class="p-lt">
            You are visiting the website https://zylo.co, owned and operated by Zylo, hereinafter, the OWNER.
          </p>
        </Reveal>
      </div>
    </section>

    {/* 2-column legal document body */}
    <section class="py-12 md:py-16">
      <div class="container-page">
        <div class="flex gap-12">
          <aside class="hidden w-[240px] shrink-0 lg:block">
            <nav class="sticky top-28 flex flex-col gap-2" aria-label="On this page">
              <p class="eyebrow mb-2">On this page</p>
              {toc.map((item) => (
                <a href={`#${item.id}`} data-toc-link class="p-sm text-steel hover:text-ink">{item.title}</a>
              ))}
            </nav>
          </aside>

          <div class="w-full max-w-[720px]">
            <section id="website-presentation" class="scroll-mt-28 border-b border-hairline-soft pb-12">
              <h2 class="h3 mb-5">1. Website presentation</h2>
              <div class="space-y-4">
                {presentation.map((item) => (
                  <p class="p-rg">
                    <span class="font-medium text-ink">{item.label}</span> {item.value}
                  </p>
                ))}
              </div>
            </section>

            <section id="description-of-provided-services" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">2. Description of provided services</h2>
              <div class="space-y-4">
                <p class="p-rg">
                  The purpose of the Zylo website is to provide information concerning all of the company’s activities. Zylo to
                  provide information on the site that is as accurate as possible. However, Zylo cannot be held responsible for
                  any omissions, inaccuracies or failure to update information, whether caused by Zylo or by third-party
                  partners conferring said information.
                </p>
                <p class="p-rg">
                  All details regarding the website are provided for information purposes only, and is subject to
                  modifications. Furthermore, the website’s content is not exhaustive.
                </p>
              </div>
            </section>

            <section id="personal-data-management" class="scroll-mt-28 pt-12">
              <h2 class="h3 mb-5">3. Personal data management</h2>
              <div class="space-y-4">
                {dataManagement.map((p) => (
                  <p class="p-rg">{p}</p>
                ))}
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const setActive = (id: string) => {
      links.forEach((l) => {
        const on = l.getAttribute('href') === `#${id}`;
        l.classList.toggle('text-ink', on);
        l.classList.toggle('text-steel', !on);
      });
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        });
      },
      { rootMargin: '-120px 0px -70% 0px' }
    );
    links.forEach((l) => {
      const target = document.querySelector(l.getAttribute('href') || '');
      if (target) observer.observe(target);
    });
  }
</script>
