---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const meta = [
  'Written by: John Deep',
  'Synonyms: Expandable menu, Dropdown panels',
  'Platform: ios, Android, Web',
];

// Property rows derived from the meta strings above (label before the colon)
const metaRows = meta.map((m) => {
  const idx = m.indexOf(':');
  return { label: m.slice(0, idx + 1), value: m.slice(idx + 1).trim() };
});

const points = [
  'Users can click on the accordion headers to expand or collapse content panels, revealing more details only when they need them.',
  'Some accordions allow only one section to be open at at time, while others support multiple open sections at the same time.',
  'Accordion panels usually have animations to aid transitions so that the experience is smooth.',
];
---

<Layout title="Accordion component — Zylo Glossary" description="It can be used during the main testing phase or post launch but requires a large sample size for accurate results.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page">
      <article class="mx-auto w-full max-w-[720px]">
        {/* 1. Term header */}
        <Reveal class="mb-8">
          <a href="/glossary" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-steel transition-colors hover:text-ink">
            <Icon name="lucide:arrow-left" class="h-4 w-4" /> Back to glossary
          </a>
          <h1 class="h1 mb-4">Accordion component</h1>
          <p class="subtitle">
            It can be used during the main testing phase or post launch but requires a large sample size for accurate results.
          </p>
        </Reveal>

        {/* 2. Property-row meta */}
        <Reveal delay={80} class="mb-12 flex flex-col border-t border-hairline-soft">
          {metaRows.map((m) => (
            <div class="flex flex-wrap items-baseline gap-2 border-b border-hairline-soft py-4">
              <span class="text-sm font-medium text-ink">{m.label}</span>
              <span class="p-sm">{m.value}</span>
            </div>
          ))}
        </Reveal>

        {/* 3. Definition body */}
        <Reveal delay={120} class="flex flex-col gap-6">
          <h2 class="h2">What is and accordion component?</h2>
          <p class="p-rg">
            Accordion is a vertical stack of collapsible containers that reveal or hide sections of content.
          </p>

          <ol class="mt-2 flex flex-col gap-4">
            {points.map((p, idx) => (
              <li class="flex gap-4">
                <span class="p-rg shrink-0">{idx + 1}.</span>
                <p class="p-rg">{p}</p>
              </li>
            ))}
          </ol>

          <div class="mt-8 flex flex-col gap-6 border-t border-hairline-soft pt-8">
            <p class="p-rg text-ink">
              Accordions are commonly used in the following design patterns: FAQ, Product features or specifications, Filtering &amp; sorting.
            </p>
            <p class="p-rg text-ink">
              Fun fact: The term "accordion" in UI design is inspired by the musical instrument accordion, which expands and contracts to produce sound—just like how UI accordions expand to reveal content and collapse to hide it.
            </p>
          </div>
        </Reveal>
      </article>
    </div>
  </main>

  <Footer />
</Layout>
