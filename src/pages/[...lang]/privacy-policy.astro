---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}
---

<Layout title="Privacy policy | Zylo" description="Official Privacy Policy and Data Handling Disclosures for Zylo.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-4xl mx-auto px-4">
      <Reveal class="mb-12 text-center">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Legal &amp; Privacy
        </span>
        <h1 class="text-4xl font-bold text-slate-900 font-heading mb-4">Privacy policy | Zylo</h1>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider">Last Updated: October 9th 2025</p>
      </Reveal>

      <Reveal delay={100} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-12 shadow-sm space-y-10 text-slate-600 leading-relaxed text-base">
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">1. Who we are</h2>
          <p>
            Zylo (&quot;we&quot;, &quot;our&quot;, &quot;us&quot;) operates this website and is responsible for your personal
            data. If you have questions about this policy or your rights, contact us at
            <a href="mailto:support@zylo.co" class="font-medium text-slate-900 underline underline-offset-4">support@zylo.co</a>
          </p>
          <ul class="list-disc pl-5 space-y-2">
            <li>Zylo Limited</li>
            <li>10 Queen Street Place</li>
            <li>City of London, London EC4R 1AG</li>
            <li>United Kingdom</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">2. What information we collect</h2>
          <p>When you join our waitlist, community, or contact us, we may collect:</p>
          <ul class="list-disc pl-5 space-y-2">
            <li>Your name (if provided)</li>
            <li>Your email address</li>
            <li>Your company name (if provided)</li>
            <li>Any other information you voluntarily share</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">3. How we use your information</h2>
          <p>We process your personal data to:</p>
          <ul class="list-disc pl-5 space-y-2">
            <li>Send updates about the Zylo community and product</li>
            <li>Invite you to events, beta programs, and early access</li>
            <li>Share relevant marketing tips, resources, and offers</li>
            <li>Improve our products and services through feedback</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">4. Legal basis under GDPR</h2>
          <p>We only process your data when we have a lawful basis:</p>
          <ul class="list-disc pl-5 space-y-2">
            <li>Consent: You agreed to receive emails (via the consent box or form text)</li>
            <li>Legitimate interest: To send service-related updates about your waitlist registration</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">5. How long we keep your data</h2>
          <p>We keep your information until you unsubscribe or request deletion.</p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">6. Who we share your data with</h2>
          <p>We do not sell your personal data.</p>
          <p>We may share it with trusted third parties that help us deliver our services, including:</p>
          <ul class="list-disc pl-5 space-y-2">
            <li>Email service providers (for sending updates)</li>
            <li>Analytics tools (to understand and improve our services)</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">7. Unsubscribing</h2>
          <p>
            You can unsubscribe from our emails at any time by clicking the unsubscribe link or
            replying with &quot;unsubscribe.&quot;
          </p>
        </section>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
