---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

// Table of contents derived from the document's own clause headings.
const toc = [
  { id: 'who-we-are', title: '1. Who we are' },
  { id: 'what-information-we-collect', title: '2. What information we collect' },
  { id: 'how-we-use-your-information', title: '3. How we use your information' },
  { id: 'legal-basis-under-gdpr', title: '4. Legal basis under GDPR' },
  { id: 'how-long-we-keep-your-data', title: '5. How long we keep your data' },
  { id: 'who-we-share-your-data-with', title: '6. Who we share your data with' },
  { id: 'unsubscribing', title: '7. Unsubscribing' },
];
---

<Layout title="Privacy policy | Zylo" description="Official Privacy Policy and Data Handling Disclosures for Zylo.">
  <Navbar />

  <main id="main" class="bg-canvas pt-24 md:pt-[120px]">
    {/* Compact hero */}
    <section class="border-b border-hairline-soft pb-10">
      <div class="container-page">
        <Reveal class="max-w-[720px]">
          <p class="eyebrow mb-4">Legal &amp; Privacy</p>
          <h1 class="h1 mb-4">Privacy policy | Zylo</h1>
          <p class="p-lt">Last Updated: October 9th 2025</p>
        </Reveal>
      </div>
    </section>

    {/* 2-column legal document body */}
    <section class="py-12 md:py-16">
      <div class="container-page">
        <div class="flex gap-12">
          <aside class="hidden w-[240px] shrink-0 lg:block">
            <nav class="sticky top-28 flex flex-col gap-2" aria-label="On this page">
              <p class="eyebrow mb-2">On this page</p>
              {toc.map((item) => (
                <a href={`#${item.id}`} data-toc-link class="p-sm text-steel hover:text-ink">{item.title}</a>
              ))}
            </nav>
          </aside>

          <div class="w-full max-w-[720px]">
            <section id="who-we-are" class="scroll-mt-28 border-b border-hairline-soft pb-12">
              <h2 class="h3 mb-5">1. Who we are</h2>
              <p class="p-rg mb-4">
                Zylo (&quot;we&quot;, &quot;our&quot;, &quot;us&quot;) operates this website and is responsible for your personal
                data. If you have questions about this policy or your rights, contact us at
                <a href="mailto:support@zylo.co" class="font-medium text-ink underline underline-offset-4">support@zylo.co</a>
              </p>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Zylo Limited</li>
                <li class="p-rg">10 Queen Street Place</li>
                <li class="p-rg">City of London, London EC4R 1AG</li>
                <li class="p-rg">United Kingdom</li>
              </ul>
            </section>

            <section id="what-information-we-collect" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">2. What information we collect</h2>
              <p class="p-rg mb-4">When you join our waitlist, community, or contact us, we may collect:</p>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Your name (if provided)</li>
                <li class="p-rg">Your email address</li>
                <li class="p-rg">Your company name (if provided)</li>
                <li class="p-rg">Any other information you voluntarily share</li>
              </ul>
            </section>

            <section id="how-we-use-your-information" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">3. How we use your information</h2>
              <p class="p-rg mb-4">We process your personal data to:</p>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Send updates about the Zylo community and product</li>
                <li class="p-rg">Invite you to events, beta programs, and early access</li>
                <li class="p-rg">Share relevant marketing tips, resources, and offers</li>
                <li class="p-rg">Improve our products and services through feedback</li>
              </ul>
            </section>

            <section id="legal-basis-under-gdpr" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">4. Legal basis under GDPR</h2>
              <p class="p-rg mb-4">We only process your data when we have a lawful basis:</p>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Consent: You agreed to receive emails (via the consent box or form text)</li>
                <li class="p-rg">Legitimate interest: To send service-related updates about your waitlist registration</li>
              </ul>
            </section>

            <section id="how-long-we-keep-your-data" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">5. How long we keep your data</h2>
              <p class="p-rg">We keep your information until you unsubscribe or request deletion.</p>
            </section>

            <section id="who-we-share-your-data-with" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">6. Who we share your data with</h2>
              <p class="p-rg mb-4">We do not sell your personal data.</p>
              <p class="p-rg mb-4">We may share it with trusted third parties that help us deliver our services, including:</p>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Email service providers (for sending updates)</li>
                <li class="p-rg">Analytics tools (to understand and improve our services)</li>
              </ul>
            </section>

            <section id="unsubscribing" class="scroll-mt-28 pt-12">
              <h2 class="h3 mb-5">7. Unsubscribing</h2>
              <p class="p-rg">
                You can unsubscribe from our emails at any time by clicking the unsubscribe link or
                replying with &quot;unsubscribe.&quot;
              </p>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const setActive = (id: string) => {
      links.forEach((l) => {
        const on = l.getAttribute('href') === `#${id}`;
        l.classList.toggle('text-ink', on);
        l.classList.toggle('text-steel', !on);
      });
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        });
      },
      { rootMargin: '-120px 0px -70% 0px' }
    );
    links.forEach((l) => {
      const target = document.querySelector(l.getAttribute('href') || '');
      if (target) observer.observe(target);
    });
  }
</script>
