---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import FeatureHero from '@/components/sections/features/FeatureHero.astro';
import FeatureRow from '@/components/sections/features/FeatureRow.astro';
import FeatureBento from '@/components/sections/features/FeatureBento.astro';
import FeatureTestimonial from '@/components/sections/features/FeatureTestimonial.astro';
import UseCases from '@/components/sections/UseCases.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

const featureRows = [
  {
    eyebrow: 'Build with AI, Not From Scratch',
    heading: 'Your AI automation partner.',
    description: 'Turn a plain-language prompt into a working agent, then tune it without writing code.',
    points: [
      'Describe a task, get a working agent',
      'Multi-step reasoning and tool use',
      'Human approvals and guardrails',
      'Run on a schedule or any trigger',
      'Bring your own AI key'
    ],
    placeholderImage: '/features/Your AI writing partner..png',
    bgColor: '#EBE4FF',
    reverse: false
  },
  {
    eyebrow: 'Reliable by Default',
    heading: 'Automations you can trust.',
    description: 'Every run is logged, traceable, and easy to debug. No black boxes.',
    points: [
      'Full run logs and history',
      'Retries and error handling',
      'Live test runs before you ship',
      'Version control for every agent',
      'Alerts when something breaks'
    ],
    placeholderImage: '/features/Docs that look designed..png',
    bgColor: '#FFE4F1',
    reverse: true
  },
  {
    eyebrow: 'Built for the AI Era',
    heading: 'Any model, your choice.',
    description: 'Zylo works with GPT, Claude, and open models — swap them without rebuilding.',
    points: [
      'Use GPT, Claude, or open models',
      'Bring your own API key',
      'Route tasks to the best model',
      'No lock-in, ever'
    ],
    placeholderImage: '/features/Found by humans and AI alike..png',
    bgColor: '#FFEEE4',
    reverse: false
  },
  {
    eyebrow: 'Built for Teams',
    heading: 'Automate together, scale together.',
    description: 'Invite your team, set roles, and keep every automation in sync.',
    points: [
      'Roles and permissions',
      'Multiple workspaces',
      'Shared agent library',
      'Usage analytics'
    ],
    placeholderImage: '/features/Write together, ship together..png',
    bgColor: '#E7FCE6',
    reverse: true
  },
  {
    eyebrow: 'Connects to Your Stack',
    heading: 'Fits how you already work.',
    description: 'Zylo plugs into the tools your team already uses.',
    points: [
      'GitHub sync',
      'Slack, email, and CRM connectors',
      'Webhooks and API access',
      'Google Analytics and Tag Manager'
    ],
    placeholderImage: '/features/Fits how you already work..png',
    bgColor: '#E6F3FC',
    reverse: false
  }
];
---

<Layout
  title="Features — Zylo"
  description="Explore the visual builder, AI agents, and integrations that make Zylo the easiest way to automate real work."
>
  <Navbar />
  <main id="main">
    <!-- Hero -->
    <FeatureHero />

    <!-- What you can build -->
    <UseCases />

    <!-- Features -->
    <div class="bg-[#ffffff] pb-24">
      <div class="container-page flex flex-col gap-10">
        {featureRows.slice(0, 3).map((row) => (
          <FeatureRow {...row} />
        ))}
        
        <FeatureTestimonial />
        
        {featureRows.slice(3).map((row) => (
          <FeatureRow {...row} />
        ))}
      </div>
    </div>

    <!-- Bento -->
    <FeatureBento />
  </main>
  <Footer />
</Layout>
