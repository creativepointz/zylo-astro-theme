---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX'];

/* 5-up feature grid — icon + label + one line */
const featureGrid = [
  { icon: 'lucide:zap', title: 'Lightning Execution', desc: 'Run automated workflows and trigger webhooks instantly across your tools.' },
  { icon: 'lucide:send', title: 'Visual Builder', desc: 'Map your workflow visually with an intuitive drag-and-drop canvas.' },
  { icon: 'lucide:shield-check', title: 'Safe & Secure', desc: 'Built with enterprise-grade encryption and full audit logs for compliance.' },
  { icon: 'lucide:trending-up', title: 'Scale Automatically', desc: 'Run thousands of concurrent tasks without performance drops.' },
  { icon: 'lucide:receipt-text', title: 'Detailed Trace Logs', desc: 'Get deep execution reports and step-by-step logs to debug pipelines.' },
];

const paymentFeatures = [
  { icon: 'lucide:globe', title: 'Global App Ecosystem', desc: 'Connect Slack, Notion, Jira, GitHub, and 100+ integrations seamlessly.' },
  { icon: 'lucide:credit-card', title: 'Custom API Integrations', desc: 'Connect private systems and internal databases with custom authentication.' },
];

const howSteps = [
  { step: 'Step 01', title: 'Sign up for free.' },
  { step: 'Step 02', title: 'Connect your stack.' },
  { step: 'Step 03', title: 'Build your first workflow.' },
];

const stepDesc = 'Create an account in minutes with your work email to start building workflows.';

const browseCards = [
  'Browse 20+ workflow templates to kickstart your team automation!',
  'Connect 100+ tools with pre-built data synchronization recipes.',
  'Enable AI agents to automatically handle repetitive administrative tasks.',
];

const aboutPoints = [
  'Connect globally, collaborate seamlessly',
  'Smart automation for faster business operations',
  'Unified task monitoring and error handling',
  'Real-time operational insights and analytics',
];

const stats = [
  { value: '4.9/5', label: 'Average customer rating' },
  { value: '426', label: 'Reviews on Trustpilot' },
  { value: '20+', label: 'Templates to start from' },
];

const testimonialQuote =
  '“Our efficiency plateaued until we started using Zylo. The visual canvas helped us automate manual syncing, and our team saved over 150 hours per month. Zylo paid for itself within weeks.”';

const testimonials = ['Richard', 'Oliver', 'Amelia'];
---

<Layout title="More features — Smart automation solution for your business" description="Zylo's fully integrated platform is built to handle your automation needs seamlessly.">
  <Navbar />

  <main id="main" class="bg-canvas">

    {/* 1. Centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-4xl mx-auto">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            More features
          </span>
          <h1 class="hero-display mb-6">
            Smart automation<br class="hidden sm:inline" /> solution for your business
          </h1>
          <p class="subtitle max-w-2xl mx-auto mb-8">
            Everything you need to connect your tools, automate workflows, and coordinate tasks — in one platform.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Contact sales</a>
          </div>
        </Reveal>

        <Reveal delay={120} class="mt-12 md:mt-16">
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden max-w-5xl mx-auto">
            <img src="/placeholder.png" alt="Zylo feature dashboard" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Social proof strip */}
    <section class="border-y border-hairline py-12">
      <div class="container-page text-center">
        <Reveal>
          <p class="eyebrow mb-8">
            Rated <span class="text-ink">4.9/5</span> from over 450 reviews
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center justify-items-center">
            {brands.map((b) => (
              <span class="p-lg font-medium tracking-tight text-steel">{b}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Feature grid — 5-up */}
    <section class="section">
      <div class="container-page">
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
          {featureGrid.map((f, idx) => (
            <Reveal delay={idx * 60}>
              <div class="card h-full">
                <span class="icon-tile mb-5">
                  <Icon name={f.icon} class="w-5 h-5" />
                </span>
                <h3 class="h5 mb-2">{f.title}</h3>
                <p class="p-sm">{f.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Alternating feature rows */}
    <section class="pb-16 md:pb-24">
      <div class="container-page space-y-16 md:space-y-24">

        {/* Row 1 — text left */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal>
            <h2 class="h2 mb-5">Complete Operations Control</h2>
            <p class="p-rg">
              Zylo's fully integrated platform is built to handle your automation needs seamlessly, whether you need to connect API endpoints, sync databases, or deploy AI agents.
            </p>
          </Reveal>
          <Reveal delay={100}>
            <div class="card space-y-7 p-8">
              {paymentFeatures.map((f) => (
                <div class="flex items-start gap-4">
                  <span class="icon-tile shrink-0">
                    <Icon name={f.icon} class="w-5 h-5" />
                  </span>
                  <div>
                    <h3 class="h5 mb-1">{f.title}</h3>
                    <p class="p-sm">{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </Reveal>
        </div>

        {/* Row 2 — text right */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal class="lg:order-2">
            <h2 class="h2 mb-5">Build and monitor pipelines</h2>
            <p class="p-rg mb-8">
              The easiest way to trigger workflows, run scheduled tasks, and monitor active runs in real-time. Fully integrated with your operations stack.
            </p>
            <a href="/contact" class="btn-primary btn-md">
              Contact sales <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </Reveal>
          <Reveal delay={100} class="lg:order-1">
            <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
              <img src="/placeholder.png" alt="Zylo workflow dashboard" class="w-full rounded-md block" />
            </div>
          </Reveal>
        </div>

        {/* Row 3 — text left */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal>
            <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
              More features
            </span>
            <h2 class="h2 mb-5">
              How does<br class="hidden sm:inline" /> it even work?
            </h2>
            <p class="p-rg">
              Use Zylo for free as long as you want, or upgrade to get access to our best features for work and team projects.
            </p>
          </Reveal>
          <Reveal delay={100}>
            <div class="space-y-4">
              {howSteps.map((s) => (
                <div class="card">
                  <span class="eyebrow mb-3 inline-block rounded-full border border-hairline bg-surface px-3 py-1">{s.step}</span>
                  <h3 class="h5 mb-2">{s.title}</h3>
                  <p class="p-sm">{stepDesc}</p>
                </div>
              ))}
            </div>
          </Reveal>
        </div>

        {/* Browse cards */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {browseCards.map((text, idx) => (
            <Reveal delay={idx * 70}>
              <div class="card h-full flex flex-col justify-between gap-6">
                <p class="h5 leading-snug">{text}</p>
                <a href="/pricing" class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:underline">
                  Browse <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
                </a>
              </div>
            </Reveal>
          ))}
        </div>

        {/* Row 4 — text right */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal class="lg:order-2">
            <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
              Built smarter transactions
            </span>
            <h2 class="h2 mb-5">Grow your transaction from another level</h2>
            <p class="p-rg">
              Fintech harnesses advanced technology to transform and optimize financial processes, delivering innovative, secure, and intelligent banking solutions that enhance efficiency.
            </p>
          </Reveal>
          <Reveal delay={100} class="lg:order-1">
            <div class="card-feature">
              <ul class="space-y-5">
                {aboutPoints.map((p) => (
                  <li class="flex items-start gap-3">
                    <Icon name="lucide:check" class="w-5 h-5 mt-0.5 shrink-0 text-brand" />
                    <span class="h6 leading-snug">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Reveal>
        </div>

      </div>
    </section>

    {/* 5. Stat row */}
    <section class="border-y border-hairline py-16">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          {stats.map((s, idx) => (
            <Reveal delay={idx * 80}>
              <div class="display-lg mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 6. Testimonials */}
    <section class="section">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto mb-12">
          <span class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.5px] text-steel mb-6">
            <Icon name="lucide:star" class="w-3.5 h-3.5 text-brand" />
            See our 426 reviews on Trustpilot
          </span>
          <h2 class="h2 mb-5">
            Trusted by Crypto<br class="hidden sm:inline" /> Natives Worldwide
          </h2>
          <p class="p-rg mb-6">What's your work finance</p>
          <a href="/pricing" class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:underline">
            See how default works <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((name, idx) => (
            <Reveal delay={idx * 70}>
              {idx === 1 ? (
                <div class="rounded-lg bg-testimonial-orange text-on-dark p-8 h-full flex flex-col justify-between">
                  <p class="text-base leading-[1.5] text-on-dark mb-6">{testimonialQuote}</p>
                  <div class="flex items-center justify-between border-t border-white/25 pt-5">
                    <div>
                      <div class="text-sm font-semibold text-on-dark">{name}</div>
                      <div class="text-[13px] text-on-dark-muted">CEO SPX</div>
                    </div>
                    <span class="inline-flex items-center gap-1 text-sm font-semibold text-on-dark">
                      <Icon name="lucide:star" class="w-4 h-4" /> 4.9
                    </span>
                  </div>
                </div>
              ) : (
                <div class="card h-full flex flex-col justify-between p-8">
                  <p class="p-sm mb-6">{testimonialQuote}</p>
                  <div class="flex items-center justify-between border-t border-hairline pt-5">
                    <div>
                      <div class="h6">{name}</div>
                      <div class="p-lt">CEO SPX</div>
                    </div>
                    <span class="inline-flex items-center gap-1 h6">
                      <Icon name="lucide:star" class="w-4 h-4 text-brand" /> 4.9
                    </span>
                  </div>
                </div>
              )}
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7. Closing CTA band */}
    <section class="section bg-surface-soft border-t border-hairline">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <h2 class="h2 mb-5">
            Start planning smarter and more<br class="hidden sm:inline" /> meaningful user experiences
          </h2>
          <p class="p-rg mb-8">
            Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Subscribe now <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Contact sales</a>
          </div>
        </Reveal>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
