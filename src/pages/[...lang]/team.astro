---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const team = [
  { name: 'Matteo Rassi', role: 'CEO SPX' },
  { name: 'Michael Johnson', role: 'CEO SPX' },
  { name: 'Robert Fox', role: 'CEO SPX' },
  { name: 'Alexa Montes', role: 'CEO SPX' },
  { name: 'Ravi Ganatra', role: 'CEO SPX' },
  { name: 'Imdat Cimsit', role: 'CEO SPX' },
];

const stats = [
  { label: 'Satisfied clients', value: '600+' },
  { label: 'Saved for clients annually', value: '$5bn' },
  { label: 'We worked of the Global 500', value: '80%' },
];
---

<Layout title="Meet Our Team — Zylo" description="Meet the team building the future of AI automation at Zylo.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow mb-4 block">Innovation meets intent</span>
        <h1 class="h1 mb-5">
          Meet our team
        </h1>
        <p class="subtitle">
          The people building Zylo&rsquo;s workflow automation platform — and the support behind every deployment.
        </p>
      </Reveal>

      {/* 2. Team card grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
        {team.map((m, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-lg border border-hairline bg-canvas p-6 h-full flex flex-col justify-between">
              <div>
                <img
                  src="/placeholder.png"
                  alt={m.name}
                  loading="lazy"
                  class="w-14 h-14 rounded-full border border-hairline bg-surface object-cover mb-5"
                />
                <h2 class="h4 mb-1">{m.name}</h2>
                <p class="p-lt">{m.role}</p>
              </div>
              <div class="pt-5 mt-5 border-t border-hairline-soft flex items-center gap-3 text-stone">
                <a href="#" aria-label="LinkedIn" class="hover:text-ink transition-colors"><Icon name="lucide:linkedin" class="w-4 h-4" /></a>
                <a href="#" aria-label="Twitter" class="hover:text-ink transition-colors"><Icon name="lucide:twitter" class="w-4 h-4" /></a>
                <a href="#" aria-label="GitHub" class="hover:text-ink transition-colors"><Icon name="lucide:github" class="w-4 h-4" /></a>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Stat row */}
      <Reveal class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="h2 mb-4">
          Gain 2,000+ hours per month
        </h2>
        <p class="p-rg">
          Give your team time back to focus on what matters most — your customers.
        </p>
      </Reveal>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-4">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80} class="text-center">
            <div class="display-lg mb-2">{s.value}</div>
            <p class="p-sm">{s.label}</p>
          </Reveal>
        ))}
      </div>
    </section>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline mt-20">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">
            Start planning smarter and more meaningful user experiences
          </h2>
          <p class="p-rg mb-8">
            Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">Subscribe now</a>
            <a href="/career" class="btn-secondary btn-lg">See open roles</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
