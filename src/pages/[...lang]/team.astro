---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const team = [
  { name: 'Matteo Rassi', role: 'CEO SPX' },
  { name: 'Michael Johnson', role: 'CEO SPX' },
  { name: 'Robert Fox', role: 'CEO SPX' },
  { name: 'Alexa Montes', role: 'CEO SPX' },
  { name: 'Ravi Ganatra', role: 'CEO SPX' },
  { name: 'Imdat Cimsit', role: 'CEO SPX' },
];

const stats = [
  { label: 'Satisfied clients', value: '600+' },
  { label: 'Saved for clients annually', value: '$5bn' },
  { label: 'We worked of the Global 500', value: '80%' },
  { label: 'Satisfied clients', value: '>90' },
];
---

<Layout title="Meet Our Team — Zylo" description="Meet the team building the future of AI automation at Zylo.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="inline-block border border-hairline bg-canvas px-4 py-1.5 rounded-full text-xs font-semibold text-ink uppercase tracking-wider mb-6 shadow-[var(--shadow-subtle)]">
          Innovation meets intent
        </span>
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-semibold text-ink font-heading tracking-tight leading-[1.05]">
          Meet our team
        </h1>
      </Reveal>

      {/* 2. Team Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
        {team.map((m, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] hover:shadow-[var(--shadow-subtle)] transition-all h-full flex flex-col justify-between">
              <div>
                <div class="w-16 h-16 rounded-full bg-canvas-dark text-on-dark font-semibold text-xl flex items-center justify-center font-heading mb-6 shadow-[var(--shadow-subtle)]">
                  {m.name[0]}
                </div>
                <h3 class="text-2xl font-semibold text-ink font-heading mb-1">{m.name}</h3>
                <span class="inline-block text-xs font-semibold text-brand">{m.role}</span>
              </div>
              <div class="pt-6 mt-6 border-t border-hairline-soft flex items-center gap-3 text-stone">
                <a href="#" aria-label="LinkedIn" class="hover:text-brand transition-colors"><Icon name="lucide:linkedin" class="w-4 h-4" /></a>
                <a href="#" aria-label="Twitter" class="hover:text-brand transition-colors"><Icon name="lucide:twitter" class="w-4 h-4" /></a>
                <a href="#" aria-label="GitHub" class="hover:text-brand transition-colors"><Icon name="lucide:github" class="w-4 h-4" /></a>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Gain 2,000+ Hours Banner */}
      <Reveal class="rounded-lg bg-canvas-dark text-on-dark p-10 md:p-16 text-center shadow-[var(--shadow-card)] mb-10 max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-semibold font-heading mb-4 tracking-tight leading-tight">
          Gain 2,000+ <br class="hidden sm:inline" /> hours per month
        </h2>
        <p class="text-on-dark-muted text-base max-w-xl mx-auto">
          Give your team time back to focus on what matters most — your customers.
        </p>
      </Reveal>

      {/* 4. Funfact Stats */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
        {stats.map((s, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] hover:shadow-[var(--shadow-subtle)] transition-all h-full">
              <p class="text-xs text-steel leading-relaxed font-medium mb-4">{s.label}</p>
              <div class="text-5xl font-semibold text-ink font-heading tracking-tight">{s.value}</div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 5. Final CTA */}
      <Reveal class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl sm:text-5xl font-semibold text-ink font-heading tracking-tight mb-6 leading-tight">
          Start planning smarter and more <br class="hidden sm:inline" /> meaningful user experiences
        </h2>
        <p class="text-steel text-base mb-8 leading-relaxed">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <a href="/pricing" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-semibold text-on-primary hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]">
          Subscribe now <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
