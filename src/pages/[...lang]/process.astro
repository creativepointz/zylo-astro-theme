---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX'];

const steps = [
  { num: '1', title: 'Create your Free Account in Seconds', image: '/features/Custom Domain.png' },
  { num: '2', title: 'Import Contacts, Leads, and deals Easily.', image: '/features/Roles and Permissions.png' },
  { num: '3', title: 'Customize your sales pipeline and task flows.', image: '/features/Page Analytics.png' },
];

const stepDesc = 'Minimal, organized structure to help you manage, sort, & access every task.';

/* 5-up grid — what you get on every plan */
const highlights = [
  { icon: 'lucide:user-plus', title: 'Free account', desc: 'Start in seconds, no card needed.' },
  { icon: 'lucide:upload', title: 'Easy import', desc: 'Bring contacts, leads, and deals with you.' },
  { icon: 'lucide:sliders-horizontal', title: 'Custom pipeline', desc: 'Shape stages and task flows around your team.' },
  { icon: 'lucide:bot', title: 'AI assistance', desc: 'Let Zylo handle the repeat work in each stage.' },
  { icon: 'lucide:life-buoy', title: 'Human handover', desc: 'Hand a conversation to an agent whenever needed.' },
];

const stats = [
  { value: '3 steps', label: 'From sign-up to first workflow' },
  { value: 'Free', label: 'For as long as you want' },
  { value: '24/7', label: 'Support when you need a person' },
];

const faqAnswer =
  'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.';

const faqs = [
  'Can I test ChatBot for free?',
  'What is a generative AI chatbot?',
  'How does a generative AI chatbot work?',
  'How do AI chatbots benefit customer support?',
  'Can ChatBot be integrated with LiveChat?',
  'Can I test ChatBot for free?',
];
---

<Layout title="Learn how it works — Zylo Process" description="Use Zylo for free as long as you want, or upgrade to get access to our best features for work and team projects.">
  <Navbar />

  <main id="main" class="bg-canvas">

    {/* 1. Centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Process
          </span>
          <h1 class="hero-display mb-6">Learn how it works</h1>
          <p class="subtitle max-w-2xl mx-auto mb-8">
            Use Zylo for free as long as you want, or upgrade to get access to our best features for work and team projects.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get Started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to sales</a>
          </div>
        </Reveal>

        <Reveal delay={120} class="mt-12 md:mt-16">
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden max-w-5xl mx-auto">
            <img src="/placeholder.png" alt="Zylo workspace" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Social proof strip */}
    <section class="border-y border-hairline py-12">
      <div class="container-page text-center">
        <Reveal>
          <p class="eyebrow mb-8">
            Teams set up their first workflow in under <span class="text-ink">10 minutes</span>
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center justify-items-center">
            {brands.map((b) => (
              <span class="p-lg font-medium tracking-tight text-steel">{b}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Feature grid — 5-up */}
    <section class="section">
      <div class="container-page">
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
          {highlights.map((h, idx) => (
            <Reveal delay={idx * 60}>
              <div class="card h-full">
                <span class="icon-tile mb-5">
                  <Icon name={h.icon} class="w-5 h-5" />
                </span>
                <h3 class="h5 mb-2">{h.title}</h3>
                <p class="p-sm">{h.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Alternating step rows */}
    <section class="pb-16 md:pb-24">
      <div class="container-page space-y-16 md:space-y-24">
        {steps.map((s, idx) => (
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <Reveal class={idx % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-md bg-primary font-heading text-base font-semibold text-on-primary">
                {s.num}
              </div>
              <h2 class="h2 mb-5">{s.title}</h2>
              <p class="p-rg mb-8">{stepDesc}</p>
              <a href="/pricing" class="btn-secondary btn-md">
                Get Started <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            </Reveal>
            <Reveal delay={100} class={idx % 2 === 1 ? 'lg:order-1' : ''}>
              <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
                <img src={s.image} alt={s.title} class="w-full rounded-md block" />
              </div>
            </Reveal>
          </div>
        ))}
      </div>
    </section>

    {/* 5. Stat row */}
    <section class="border-y border-hairline py-16">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          {stats.map((s, idx) => (
            <Reveal delay={idx * 80}>
              <div class="display-lg mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="section">
      <div class="container-page">
        <Reveal class="text-center max-w-2xl mx-auto mb-12">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            FAQ
          </span>
          <h2 class="h2 mb-4">Commonly asked questions</h2>
          <p class="p-rg">
            Offer live chat support to your customers. Our chatbot seamlessly transitions to human agents when needed.
          </p>
        </Reveal>

        <div class="max-w-3xl mx-auto space-y-4">
          {faqs.map((q, idx) => (
            <Reveal delay={idx * 50}>
              <details class="group rounded-md border border-hairline-soft bg-canvas p-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 h5">
                  {q}
                  <Icon name="lucide:plus" class="w-5 h-5 shrink-0 text-steel transition-transform group-open:rotate-45" />
                </summary>
                <p class="p-rg mt-4">{faqAnswer}</p>
              </details>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7. Closing CTA band */}
    <section class="section bg-surface-soft">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <h2 class="h2 mb-5">Three steps to your first automated workflow</h2>
          <p class="p-rg mb-8">
            Create an account, bring your data across, and let Zylo run the routine work from there.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get Started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to sales</a>
          </div>
        </Reveal>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
