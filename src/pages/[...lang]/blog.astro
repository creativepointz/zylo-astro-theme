---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const posts = [
  { title: 'Embrace the Power of SaaS for Banking Evolution' },
  { title: 'Accelerate Digital Transformation in Modern Banking' },
  { title: 'Unlock Scalable Growth with Smart Banking Solutions' },
  { title: 'Empower Financial Innovation Through SaaS Technology' },
  { title: 'Revolutionize Customer Experience in the Banking Sector' },
  { title: 'Drive Secure and Agile Banking Operations with SaaS' },
];
---

<Layout title="Blog — Never miss an update from Zylo" description="Press, product news, and updates from Zylo.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block border border-hairline bg-canvas px-4 py-1.5 rounded-full text-xs font-semibold text-ink uppercase tracking-wider mb-6 shadow-[var(--shadow-subtle)]">
          Press
        </span>
        <h1 class="text-4xl sm:text-6xl font-semibold text-ink font-heading tracking-tight mb-6">
          Never miss an update from Zylo
        </h1>
        <p class="text-base text-steel leading-relaxed">
          Zylo is trusted by creator-educators around the world to grow their impact and income. From online
          courses and communities to memberships and downloads, Zylo&rsquo;s digital learning products help
          creator-educators drive meaningful connection and sustainable revenue.
        </p>
      </Reveal>

      {/* 2. Blog Posts Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {posts.map((p, idx) => (
          <Reveal delay={idx * 80}>
            <div class="group rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] hover:border-brand/40 hover:shadow-[var(--shadow-subtle)] transition-all flex flex-col justify-between h-full">
              <h3 class="text-xl font-semibold text-ink font-heading mb-8 leading-snug">
                <a href="/article" class="group-hover:text-brand transition-colors">{p.title}</a>
              </h3>
              <a
                href="/article"
                class="inline-flex h-10 w-fit items-center justify-center gap-2 rounded-full bg-canvas-dark px-5 text-xs font-semibold text-on-dark hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]"
              >
                <span>Read more</span>
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
