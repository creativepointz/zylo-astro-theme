---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const posts = [
  { title: 'Embrace the Power of SaaS for Banking Evolution', tag: 'Product' },
  { title: 'Accelerate Digital Transformation in Modern Banking', tag: 'Product' },
  { title: 'Unlock Scalable Growth with Smart Banking Solutions', tag: 'Guides' },
  { title: 'Empower Financial Innovation Through SaaS Technology', tag: 'Guides' },
  { title: 'Revolutionize Customer Experience in the Banking Sector', tag: 'Company' },
  { title: 'Drive Secure and Agile Banking Operations with SaaS', tag: 'Company' },
];

const topics = ['All', 'Product', 'Guides', 'Company'];
---

<Layout title="Blog — Never miss an update from Zylo" description="Press, product news, and updates from Zylo.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="container-page max-w-6xl">
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow mb-4 block">Press</span>
        <h1 class="h1 mb-5">
          Never miss an update from Zylo
        </h1>
        <p class="subtitle">
          Zylo is trusted by creator-educators around the world to grow their impact and income. From online
          courses and communities to memberships and downloads, Zylo&rsquo;s digital learning products help
          creator-educators drive meaningful connection and sustainable revenue.
        </p>
      </Reveal>

      <Reveal delay={60}>
        <img
          src="/placeholder.png"
          alt="Latest from Zylo"
          loading="lazy"
          class="mb-12 aspect-[21/9] w-full rounded-lg border border-hairline-soft bg-surface object-contain p-4"
        />
      </Reveal>

      {/* 2. Topic filter row */}
      <Reveal delay={60} class="mb-12">
        <div id="blog-tabs" class="flex flex-wrap justify-center gap-2">
          {topics.map((t, idx) => (
            <button
              type="button"
              data-topic={t}
              class:list={[
                'blog-tab rounded-full px-4 py-2 text-sm font-medium transition-colors',
                idx === 0
                  ? 'bg-primary text-on-primary border border-primary'
                  : 'bg-canvas text-steel border border-hairline',
              ]}
            >
              {t}
            </button>
          ))}
        </div>
      </Reveal>

      {/* 3. Post card grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
        {posts.map((p, idx) => (
          <Reveal delay={idx * 60}>
            <article
              class="blog-card group rounded-lg border border-hairline bg-canvas overflow-hidden flex flex-col justify-between h-full"
              data-topic={p.tag}
            >
              <div class="p-6">
                <img
                  src="/placeholder.png"
                  alt={p.title}
                  loading="lazy"
                  class="mb-5 -mt-6 -mx-6 aspect-[16/9] w-[calc(100%+3rem)] max-w-none border-b border-hairline-soft bg-surface object-contain p-4"
                />
                <p class="p-lt mb-3">{p.tag}</p>
                <h3 class="h5 mb-6">
                  <a href="/article">{p.title}</a>
                </h3>
              </div>
              <a href="/article" class="btn-secondary btn-md w-fit gap-2 mx-6 mb-6">
                <span>Read more</span>
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            </article>
          </Reveal>
        ))}
      </div>
    </section>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page max-w-3xl py-16 md:py-24 text-center">
        <Reveal>
          <h2 class="h2 mb-4">Get the next update first</h2>
          <p class="p-rg mb-8">
            New posts on workflow automation, AI agents, and the teams shipping with Zylo — sent as they publish.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/contact" class="btn-primary btn-lg">Subscribe now</a>
            <a href="/features" class="btn-secondary btn-lg">Explore Zylo</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.blog-tab');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const topic = tab.dataset.topic;

      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('bg-primary', active);
        t.classList.toggle('text-on-primary', active);
        t.classList.toggle('border-primary', active);
        t.classList.toggle('bg-canvas', !active);
        t.classList.toggle('text-steel', !active);
        t.classList.toggle('border-hairline', !active);
      });

      cards.forEach((card) => {
        const wrapper = (card.parentElement as HTMLElement) ?? card;
        wrapper.hidden = topic !== 'All' && card.dataset.topic !== topic;
      });
    });
  });
</script>
