---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'HyperLogistics'];

const integrations = [
  { name: 'LiveChat', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:message-square' },
  { name: 'Chat Widget', desc: 'Add a beautiful, customizable chat widget to your website.', icon: 'lucide:bot' },
  { name: 'HelpDesk', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:headphones' },
  { name: 'Shopify', desc: 'Offer 24/7 personalized customer service and drive sales performance.', icon: 'lucide:shopping-cart' },
  { name: 'Zapier', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:zap' },
  { name: 'Notion', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:file-text' },
  { name: 'Slack', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:slack' },
  { name: 'Zendesk', desc: 'Add a beautiful, customizable chat widget to your website.', icon: 'lucide:life-buoy' },
];

const setupPoints = [
  'Connect an app in a few clicks — no engineering ticket',
  'Keep records in sync both ways, automatically',
  'Swap or pause a connection without breaking a workflow',
];

const stats = [
  { value: '80+', label: 'Apps ready to connect' },
  { value: 'Minutes', label: 'Typical time to first sync' },
  { value: 'Two-way', label: 'Data stays current in both tools' },
];
---

<Layout title="Chatbot Integrations — Connect ChatBot with your favorite tools and apps" description="Connect ChatBot with your favorite tools and apps.">
  <Navbar />

  <main id="main" class="bg-canvas">

    {/* 1. Centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-4xl mx-auto">
          <span class="eyebrow mb-6 inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-3 py-1">
            <Icon name="lucide:sparkles" class="w-3.5 h-3.5 text-brand" />
            Chatbot Integrations
          </span>
          <h1 class="hero-display mb-6">
            Connect ChatBot with your<br class="hidden sm:inline" /> favorite tools and apps
          </h1>
          <p class="subtitle max-w-2xl mx-auto mb-8">
            Plug Zylo into the tools your team already runs on and let work move between them on its own.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Start your free trial <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="#all-integrations" class="btn-secondary btn-lg">Browse all integrations</a>
          </div>
        </Reveal>

        <Reveal delay={120} class="mt-12 md:mt-16">
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden max-w-5xl mx-auto">
            <img src="/placeholder.png" alt="Zylo integrations" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Social proof strip */}
    <section class="border-y border-hairline py-12">
      <div class="container-page text-center">
        <Reveal>
          <p class="eyebrow mb-8">
            <span class="text-ink">80+</span> apps connected across every plan
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center justify-items-center">
            {brands.map((b) => (
              <span class="p-lg font-medium tracking-tight text-steel">{b}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Integration grid */}
    <section id="all-integrations" class="section">
      <div class="container-page">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {integrations.map((i, idx) => (
            <Reveal delay={idx * 50}>
              <div class="card h-full flex flex-col justify-between gap-6">
                <div>
                  <span class="icon-tile mb-5">
                    <Icon name={i.icon} class="w-5 h-5" />
                  </span>
                  <h2 class="h5 mb-2">{i.name}</h2>
                  <p class="p-sm">{i.desc}</p>
                </div>
                <a href="/integrations" class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:underline">
                  Check out <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
                </a>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Alternating feature rows */}
    <section class="pb-16 md:pb-24">
      <div class="container-page space-y-16 md:space-y-24">

        {/* Row 1 — text left */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal>
            <h2 class="h2 mb-5">Set up a connection in a few clicks</h2>
            <p class="p-rg mb-8">
              Pick an app, sign in once, and choose what should sync. Zylo keeps the connection running and tells you when something needs a look.
            </p>
            <ul class="space-y-4">
              {setupPoints.map((p) => (
                <li class="flex items-start gap-3">
                  <Icon name="lucide:check" class="w-5 h-5 mt-0.5 shrink-0 text-brand" />
                  <span class="p-rg">{p}</span>
                </li>
              ))}
            </ul>
          </Reveal>
          <Reveal delay={100}>
            <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
              <img src="/placeholder.png" alt="Connecting an app in Zylo" class="w-full rounded-md block" />
            </div>
          </Reveal>
        </div>

        {/* Row 2 — text right */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <Reveal class="lg:order-2">
            <h2 class="h2 mb-5">Hand off to a person when it matters</h2>
            <p class="p-rg mb-8">
              Chat, helpdesk, and commerce tools share the same thread, so a bot can answer the routine questions and pass the rest to an agent with full context.
            </p>
            <a href="/contact" class="btn-secondary btn-md">
              Talk to sales <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </Reveal>
          <Reveal delay={100} class="lg:order-1">
            <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
              <img src="/placeholder.png" alt="Handover to a support agent" class="w-full rounded-md block" />
            </div>
          </Reveal>
        </div>

      </div>
    </section>

    {/* 5. Stat row */}
    <section class="border-y border-hairline py-16">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          {stats.map((s, idx) => (
            <Reveal delay={idx * 80}>
              <div class="display-lg mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7. Closing CTA band */}
    <section class="section bg-surface-soft">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <h2 class="h2 mb-5">Connect your stack and let it run</h2>
          <p class="p-rg mb-8">
            Start with one app today and add the rest whenever you are ready.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Start your free trial <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Talk to sales</a>
          </div>
        </Reveal>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
