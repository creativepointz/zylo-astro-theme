---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const integrations = [
  { name: 'LiveChat', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:message-square' },
  { name: 'Chat Widget', desc: 'Add a beautiful, customizable chat widget to your website.', icon: 'lucide:bot' },
  { name: 'HelpDesk', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:headphones' },
  { name: 'Shopify', desc: 'Offer 24/7 personalized customer service and drive sales performance.', icon: 'lucide:shopping-cart' },
  { name: 'Zapier', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:zap' },
  { name: 'Notion', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:file-text' },
  { name: 'Slack', desc: 'Improve your customer services working side by side with a bot.', icon: 'lucide:slack' },
  { name: 'Zendesk', desc: 'Add a beautiful, customizable chat widget to your website.', icon: 'lucide:life-buoy' },
];
---

<Layout title="Chatbot Integrations — Connect ChatBot with your favorite tools and apps" description="Connect ChatBot with your favorite tools and apps.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 border border-hairline bg-canvas px-4 py-1.5 rounded-full text-xs font-semibold text-ink uppercase tracking-wider mb-6 shadow-[var(--shadow-subtle)]">
          <Icon name="lucide:sparkles" class="w-3.5 h-3.5 text-brand" />
          Chatbot Integrations
        </span>
        <h1 class="text-4xl sm:text-6xl font-semibold text-ink font-heading tracking-tight leading-[1.08] mb-8">
          Connect ChatBot with your<br class="hidden sm:block" /> favorite tools and apps
        </h1>
        <a href="/pricing" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-primary px-8 text-sm font-semibold text-on-primary hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]">
          Start your free trial <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </Reveal>

      {/* 2. Grid of Integrations */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {integrations.map((i, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-subtle)] hover:border-brand/40 hover:shadow-[var(--shadow-subtle)] transition-all h-full flex flex-col justify-between">
              <div>
                <div class="w-11 h-11 rounded-md bg-brand/10 text-brand flex items-center justify-center mb-6">
                  <Icon name={i.icon} class="w-5 h-5" />
                </div>
                <h2 class="text-xl font-semibold text-ink font-heading mb-1">{i.name}</h2>
                <p class="text-steel text-sm leading-relaxed mb-7">{i.desc}</p>
              </div>
              <a href="/integrations" class="inline-flex h-10 items-center justify-center gap-2 rounded-full bg-canvas-dark px-5 text-xs font-semibold text-on-dark hover:bg-charcoal transition-colors self-start">
                Check out <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
              </a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
