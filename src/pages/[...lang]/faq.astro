---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const faqData = [
  {
    category: 'General',
    questions: [
      { q: 'How does Zylo automate our daily tasks?', a: 'Zylo uses intelligent triggers and data connectors to map and execute workflows. You can visually configure steps, map fields between tools, and let our agents handle repetitive tasks autonomously.' },
      { q: 'Is there a free trial available?', a: 'Yes! We offer a 14-day free trial on our Starter and Growth plans, with no credit card required to sign up.' },
      { q: 'What is the limit on active workflows?', a: 'Starter plans support up to 20 active workflows, Growth plans up to 100, and Enterprise plans offer unlimited workflows.' }
    ]
  },
  {
    category: 'Alerts',
    questions: [
      { q: 'Can I set up real-time error notifications?', a: 'Yes. Zylo can send immediate alerts via Slack, email, or custom webhooks when a critical step in your workflow fails.' },
      { q: 'How do I customize alert conditions?', a: 'You can configure conditional filters on any workflow step to trigger alerts only for specific error codes or high-priority accounts.' }
    ]
  },
  {
    category: 'Reports',
    questions: [
      { q: 'What analytics are included in my dashboard?', a: 'You can track task execution counts, success rates, average runs per hour, and total cost/time savings metrics.' },
      { q: 'Can I export operational reports?', a: 'Yes, reports can be downloaded in PDF and CSV formats, or synced directly to Google Sheets or Notion databases.' }
    ]
  },
  {
    category: 'Exports',
    questions: [
      { q: 'What file formats are supported for exports?', a: 'Zylo supports exporting task logs and data in JSON, CSV, PDF, and Markdown format.' },
      { q: 'Can I schedule automated weekly exports?', a: 'Absolutely. You can set a cron-like trigger to run background exports of your logs and metrics weekly.' }
    ]
  },
  {
    category: 'API',
    questions: [
      { q: 'Do you offer a public API?', a: 'Yes, Zylo provides a fully documented REST API to trigger workflows, fetch execution logs, and manage connectors programmatically.' },
      { q: 'Can I connect custom endpoints?', a: 'Yes, our Custom HTTP block allows you to make authenticated GET/POST requests to any secure internal or external API endpoint.' }
    ]
  },
  {
    category: 'Media monitoring',
    questions: [
      { q: 'How does media monitoring work?', a: 'Zylo can scan social media feeds, RSS feeds, or news APIs for specific keywords and feed that data directly into your workflows.' },
      { q: 'Can I analyze sentiment automatically?', a: 'Yes, you can plug in our AI Sentiment Analysis block to score text data before routing it to your team channels.' }
    ]
  }
];

const tabs = faqData.map(f => f.category);

const helpCards = [
  {
    icon: 'lucide:book-open',
    title: 'Documentation',
    desc: 'Setup guides, workflow recipes and reference for every Zylo automation.',
    label: 'Read the docs',
    href: '/support',
  },
  {
    icon: 'lucide:headphones',
    title: 'Contact support',
    desc: 'Reach the support team for account, billing and workflow questions.',
    label: 'Get in touch',
    href: '/contact',
  },
  {
    icon: 'lucide:blocks',
    title: 'Integrations',
    desc: 'See which tools connect to Zylo and how the data moves between them.',
    label: 'Browse integrations',
    href: '/integrations',
  },
  {
    icon: 'lucide:briefcase',
    title: 'Talk to sales',
    desc: 'Plan a rollout across teams and review pricing for your workspace.',
    label: 'Book a call',
    href: '/contact',
  },
];
---

<Layout title="Customer questions, answered — Zylo FAQ" description="This section provides clear, helpful answers so users can resolve issues quickly without contacting support saving valuable time.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] bg-canvas">
    {/* 1. Compact centered hero */}
    <div class="container-page pb-12 md:pb-16">
      <Reveal class="text-center max-w-3xl mx-auto">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Our faq’s
        </span>
        <h1 class="h1 mb-6">Customer questions, answered</h1>
        <p class="subtitle">
          This section provides clear, helpful answers so users can resolve issues quickly without contacting support
          saving valuable time.
        </p>
      </Reveal>
    </div>

    {/* 2. Category pill tabs */}
    <div class="container-page pb-10">
      <Reveal delay={80} class="flex flex-wrap justify-center gap-2">
        {tabs.map((t, idx) => (
          <button
            type="button"
            data-faq-tab={String(idx)}
            class:list={[
              'faq-tab rounded-full border px-4 py-2 text-sm font-medium transition-colors',
              idx === 0
                ? 'border-primary bg-primary text-on-primary'
                : 'border-hairline bg-canvas text-steel',
            ]}
          >
            {t}
          </button>
        ))}
      </Reveal>
    </div>

    {/* 3. Accordion list */}
    <div class="container-page pb-16 md:pb-24">
      <div class="max-w-3xl mx-auto">
        {faqData.map((group, tabIdx) => (
          <div data-faq-panel={String(tabIdx)} class="space-y-3" style={tabIdx === 0 ? '' : 'display:none'}>
            {group.questions.map((item, idx) => (
              <Reveal delay={idx * 50}>
                <details class="group rounded-md border border-hairline-soft bg-canvas p-6 [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex cursor-pointer items-center justify-between gap-4">
                    <span class="h5">{item.q}</span>
                    <Icon
                      name="lucide:chevron-down"
                      class="w-4 h-4 shrink-0 text-steel transition-transform group-open:rotate-180"
                    />
                  </summary>
                  <p class="p-rg mt-4 text-stone">{item.a}</p>
                </details>
              </Reveal>
            ))}
          </div>
        ))}
      </div>
    </div>

    {/* 4. Need help? card row */}
    <div class="container-page pb-16 md:pb-24">
      <Reveal class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="h2 mb-4">Need help?</h2>
        <p class="subtitle">Get quick answers and friendly assistance anytime you need.</p>
      </Reveal>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {helpCards.map((c, idx) => (
          <Reveal delay={idx * 60}>
            <div class="h-full rounded-lg border border-hairline bg-canvas p-6 flex flex-col">
              <span class="icon-tile mb-5">
                <Icon name={c.icon} class="w-5 h-5" />
              </span>
              <h3 class="h5 mb-2">{c.title}</h3>
              <p class="p-sm mb-6">{c.desc}</p>
              <a href={c.href} class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-ink">
                {c.label}
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 5. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page section">
        <Reveal class="text-center max-w-2xl mx-auto">
          <h2 class="h2 mb-4">Still have a question?</h2>
          <p class="p-rg mb-8">
            Tell us what you are trying to automate and the team will point you to the right workflow.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/contact" class="btn-primary btn-lg">
              Contact us <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/support" class="btn-secondary btn-lg">Visit support</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const tabButtons = document.querySelectorAll<HTMLElement>('[data-faq-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-faq-panel]');
  const activeClasses = ['border-primary', 'bg-primary', 'text-on-primary'];
  const idleClasses = ['border-hairline', 'bg-canvas', 'text-steel'];

  tabButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.faqTab;
      tabButtons.forEach((b) => {
        const isActive = b.dataset.faqTab === target;
        activeClasses.forEach((c) => b.classList.toggle(c, isActive));
        idleClasses.forEach((c) => b.classList.toggle(c, !isActive));
      });
      panels.forEach((p) => {
        p.style.display = p.dataset.faqPanel === target ? '' : 'none';
      });
    });
  });
</script>
