---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const tabs = ['General', 'Alerts', 'Reports', 'Exports', 'API', 'Media monitoring'];

const questions = [
  'How does an AI resume builder work?',
  'Can the AI customize resumes for different jobs?',
  'Does it improve my chances of getting hired?',
  'Does it have templates for different industries?',
  'What file formats can I download (PDF, TXT, DOCX)?',
  'What file formats can I download (PDF, TXT, DOCX)?',
];

const answer =
  'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.';
---

<Layout title="Customer questions, answered — Zylo FAQ" description="This section provides clear, helpful answers so users can resolve issues quickly without contacting support saving valuable time.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-4xl mx-auto px-4">
      {/* 1. FAQ header */}
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-block border border-hairline bg-canvas px-4 py-1.5 rounded-full text-xs font-semibold text-ink uppercase tracking-wider mb-6 shadow-[var(--shadow-subtle)]">
          Our faq’s
        </span>
        <h1 class="text-4xl sm:text-6xl font-semibold text-ink font-heading tracking-tight mb-6">
          Customer questions, answered
        </h1>
        <p class="text-lg text-steel leading-relaxed">
          This section provides clear, helpful answers so users can resolve issues quickly without contacting support
          saving valuable time.
        </p>
      </Reveal>

      {/* 2. Category tabs */}
      <Reveal delay={80} class="flex flex-wrap justify-center gap-3 mb-12">
        {tabs.map((t, idx) => (
          <button
            type="button"
            data-faq-tab={String(idx)}
            class:list={[
              'faq-tab rounded-full border px-5 py-2.5 text-xs font-semibold transition-colors',
              idx === 0
                ? 'border-brand bg-primary text-on-primary'
                : 'border-hairline bg-canvas text-steel hover:border-brand/40 hover:text-brand',
            ]}
          >
            {t}
          </button>
        ))}
      </Reveal>

      {/* 3. Accordion panels */}
      <div class="mb-20">
        {tabs.map((t, tabIdx) => (
          <div data-faq-panel={String(tabIdx)} class="space-y-4" style={tabIdx === 0 ? '' : 'display:none'}>
            {questions.map((q, idx) => (
              <Reveal delay={idx * 50}>
                <details class="group rounded-lg border border-hairline bg-canvas p-6 shadow-[var(--shadow-subtle)] cursor-pointer transition-all hover:shadow-[var(--shadow-subtle)] [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex items-center justify-between gap-4 font-semibold text-ink font-heading text-lg">
                    <span>{q}</span>
                    <span class="w-8 h-8 rounded-full bg-surface flex items-center justify-center shrink-0 group-open:rotate-180 transition-transform">
                      <Icon name="lucide:chevron-down" class="w-4 h-4 text-steel" />
                    </span>
                  </summary>
                  <p class="mt-4 text-steel text-sm leading-relaxed border-t border-hairline-soft pt-4 font-normal">
                    {answer}
                  </p>
                </details>
              </Reveal>
            ))}
          </div>
        ))}
      </div>

      {/* 4. Need help contact form */}
      <Reveal class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="text-3xl sm:text-5xl font-semibold text-ink font-heading tracking-tight mb-5">Need help?</h2>
        <p class="text-lg text-steel leading-relaxed">
          Get quick answers and friendly assistance anytime you need.
        </p>
      </Reveal>

      <Reveal delay={100} class="rounded-lg border border-hairline bg-canvas p-8 md:p-12 shadow-[var(--shadow-card)] max-w-2xl mx-auto">
        <form class="space-y-4">
          <input
            type="text"
            placeholder="Your full name"
            class="w-full rounded-md border border-hairline px-5 py-3 text-sm text-ink placeholder:text-stone focus:border-brand focus:outline-none"
          />
          <input
            type="text"
            placeholder="Your email address"
            class="w-full rounded-md border border-hairline px-5 py-3 text-sm text-ink placeholder:text-stone focus:border-brand focus:outline-none"
          />
          <textarea
            rows="4"
            placeholder="Write your message"
            class="w-full resize-none rounded-md border border-hairline px-5 py-3 text-sm text-ink placeholder:text-stone focus:border-brand focus:outline-none"
          ></textarea>
          <label class="flex items-center gap-2 text-sm text-steel">
            <input type="checkbox" class="h-4 w-4 rounded border-hairline text-brand focus:ring-brand" />
            I agree to receive marketing materials
          </label>
          <button
            type="submit"
            class="w-full rounded-full bg-primary py-3.5 text-sm font-semibold text-on-primary hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]"
          >
            Send Analysis
          </button>
        </form>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const tabButtons = document.querySelectorAll<HTMLElement>('[data-faq-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-faq-panel]');
  const activeClasses = ['border-primary', 'bg-primary', 'text-on-primary'];
  const idleClasses = ['border-hairline', 'bg-canvas', 'text-steel'];

  tabButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.faqTab;
      tabButtons.forEach((b) => {
        const isActive = b.dataset.faqTab === target;
        b.classList.toggle('hover:border-brand/40', !isActive);
        b.classList.toggle('hover:text-brand', !isActive);
        activeClasses.forEach((c) => b.classList.toggle(c, isActive));
        idleClasses.forEach((c) => b.classList.toggle(c, !isActive));
      });
      panels.forEach((p) => {
        p.style.display = p.dataset.faqPanel === target ? '' : 'none';
      });
    });
  });
</script>
