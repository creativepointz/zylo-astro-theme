---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const badges = ['Rated #1 SaaS solution for business growth', 'Leader position winter 2026'];

const cards = [
  {
    eyebrow: '24/7 Support for customers',
    title: 'Contact support',
    icon: 'lucide:headphones',
    rows: [
      { label: 'Call support', value: '(510) 630-2397', href: 'tel:5106302397', icon: 'lucide:phone' },
      { label: 'Let us help', value: 'hello@zylo.co', href: 'mailto:hello@zylo.co', icon: 'lucide:mail' },
    ],
  },
  {
    eyebrow: 'Talk to our Sales team',
    title: 'Contact sales',
    icon: 'lucide:briefcase',
    rows: [
      { label: 'Get a demo', value: 'See Zylo in action', href: '/contact', icon: 'lucide:play' },
      { label: 'Let us help', value: 'hello@zylo.co', href: 'mailto:hello@zylo.co', icon: 'lucide:mail' },
    ],
  },
];

const faqs = [
  'How does Zylo automate our daily tasks?',
  'Can I build custom tools or connect third-party APIs?',
  'Is my project data secure and compliant on Zylo?',
  'What kind of templates are available to start with?',
  'How does the AI agent workflow builder work?',
];

const faqAnswer =
  'Zylo uses intelligent triggers and data connectors to map and execute workflows. You can visually configure steps, map fields between tools, and let our agents handle repetitive tasks autonomously.';
---

<Layout title="Support — Zylo Platform" description="It's always easy to contact our top-rated support team.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] bg-canvas">
    {/* 1. Compact centered hero */}
    <div class="container-page pb-16 md:pb-20">
      <Reveal class="text-center max-w-3xl mx-auto">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Support
        </span>
        <h1 class="h1 mb-6">
          See why our support is consistently called the best in the industry
        </h1>
        <p class="subtitle mb-8">It's always easy to contact our top-rated support team.</p>
        <div class="flex flex-wrap justify-center gap-2">
          {badges.map((b) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-steel">
              <Icon name="lucide:award" class="w-4 h-4 text-brand" />
              {b}
            </span>
          ))}
        </div>
      </Reveal>
    </div>

    {/* 2. Accordion list */}
    <div class="container-page pb-16 md:pb-24">
      <Reveal class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="h2 mb-4">Need help?</h2>
        <p class="subtitle">Get quick answers and friendly assistance anytime you need.</p>
      </Reveal>

      <div class="space-y-3 max-w-3xl mx-auto">
        {faqs.map((q, idx) => (
          <Reveal delay={idx * 50}>
            <details class="group rounded-md border border-hairline-soft bg-canvas p-6 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4">
                <span class="h5">{q}</span>
                <Icon
                  name="lucide:chevron-down"
                  class="w-4 h-4 shrink-0 text-steel transition-transform group-open:rotate-180"
                />
              </summary>
              <p class="p-rg mt-4">{faqAnswer}</p>
            </details>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 3. Contact card row */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {cards.map((c, idx) => (
          <Reveal delay={idx * 80}>
            <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
              <span class="icon-tile mb-5">
                <Icon name={c.icon} class="w-5 h-5" />
              </span>
              <p class="eyebrow mb-2">{c.eyebrow}</p>
              <h3 class="h5 mb-6">{c.title}</h3>
              <div class="space-y-4">
                {c.rows.map((r) => (
                  <div class="flex items-start gap-3">
                    <Icon name={r.icon} class="w-4 h-4 text-steel mt-0.5 shrink-0" />
                    <div>
                      <span class="block p-sm">{r.label}</span>
                      <a href={r.href} class="text-sm font-medium text-ink">{r.value}</a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page section">
        <Reveal class="text-center max-w-2xl mx-auto">
          <h2 class="h2 mb-4">Prefer to self-serve?</h2>
          <p class="p-rg mb-8">
            If you prefer to do things yourself, we’ve also got articles teaching you how to use your new system.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/faq" class="btn-primary btn-lg">
              Browse the FAQ <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Contact us</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
