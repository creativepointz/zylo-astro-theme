---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const badges = ['Rated #1 SaaS solution for business growth', 'Leader position winter 2026'];

const cards = [
  {
    eyebrow: '24/7 Support for customers',
    title: 'Contact support',
    icon: 'lucide:headphones',
    rows: [
      { label: 'Call support', value: '(510) 630-2397', href: 'tel:5106302397', icon: 'lucide:phone' },
      { label: 'Let us help', value: 'hello@zylo.co', href: 'mailto:hello@zylo.co', icon: 'lucide:mail' },
    ],
  },
  {
    eyebrow: 'Talk to our Sales team',
    title: 'Contact sales',
    icon: 'lucide:briefcase',
    rows: [
      { label: 'Get a demo', value: 'See Zylo in action', href: '/contact', icon: 'lucide:play' },
      { label: 'Let us help', value: 'hello@zylo.co', href: 'mailto:hello@zylo.co', icon: 'lucide:mail' },
    ],
  },
];

const faqs = [
  'How does an AI resume builder work?',
  'Can the AI customize resumes for different jobs?',
  'Does it improve my chances of getting hired?',
  'Does it have templates for different industries?',
  'What file formats can I download (PDF, TXT, DOCX)?',
];

const faqAnswer =
  'When you enter your experience and the specific job you’re targeting, the AI analyzes the job description and tailors your resume to match the key skills, keywords.';
---

<Layout title="Support — Zylo Platform" description="It's always easy to contact our top-rated support team.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Support top */}
      <Reveal class="text-center max-w-4xl mx-auto mb-20">
        <h1 class="text-4xl sm:text-6xl font-bold text-slate-900 font-heading tracking-tight mb-6">
          See why our support is consistently called the best in the world saas solutions
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          It's always easy to contact our top-rated support team.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          {badges.map((b) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold text-slate-800 shadow-sm">
              <Icon name="lucide:award" class="w-4 h-4 text-brand" />
              {b}
            </span>
          ))}
        </div>
      </Reveal>

      {/* 2. Support center */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        {cards.map((c, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10 shadow-sm h-full">
              <div class="w-12 h-12 rounded-2xl bg-brand/10 text-brand flex items-center justify-center mb-6">
                <Icon name={c.icon} class="w-6 h-6" />
              </div>
              <span class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">{c.eyebrow}</span>
              <h2 class="text-2xl font-bold text-slate-900 font-heading mb-8">{c.title}</h2>
              <div class="space-y-5">
                {c.rows.map((r) => (
                  <div class="flex items-start gap-3">
                    <Icon name={r.icon} class="w-4 h-4 text-brand mt-1 shrink-0" />
                    <div>
                      <span class="block text-xs font-semibold text-slate-500 mb-1">{r.label}</span>
                      <a href={r.href} class="text-sm font-semibold text-slate-900 hover:text-brand transition-colors">
                        {r.value}
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Self-serve articles callout */}
      <Reveal delay={120} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10 shadow-sm text-center mb-20">
        <div class="w-12 h-12 rounded-2xl bg-brand/10 text-brand flex items-center justify-center mx-auto mb-6">
          <Icon name="lucide:book-open" class="w-6 h-6" />
        </div>
        <p class="text-base text-slate-600 leading-relaxed max-w-2xl mx-auto">
          If you prefer to do things yourself, we’ve also got articles teaching you how to use your new system.
        </p>
      </Reveal>

      {/* 4. Need help FAQ */}
      <Reveal class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-5">Need help?</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          Get quick answers and friendly assistance anytime you need.
        </p>
      </Reveal>

      <div class="space-y-4 max-w-3xl mx-auto">
        {faqs.map((q, idx) => (
          <Reveal delay={idx * 50}>
            <details class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm cursor-pointer transition-all hover:shadow-md [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex items-center justify-between gap-4 font-bold text-slate-900 font-heading text-lg">
                <span>{q}</span>
                <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center shrink-0 group-open:rotate-180 transition-transform">
                  <Icon name="lucide:chevron-down" class="w-4 h-4 text-slate-700" />
                </span>
              </summary>
              <p class="mt-4 text-slate-600 text-sm leading-relaxed border-t border-slate-100 pt-4 font-normal">
                {faqAnswer}
              </p>
            </details>
          </Reveal>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
