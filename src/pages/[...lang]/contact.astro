---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const offices = [
  { country: 'Colombia', address: 'Bogota D.C., Colombia, b. a 181 C No. 930 Ap 202', main: false },
  { country: 'France', address: '9 Pearse Street, Kinsale, Cork, P17 AH66, Ireland', main: true },
  { country: 'Egypt', address: "Av. Cordoba 1309, 3'A, City of Buenos Aires, Egypt", main: false },
];

const demoDetails = [
  { icon: 'lucide:mail', label: 'Email us', value: 'contact@zylo.co', href: 'mailto:contact@zylo.co' },
  { icon: 'lucide:phone', label: 'Call us', value: '+1-202-555-0144', href: 'tel:+12025550144' },
  { icon: 'lucide:map-pin', label: 'Visit us', value: '35Park Avenue, Uk', href: '#' },
];
---

<Layout title="Contact us — Zylo" description="Our support team is here to assist you reach out anytime.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] bg-canvas">
    {/* 1. Compact centered hero */}
    <div class="container-page pb-16 md:pb-20">
      <Reveal class="text-center max-w-3xl mx-auto">
        <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
          Contact us
        </span>
        <h1 class="h1">Our support team is here to assist you reach out anytime.</h1>
      </Reveal>
    </div>

    {/* 2. Offices — 3-up */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {offices.map((o, idx) => (
          <Reveal delay={idx * 80}>
            <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
              <div class="flex items-center justify-between gap-3 mb-5">
                <span class="icon-tile">
                  <Icon name="lucide:map-pin" class="w-5 h-5" />
                </span>
                {o.main && (
                  <span class="rounded-full border border-hairline bg-surface px-3 py-1 text-[13px] font-semibold text-steel">
                    Main Office
                  </span>
                )}
              </div>
              <h2 class="h5 mb-2">{o.country}</h2>
              <p class="p-sm">{o.address}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>

    {/* 3. Form + supporting detail */}
    <div class="container-page pb-16 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <Reveal>
          <div class="rounded-lg border border-hairline bg-canvas p-6 md:p-8">
            <form class="space-y-4">
              <div>
                <label class="block p-sm mb-1.5" for="contact-name">Your full name</label>
                <input
                  id="contact-name"
                  type="text"
                  placeholder="Your full name"
                  class="w-full h-10 rounded-md border border-hairline bg-canvas px-4 text-base text-ink placeholder:text-muted focus:border-brand focus:border-2 focus:outline-none"
                />
              </div>
              <div>
                <label class="block p-sm mb-1.5" for="contact-email">Your email address</label>
                <input
                  id="contact-email"
                  type="email"
                  placeholder="Your email address"
                  class="w-full h-10 rounded-md border border-hairline bg-canvas px-4 text-base text-ink placeholder:text-muted focus:border-brand focus:border-2 focus:outline-none"
                />
              </div>
              <div>
                <label class="block p-sm mb-1.5" for="contact-message">Write your message</label>
                <textarea
                  id="contact-message"
                  rows="5"
                  placeholder="Write your message"
                  class="w-full resize-none rounded-md border border-hairline bg-canvas px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:border-2 focus:outline-none"
                ></textarea>
              </div>
              <label class="flex items-center gap-2 p-sm">
                <input type="checkbox" class="h-4 w-4 rounded-sm border-hairline text-brand" />
                I agree to receive marketing materials
              </label>
              <button type="submit" class="btn-primary btn-lg w-full">Send Analysis</button>
            </form>
          </div>
        </Reveal>

        <Reveal delay={100}>
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Let’s contact us
          </span>
          <h2 class="h2 mb-4">Get in touch with our support for help.</h2>
          <p class="subtitle mb-8">We accept smoke signals, but modern communication works better today.</p>

          <div class="space-y-4">
            {demoDetails.map((d) => (
              <a href={d.href} class="flex items-center gap-4 rounded-md border border-hairline bg-canvas p-4">
                <span class="icon-tile shrink-0">
                  <Icon name={d.icon} class="w-5 h-5" />
                </span>
                <span>
                  <span class="block p-sm">{d.label}</span>
                  <span class="block text-sm font-medium text-ink">{d.value}</span>
                </span>
              </a>
            ))}
          </div>
        </Reveal>
      </div>
    </div>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft border-t border-hairline">
      <div class="container-page section">
        <Reveal class="text-center max-w-2xl mx-auto">
          <h2 class="h2 mb-4">Book a Demo!</h2>
          <p class="p-rg mb-8">We will contact again after receive your request in 24h</p>
          <a href="mailto:contact@zylo.co" class="btn-primary btn-lg">
            Book a demo <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
