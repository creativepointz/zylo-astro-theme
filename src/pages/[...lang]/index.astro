---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Hero from '@/components/sections/Hero.astro';
import MakersMarquee from '@/components/sections/MakersMarquee.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import Features from '@/components/sections/Features.astro';
import WhyZylo from '@/components/sections/WhyZylo.astro';
import PriceWedge from '@/components/sections/PriceWedge.astro';
import Integrations from '@/components/sections/Integrations.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Footer from '@/components/global/Footer.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}
---

<Layout
  title="Zylo — SaaS & AI Startup Technology Platform"
  description="Where teams move faster & work gets done. Map out tasks, work together effortlessly, and follow progress all from one unified tool."
>
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-on-primary"
  >
    Skip to content
  </a>

  <Navbar />

  <main id="main">
    <Hero />
    <MakersMarquee />
    <HowItWorks />
    <Features />
    <WhyZylo />
    <PriceWedge />
    <Integrations />
    <FAQ />
  </main>

  <Footer
    ctaTitle="Make the first step toward managing your tasks more effectively."
    ctaSubtitle="Where teams move faster & work gets done."
  />
</Layout>
