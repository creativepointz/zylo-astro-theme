---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const perks = [
  { icon: 'lucide:layout-dashboard', label: 'Real-time collaboration' },
  { icon: 'lucide:shield-check', label: 'Two factor authentication (2FA)' },
  { icon: 'lucide:sparkles', label: 'AI-Powered task assistant' },
  { icon: 'lucide:bar-chart-3', label: 'Time tracking & productivity reports' },
];
---

<Layout title="Login — Welcome To Your Zylo System" description="Sign in with email or continue with Google to access your Zylo system.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-16 md:pb-24 bg-canvas">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-2 rounded-lg border border-hairline overflow-hidden">
        {/* 1. Welcome panel */}
        <Reveal>
          <div class="h-full bg-canvas-dark p-8 md:p-12 flex flex-col justify-between">
            <div>
              <h1 class="h2 text-on-dark mb-4">Welcome To Your Zylo System.</h1>
              <p class="text-base leading-[1.5] text-on-dark-muted">
                Sign in to run your workflows, review automation activity and pick up where your team left off.
              </p>
            </div>
            <ul class="mt-12 space-y-4">
              {perks.map((p) => (
                <li class="flex items-center gap-3">
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-hairline-dark text-on-dark">
                    <Icon name={p.icon} class="w-5 h-5" />
                  </span>
                  <span class="text-sm leading-[1.5] text-on-dark-muted">{p.label}</span>
                </li>
              ))}
            </ul>
          </div>
        </Reveal>

        {/* 2. Sign in form panel */}
        <Reveal delay={100}>
          <div class="h-full bg-canvas p-8 md:p-12">
            <div class="max-w-sm mx-auto">
              <h2 class="h3 mb-8">Sign In</h2>

              <a href="#" class="btn-secondary btn-lg w-full">
                <Icon name="lucide:globe" class="w-4 h-4" />
                Continue with Google
              </a>

              <div class="flex items-center gap-4 my-8">
                <span class="h-px flex-1 bg-hairline"></span>
                <span class="text-sm text-stone">Or Sign In with email</span>
                <span class="h-px flex-1 bg-hairline"></span>
              </div>

              <form class="space-y-5">
                <div>
                  <label class="block p-sm mb-1.5" for="signin-email">Your Email</label>
                  <input
                    id="signin-email"
                    type="email"
                    required
                    class="w-full h-10 rounded-md border border-hairline bg-canvas px-4 text-base text-ink placeholder:text-muted focus:border-brand focus:border-2 focus:outline-none"
                  />
                </div>
                <div>
                  <label class="block p-sm mb-1.5" for="signin-password">Password</label>
                  <input
                    id="signin-password"
                    type="password"
                    required
                    class="w-full h-10 rounded-md border border-hairline bg-canvas px-4 text-base text-ink placeholder:text-muted focus:border-brand focus:border-2 focus:outline-none"
                  />
                </div>

                <div class="flex items-center justify-between gap-4">
                  <label class="flex items-center gap-2 text-sm text-stone cursor-pointer">
                    <input type="checkbox" class="h-4 w-4 rounded-sm border-hairline text-brand" />
                    Remember me
                  </label>
                  <a href="#" class="text-sm font-medium text-ink">Forgot password ?</a>
                </div>

                <button type="submit" class="btn-primary btn-lg w-full">Sign In</button>
              </form>

              <p class="mt-8 text-sm text-stone">
                Don't have account ? <a href="/register" class="font-medium text-ink">Register</a>
              </p>
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
