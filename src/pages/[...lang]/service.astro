---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const solutions = [
  { icon: 'lucide:credit-card', title: 'Accept payments', desc: 'Send invoices or payment links to receive one time payments fast.' },
  { icon: 'lucide:bar-chart-3', title: 'Track finances', desc: 'Keep track of your MRR, orders, and profits from our dashboard' },
  { icon: 'lucide:mail', title: 'Email marketing', desc: 'Send invoices or payment links to receive one time payments fast.' },
];

const featureServices = [
  {
    title: 'Smart agenda builder',
    desc: 'Plan meetings with clarity and purpose using AI-powered agenda creation. The Smart Agenda Builder automatically structures discussion points.',
    bullets: ['Organizes topics with clear timelines', 'Reduces unnecessary discussions']
  },
  {
    title: 'Instant recap & installer',
    desc: 'Get a clear summary of your meeting in seconds. Instantly receive key takeaways, decisions, and highlights generated by AI so everyone stays aligned.',
    bullets: ['Highlights key decisions and action points', 'Keeps the whole team on the same page']
  },
  {
    title: 'Live AI note taker',
    desc: 'Capture every important moment automatically while your meeting happens. Live AI Note Taker listens in real time.',
    bullets: ['Notes are ready instantly after the meeting', 'Real-time AI-powered note taking']
  }
];

const finHighlights = [
  'Connect globally, collaborate seamlessly',
  'Smart automation for faster financial operations',
  'Seamless payments and multi-currency support'
];
---

<Layout title="Service — The Solutions for Your All Payment Needs" description="Zylo offers you all the solutions you need for your business without stressing.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Solution Hero */}
      <Reveal class="text-center max-w-4xl mx-auto mb-16">
        <h1 class="text-4xl sm:text-6xl font-bold text-slate-900 font-heading tracking-tight mb-6">
          The solutions for your all payment needs
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
          Zylo offers you all the solutions you need for your business without stressing
        </p>
      </Reveal>

      {/* 2. Top 3 Solution Cards */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
        {solutions.map((s, idx) => (
          <Reveal delay={idx * 80}>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm hover:border-brand/40 hover:shadow-lg transition-all h-full">
              <div class="w-12 h-12 rounded-2xl bg-brand/10 text-brand flex items-center justify-center mb-6">
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-2xl font-bold text-slate-900 font-heading mb-3">{s.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{s.desc}</p>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 3. Services Section Header */}
      <Reveal class="text-center max-w-3xl mx-auto mb-14">
        <span class="inline-block border border-dashed border-slate-300 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-5">
          Services
        </span>
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight">
          Advanced enterprise security solutions
        </h2>
      </Reveal>

      {/* 4. Detailed Service Feature Blocks */}
      <div class="space-y-12 mb-24">
        {featureServices.map((fs, idx) => (
          <Reveal delay={idx * 100} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-12 shadow-sm flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="max-w-xl space-y-4">
              <h3 class="text-3xl font-bold text-slate-900 font-heading">{fs.title}</h3>
              <p class="text-slate-600 text-base leading-relaxed">{fs.desc}</p>
              <div class="space-y-2 pt-2">
                {fs.bullets.map((b) => (
                  <div class="flex items-center gap-2.5 text-xs font-semibold text-slate-700">
                    <Icon name="lucide:check-circle" class="w-4 h-4 text-emerald-500 shrink-0" />
                    <span>{b}</span>
                  </div>
                ))}
              </div>
            </div>
            <a href="/contact" class="inline-flex h-11 items-center justify-center gap-2 rounded-full border border-slate-200 px-6 text-xs font-semibold text-slate-800 hover:bg-brand hover:text-white hover:border-brand transition-colors shrink-0">
              Read more <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </Reveal>
        ))}
      </div>

      {/* 5. Built Smarter Transactions Callout */}
      <Reveal class="rounded-3xl bg-slate-900 text-white p-10 md:p-16 shadow-2xl">
        <div class="max-w-3xl">
          <span class="inline-block border border-white/20 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider mb-6 text-slate-200">
            Built smarter transactions
          </span>
          <h2 class="text-3xl md:text-5xl font-bold font-heading mb-6">
            Grow your transaction from another level
          </h2>
          <p class="text-slate-300 text-base leading-relaxed mb-8">
            Fintech harnesses advanced technology to transform and optimize financial processes, delivering innovative, secure, and intelligent banking solutions that enhance efficiency.
          </p>
          <div class="space-y-3">
            {finHighlights.map((fh) => (
              <div class="flex items-center gap-3 text-sm font-semibold text-slate-200">
                <Icon name="lucide:check-circle" class="w-4 h-4 text-emerald-400 shrink-0" />
                <span>{fh}</span>
              </div>
            ))}
          </div>
        </div>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
