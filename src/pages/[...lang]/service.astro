---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX'];

/* 5-up feature grid */
const featureGrid = [
  { icon: 'lucide:layers', title: 'Build Workflows', desc: 'Create tasks and map your automation pipelines visually in minutes.' },
  { icon: 'lucide:bar-chart-3', title: 'Monitor Pipelines', desc: 'Keep track of your active tasks, costs, and runs from one dashboard.' },
  { icon: 'lucide:users', title: 'Collaborate Live', desc: 'Work together with team members on shared boards and project views.' },
  { icon: 'lucide:repeat', title: 'Deploy Agents', desc: 'Schedule background tasks and let Zylo run them autonomously.' },
  { icon: 'lucide:shield-check', title: 'Audit Logs', desc: 'Track permissions and verify actions with enterprise-grade security logs.' },
];

const featureServices = [
  {
    title: 'Smart agenda builder',
    desc: 'Plan meetings with clarity and purpose using AI-powered agenda creation. The Smart Agenda Builder automatically structures discussion points.',
    bullets: ['Organizes topics with clear timelines', 'Reduces unnecessary discussions'],
    image: '/features/Custom Branding.png',
  },
  {
    title: 'Instant recap & installer',
    desc: 'Get a clear summary of your meeting in seconds. Instantly receive key takeaways, decisions, and highlights generated by AI so everyone stays aligned.',
    bullets: ['Highlights key decisions and action points', 'Keeps the whole team on the same page'],
    image: '/features/Export Anytime.png',
  },
  {
    title: 'Live AI note taker',
    desc: 'Capture every important moment automatically while your meeting happens. Live AI Note Taker listens in real time.',
    bullets: ['Notes are ready instantly after the meeting', 'Real-time AI-powered note taking'],
    image: '/features/Your AI writing partner..png',
  },
];

const finHighlights = [
  'Connect globally, collaborate seamlessly',
  'Smart automation for faster daily operations',
  'Unified task monitoring and error tracing',
];

const stats = [
  { value: '5', label: 'Services on one platform' },
  { value: '10,000+', label: 'Businesses running on Zylo' },
  { value: '99.9%', label: 'Platform uptime' },
];
---

<Layout title="Services — The Unified Operations Engine for Your Team" description="Zylo offers you all the tools and workflow automation solutions your business needs to scale effortlessly.">
  <Navbar />

  <main id="main" class="bg-canvas">

    {/* 1. Centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-4xl mx-auto">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Services
          </span>
          <h1 class="hero-display mb-6">The unified operations engine for your team</h1>
          <p class="subtitle max-w-2xl mx-auto mb-8">
            Zylo offers you all the tools and workflow automation solutions your business needs to scale effortlessly
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Contact sales</a>
          </div>
        </Reveal>

        <Reveal delay={120} class="mt-12 md:mt-16">
          <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)] overflow-hidden max-w-5xl mx-auto">
            <img src="/placeholder.png" alt="Zylo services dashboard" class="w-full rounded-md block" />
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Social proof strip */}
    <section class="border-y border-hairline py-12">
      <div class="container-page text-center">
        <Reveal>
          <p class="eyebrow mb-8">
            Trusted by <span class="text-ink">10,000+</span> businesses worldwide
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center justify-items-center">
            {brands.map((b) => (
              <span class="p-lg font-medium tracking-tight text-steel">{b}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Feature grid — 5-up */}
    <section class="section">
      <div class="container-page">
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
          {featureGrid.map((f, idx) => (
            <Reveal delay={idx * 60}>
              <div class="card h-full">
                <span class="icon-tile mb-5">
                  <Icon name={f.icon} class="w-5 h-5" />
                </span>
                <h3 class="h5 mb-2">{f.title}</h3>
                <p class="p-sm">{f.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Alternating feature rows */}
    <section class="pb-16 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto mb-14">
          <span class="eyebrow mb-5 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Services
          </span>
          <h2 class="h2">Advanced enterprise security solutions</h2>
        </Reveal>

        <div class="space-y-16 md:space-y-24">
          {featureServices.map((fs, idx) => (
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
              <Reveal class={idx % 2 === 1 ? 'lg:order-2' : ''}>
                <h3 class="h2 mb-5">{fs.title}</h3>
                <p class="p-rg mb-6">{fs.desc}</p>
                <div class="space-y-3 mb-8">
                  {fs.bullets.map((b) => (
                    <div class="flex items-start gap-3">
                      <Icon name="lucide:check-circle" class="w-4 h-4 mt-1 shrink-0 text-brand" />
                      <span class="p-sm">{b}</span>
                    </div>
                  ))}
                </div>
                <a href="/contact" class="btn-secondary btn-md">
                  Read more <Icon name="lucide:arrow-right" class="w-4 h-4" />
                </a>
              </Reveal>
              <Reveal delay={100} class={idx % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-card)] overflow-hidden">
                  <img src={fs.image} alt={fs.title} class="w-full rounded-md block" />
                </div>
              </Reveal>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* 5. Stat row */}
    <section class="border-y border-hairline py-16">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          {stats.map((s, idx) => (
            <Reveal delay={idx * 80}>
              <div class="display-lg mb-2">{s.value}</div>
              <p class="p-sm">{s.label}</p>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7. Closing CTA band */}
    <section class="section bg-surface-soft">
      <div class="container-page">
        <Reveal class="text-center max-w-3xl mx-auto">
          <span class="eyebrow mb-6 inline-block rounded-full border border-hairline bg-canvas px-3 py-1">
            Built smarter transactions
          </span>
          <h2 class="h2 mb-5">Grow your transaction from another level</h2>
          <p class="p-rg mb-8">
            Fintech harnesses advanced technology to transform and optimize financial processes, delivering innovative, secure, and intelligent banking solutions that enhance efficiency.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
            {finHighlights.map((fh) => (
              <div class="flex items-center gap-2.5">
                <Icon name="lucide:check-circle" class="w-4 h-4 shrink-0 text-brand" />
                <span class="p-sm">{fh}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/pricing" class="btn-primary btn-lg">
              Get started <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/contact" class="btn-secondary btn-lg">Contact sales</a>
          </div>
        </Reveal>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
