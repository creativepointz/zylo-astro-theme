---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

// Table of contents derived from the document's own clause headings.
const toc = [
  { id: 'what-is-a-return-policy', title: 'What Is a Return Policy?' },
  { id: 'what-is-a-refund-policy', title: 'What Is a Refund Policy?' },
  { id: 'difference-between-return-and-refund-policy', title: 'Is There a difference between a return policy and refund policy?' },
  { id: 'who-needs-a-return-policy', title: 'Who Needs a Return Policy?' },
];
---

<Layout title="Refund policy Zylo" description="How, when, and under what conditions returns and refunds are handled at Zylo.">
  <Navbar />

  <main id="main" class="bg-canvas pt-24 md:pt-[120px]">
    {/* Compact hero */}
    <section class="border-b border-hairline-soft pb-10">
      <div class="container-page">
        <Reveal class="max-w-[720px]">
          <p class="eyebrow mb-4">Guaranteed Satisfaction</p>
          <h1 class="h1 mb-4">Refund policy Zylo</h1>
          <p class="p-lt">
            As an online retailer, you already know that returns happen a lot and it&apos;s
            impossible to please every customer.
          </p>
        </Reveal>
      </div>
    </section>

    {/* 2-column legal document body */}
    <section class="py-12 md:py-16">
      <div class="container-page">
        <div class="flex gap-12">
          <aside class="hidden w-[240px] shrink-0 lg:block">
            <nav class="sticky top-28 flex flex-col gap-2" aria-label="On this page">
              <p class="eyebrow mb-2">On this page</p>
              {toc.map((item) => (
                <a href={`#${item.id}`} data-toc-link class="p-sm text-steel hover:text-ink">{item.title}</a>
              ))}
            </nav>
          </aside>

          <div class="w-full max-w-[720px]">
            <section id="what-is-a-return-policy" class="scroll-mt-28 border-b border-hairline-soft pb-12">
              <h2 class="h3 mb-5">What Is a Return Policy?</h2>
              <p class="p-rg mb-4">
                A return policy outlines how, when, and under what conditions your customers can return
                purchased goods and services.
              </p>
              <p class="p-rg mb-4">You can name your return policy in many different ways, such as:</p>
              <ul class="mb-4 list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Return and refund policy</li>
                <li class="p-rg">Returns and exchange policy</li>
                <li class="p-rg">Shipping and return Policy</li>
                <li class="p-rg">Store Return Policy</li>
              </ul>
              <p class="p-rg">
                A well-written return policy can help your business retain customers &amp; increase sales.
                But overly restrictive or confusing policies tend to scare people away.
              </p>
            </section>

            <section id="what-is-a-refund-policy" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">What Is a Refund Policy?</h2>
              <p class="p-rg">
                A refund policy is a document that outlines the rules for getting refunds for
                purchased goods and services. It often details the eligibility requirements
                for refunds, types of refunds given, the refund timeframe, and
                the return process.
              </p>
            </section>

            <section id="difference-between-return-and-refund-policy" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">
                Is There a difference between a return policy and refund policy?
              </h2>
              <div class="space-y-4">
                <p class="p-rg">Returns and refunds are technically two separate occurrences.</p>
                <p class="p-rg">
                  A return policy indicates rules and conditions about if, when, and for how long
                  your customers can return a purchase and receive reimbursement. It includes
                  information about how long your customer has to make the return and which
                  items are included or excluded from the policy.
                </p>
                <p class="p-rg">
                  A refund policy states if and when your customers are entitled to receive
                  reimbursement for a purchase and do not have to be contingent on a return.
                  For example, if a customer received a faulty or damaged item, or if the
                  order never arrives, your refund policy.
                </p>
              </div>
            </section>

            <section id="who-needs-a-return-policy" class="scroll-mt-28 pt-12">
              <h2 class="h3 mb-5">Who Needs a Return Policy?</h2>
              <p class="p-rg mb-4">
                Anyone directly selling goods or services to consumers online or in person needs
                a return policy, including:
              </p>
              <ul class="mb-4 list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Small businesses</li>
                <li class="p-rg">Ecommerce websites</li>
                <li class="p-rg">Retail stores</li>
                <li class="p-rg">Dropshipping companies</li>
                <li class="p-rg">Software as a Service (SaaS) businesses</li>
              </ul>
              <p class="p-rg">
                Your competitors, no doubt, already offer refunds, returns, and exchanges. This is a
                common practice, and customers will probably choose a competitor with a good
                return policy over your business if you don&apos;t provide one.
              </p>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const setActive = (id: string) => {
      links.forEach((l) => {
        const on = l.getAttribute('href') === `#${id}`;
        l.classList.toggle('text-ink', on);
        l.classList.toggle('text-steel', !on);
      });
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        });
      },
      { rootMargin: '-120px 0px -70% 0px' }
    );
    links.forEach((l) => {
      const target = document.querySelector(l.getAttribute('href') || '');
      if (target) observer.observe(target);
    });
  }
</script>
