---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const plans = [
  {
    name: 'Starter',
    price: '€89',
    yearly: '€75',
    period: '/month',
    desc: 'For small teams looking to organize tasks and automate basic workflows.',
    features: [
      'Real-time collaboration',
      'Unlimited projects & tasks',
      'Advanced task automation',
      'Team roles & permission control',
      'AI-Powered task assistant',
    ],
    bestFor: 'personal use, students',
    cta: 'Start for free',
    href: '/register',
    popular: false,
  },
  {
    name: 'Growth',
    price: '€199',
    yearly: '€169',
    period: '/month',
    desc: 'For scaling teams that need advanced automation, permissions, and reporting.',
    features: [
      'Gantt charts & timeline view',
      'Time tracking & productivity reports',
      'Kanban, calendar & list views',
      'File sharing & cloud storage',
      'Integrations with popular tools',
    ],
    bestFor: 'freelancers, small businesses',
    cta: 'Choose growth',
    href: '/register',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: '€999',
    yearly: '€849',
    period: '/month',
    desc: 'For large organizations requiring enterprise-grade security and dedicated scale.',
    features: [
      'Custom branding & label options',
      'Dedicated account manager',
      'Unlimited team members',
      'Two factor authentication (2FA)',
      '(SLA) Based priority support',
    ],
    bestFor: 'large teams, agencies',
    cta: 'Contact sales',
    href: '/contact',
    popular: false,
  },
];

// Feature comparison rows, grouped under eyebrow section-divider rows.
const comparisonGroups = [
  {
    group: 'Plan essentials',
    rows: ['Access All Features', 'No Hidden Fees', 'Flexible Pricing Models'],
  },
  {
    group: 'Program support',
    rows: ['Dedicated Program Manager', 'Volume Discounts', 'SLA Priority Support'],
  },
];

const logos = [
  'CloudScale',
  'DataPivot',
  'VentureLab',
  'SaaSify',
  'SecureBank',
  'FintechX',
];

const helpCards = [
  { title: 'Documentation', desc: 'Set up your workspace and ship your first automation.', icon: 'lucide:book-open', href: '/features' },
  { title: 'Support', desc: 'Reach the team for account, billing and workspace questions.', icon: 'lucide:life-buoy', href: '/support' },
  { title: 'Talk to sales', desc: 'Scope volume pricing and rollout for a larger team.', icon: 'lucide:message-circle', href: '/contact' },
  { title: 'Case studies', desc: 'See how other teams measure results with Zylo.', icon: 'lucide:bar-chart-3', href: '/case-studies' },
];

const faqs = [
  {
    q: 'How does the free trial work?',
    a: 'You can test any Zylo plan free for 14 days. No credit card is required to sign up, and you get access to all features in that plan.',
  },
  {
    q: 'Can I change plans or cancel anytime?',
    a: 'Yes! You can upgrade, downgrade, or cancel your subscription at any time directly from your workspace billing dashboard.',
  },
  {
    q: 'What happens if we exceed our workflow execution limit?',
    a: 'We will notify you when you approach your limit. We will never shut down active tasks without warning, and we offer flexible overage options.',
  },
  {
    q: 'Do you offer custom pricing for non-profits or startups?',
    a: 'Yes, we offer special discount programs for startups and non-profit organizations. Contact our sales team to learn more.',
  },
];
---

<Layout title="Transparent plans. Trusted value. — Zylo Pricing" description="Automate your workflows and operations with plans that scale with your team.">
  <Navbar />

  <main id="main" class="bg-canvas pt-24 md:pt-[120px]">
    {/* 1. Centered hero */}
    <section class="pb-10 md:pb-14">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <p class="eyebrow mb-4">Innovation that scales</p>
          <h1 class="h1 mb-5">Transparent plans. Trusted value.</h1>
          <p class="subtitle">
            Automate your workflows and operations with plans that scale with your team.
          </p>
        </Reveal>
      </div>
    </section>

    {/* 2. Billing controls row */}
    <section class="pb-12">
      <div class="container-page">
        <Reveal delay={100} class="flex flex-col items-center justify-center gap-5 sm:flex-row sm:gap-8">
          <div class="flex items-center gap-3">
            <div class="flex items-center rounded-full bg-surface p-1" id="billing-toggle">
              <button type="button" data-billing="monthly" class="rounded-full bg-canvas px-5 py-1.5 text-sm font-medium text-ink shadow-[var(--shadow-subtle)]">
                Pay monthly
              </button>
              <button type="button" data-billing="yearly" class="rounded-full px-5 py-1.5 text-sm font-medium text-steel hover:text-ink">
                Pay yearly
              </button>
            </div>
            <span class="rounded-full bg-brand px-2 py-0.5 text-[13px] font-semibold leading-[1.4] text-primary">
              Save up to 15% off
            </span>
          </div>

          <div class="flex items-center gap-4 text-sm font-medium text-steel">
            <label class="flex cursor-pointer items-center gap-1.5">
              <input type="radio" name="currency" checked class="text-brand focus:ring-brand" /> USD ($)
            </label>
            <label class="flex cursor-pointer items-center gap-1.5">
              <input type="radio" name="currency" class="text-brand focus:ring-brand" /> EUR (€)
            </label>
            <label class="flex cursor-pointer items-center gap-1.5">
              <input type="radio" name="currency" class="text-brand focus:ring-brand" /> GBP (£)
            </label>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 3. Tier cards */}
    <section class="pb-20 md:pb-24">
      <div class="container-page">
        <div class="grid grid-cols-1 items-stretch gap-6 md:grid-cols-3">
          {plans.map((p, idx) => (
            <Reveal delay={idx * 80} class="h-full">
              <div class={`relative flex h-full flex-col rounded-lg bg-canvas p-8 ${p.popular ? 'border-2 border-brand shadow-[var(--shadow-brand)]' : 'border border-hairline'}`}>
                {p.popular && (
                  <span class="absolute -top-3 left-8 rounded-full bg-primary px-3 py-1 text-[11px] font-semibold uppercase leading-[1.4] tracking-[0.5px] text-on-primary">
                    Popular Choice
                  </span>
                )}

                <h3 class="h3 mb-4">{p.name}</h3>

                <div class="mb-4 flex items-baseline gap-1.5">
                  <span
                    class="display-lg js-price"
                    data-monthly={p.price}
                    data-yearly={p.yearly}
                  >{p.price}</span>
                  <span class="p-sm text-stone">{p.period}</span>
                </div>

                <p class="p-sm mb-6">{p.desc}</p>

                <ul class="mb-6 space-y-3 border-t border-hairline-soft pt-6">
                  {p.features.map((f) => (
                    <li class="p-sm flex items-start gap-2.5">
                      <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-brand" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>

                <p class="p-sm mt-auto border-t border-hairline-soft pt-5">
                  <span class="font-medium text-ink">Best for:</span> {p.bestFor}
                </p>

                <a
                  href={p.href}
                  class={`mt-6 w-full ${p.popular ? 'btn-accent' : idx === 0 ? 'btn-primary' : 'btn-secondary'} btn-lg`}
                >
                  {p.cta}
                </a>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Feature comparison table */}
    <section class="pb-20 md:pb-24">
      <div class="container-page">
        <Reveal class="overflow-x-auto">
          <div class="min-w-[640px] overflow-hidden rounded-md border border-hairline bg-canvas">
            <div class="grid grid-cols-12 border-b border-hairline bg-surface-soft">
              <div class="col-span-6 px-5 py-4"></div>
              {plans.map((p) => (
                <div class="eyebrow col-span-2 px-5 py-4 text-center text-ink">
                  {p.name}
                </div>
              ))}
            </div>

            {comparisonGroups.map((group) => (
              <>
                <div class="border-b border-hairline-soft bg-surface-soft px-5 py-4">
                  <span class="eyebrow">{group.group}</span>
                </div>
                {group.rows.map((row) => (
                  <div class="grid grid-cols-12 border-b border-hairline-soft last:border-b-0">
                    <div class="p-sm col-span-6 px-5 py-4 text-ink">{row}</div>
                    {plans.map(() => (
                      <div class="col-span-2 flex items-center justify-center px-5 py-4">
                        <Icon name="lucide:check" class="h-4 w-4 text-brand" />
                      </div>
                    ))}
                  </div>
                ))}
              </>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 5. Logo wall / trust strip */}
    <section class="pb-20 md:pb-24">
      <div class="container-page">
        <Reveal class="text-center">
          <p class="p-lg mb-8">
            Trusted by <span class="font-medium text-ink">10,000+</span> businesses worldwide
          </p>
          <div class="grid grid-cols-2 items-center justify-items-center gap-y-6 sm:grid-cols-3 lg:grid-cols-6">
            {logos.map((logo) => (
              <span class="px-5 text-base font-medium text-steel">{logo}</span>
            ))}
          </div>
        </Reveal>
      </div>
    </section>

    {/* 6. FAQ accordion */}
    <section class="pb-20 md:pb-24">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
          <Reveal class="lg:col-span-5">
            <p class="eyebrow mb-4">Our faq</p>
            <h2 class="h2 mb-4">Frequently Asked Questions</h2>
            <p class="p-rg mb-8">
              Connect Analytics with your favourite tools to streamline workflows and keep everything running smoothly.
            </p>
            <a href="/contact" class="btn-primary btn-md">
              Contact us <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4" />
            </a>
          </Reveal>

          <div class="space-y-3 lg:col-span-7">
            {faqs.map((f, idx) => (
              <Reveal delay={idx * 60}>
                <details class="group rounded-md border border-hairline-soft bg-canvas p-6">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                    <span class="h5">{f.q}</span>
                    <Icon name="lucide:plus" class="h-4 w-4 shrink-0 text-steel group-open:hidden" />
                    <Icon name="lucide:minus" class="hidden h-4 w-4 shrink-0 text-steel group-open:block" />
                  </summary>
                  <p class="p-rg pt-4">{f.a}</p>
                </details>
              </Reveal>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* 7a. Need help? card row */}
    <section class="pb-20 md:pb-24">
      <div class="container-page">
        <Reveal class="mb-8">
          <p class="eyebrow mb-3">Need help?</p>
          <h2 class="h3">Still deciding which plan fits</h2>
        </Reveal>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {helpCards.map((c, idx) => (
            <Reveal delay={idx * 60} class="h-full">
              <a href={c.href} class="card flex h-full flex-col">
                <span class="icon-tile mb-4">
                  <Icon name={c.icon} class="h-4 w-4" />
                </span>
                <h3 class="h5 mb-2">{c.title}</h3>
                <p class="p-sm">{c.desc}</p>
              </a>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 7b. Closing CTA band */}
    <section class="bg-surface-soft py-16 md:py-24">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <h2 class="h2 mb-4">
            Start automating your team's workflow operations today
          </h2>
          <p class="p-rg mx-auto mb-10 max-w-2xl">
            Zylo delivers a visually intuitive workflow builder, providing your team with smooth tool connections and reliable execution logs all in one platform.
          </p>
          <form class="flex flex-wrap justify-center gap-3">
            <input
              type="email"
              placeholder="Enter your email.."
              class="h-10 w-full max-w-[300px] rounded-md border border-hairline bg-canvas px-4 text-base text-ink focus:border-brand focus:outline-none"
            />
            <button type="submit" class="btn-primary btn-md">
              Subscribe now
            </button>
          </form>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const toggle = document.getElementById('billing-toggle');
  if (toggle) {
    const buttons = toggle.querySelectorAll<HTMLButtonElement>('button[data-billing]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.billing;
        buttons.forEach((b) => {
          const active = b === btn;
          b.className = active
            ? 'rounded-full bg-canvas px-5 py-1.5 text-sm font-medium text-ink shadow-[var(--shadow-subtle)]'
            : 'rounded-full px-5 py-1.5 text-sm font-medium text-steel hover:text-ink';
        });
        document.querySelectorAll<HTMLElement>('.js-price').forEach((el) => {
          const value = mode === 'yearly' ? el.dataset.yearly : el.dataset.monthly;
          if (value) el.textContent = value;
        });
      });
    });
  }
</script>
