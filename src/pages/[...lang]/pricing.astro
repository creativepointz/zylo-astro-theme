---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';

import PricingHero from '@/components/sections/pricing/PricingHero.astro';
import PricingTable from '@/components/sections/pricing/PricingTable.astro';
import FAQ from '@/components/sections/FAQ.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

const pricingFaqs = [
  { q: 'Do I need technical skills to use Zylo?', a: 'No. Zylo is built for everyone. If you can describe a task, you can build an agent. No code required.' },
  { q: 'Can I use my own AI key?', a: 'Yes. Bring your own AI key on any plan for full control over cost and privacy.' },
  { q: 'Are there any hidden charges?', a: 'No. Zylo follows transparent pricing. You only pay for the plan you choose.' },
  { q: 'Can I run multiple workspaces?', a: 'Yes. Growth gives you 3 workspaces and Business gives you 10.' },
  { q: 'What happens to my agents if I cancel?', a: 'Your data and agents stay yours. You can export everything anytime.' },
  { q: 'Can I upgrade my plan later?', a: 'Yes. Upgrade anytime as your team grows.' },
];
---

<Layout
  title="Pricing — Zylo"
  description="Simple, transparent pricing. Choose the plan that's right for you — no hidden fees, cancel anytime."
>
  <Navbar />
  <main id="main">
    <PricingHero />
    <PricingTable />
    <FAQ faqs={pricingFaqs} title="Frequently Asked Questions" />
  </main>
  <Footer
    ctaTitle="Automate More, Effortlessly with Zylo"
    ctaSubtitle="Start simple. Stay in control. Scale with confidence. 🚀"
  />
</Layout>
