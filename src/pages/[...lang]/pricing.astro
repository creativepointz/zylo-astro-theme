---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const plans = [
  {
    name: 'Starter',
    price: '€89',
    yearly: '€189',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Real-time collaboration',
      'Unlimited projects & tasks',
      'Advanced task automation',
      'Team roles & permission control',
      'AI-Powered task assistant',
    ],
    bestFor: 'personal use, students',
    cta: 'Start for free',
    href: '/register',
    popular: false,
  },
  {
    name: 'Growth',
    price: '€199',
    yearly: '€299',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Gantt charts & timeline view',
      'Time tracking & productivity reports',
      'Kanban, calendar & list views',
      'File sharing & cloud storage',
      'Integrations with popular tools',
    ],
    bestFor: 'freelancers, small businesses',
    cta: 'Choose growth',
    href: '/register',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: '€999',
    yearly: '€1309',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Custom branding & label options',
      'Dedicated account manager',
      'Unlimited team members',
      'Two factor authentication (2FA)',
      '(SLA) Based priority support',
    ],
    bestFor: 'large teams, agencies',
    cta: 'Contact sale',
    href: '/contact',
    popular: false,
  },
];

const comparisonRows = [
  'Access All Features',
  'No Hidden Fees',
  'Flexible Pricing Models',
  'Dedicated Program Manager',
  'Volume Discounts',
  'Volume Discounts',
];

const faqs = [
  {
    q: 'How does an AI resume builder work?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
  {
    q: 'Can the AI customize resumes for different jobs?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
  {
    q: 'Can the AI customize resumes for different jobs?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
  {
    q: 'How do AI chatbots benefit customer support?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
  {
    q: 'Does it have templates for different industries?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
  {
    q: 'Can I test ChatBot for free?',
    a: 'A generative AI chatbot is an advanced type of chatbot that uses artificial intelligence to create dynamic, human-like responses in real time rather than solely on predefined scripts or answers.',
  },
];
---

<Layout title="Transparent plans. Trusted value. — Zylo Pricing" description="Accept payments that will scale and adapt to your business needs.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Pricing header */}
      <Reveal class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Innovation that scales
        </span>
        <h1 class="text-4xl sm:text-6xl font-bold text-slate-900 font-heading tracking-tight mb-6">
          Transparent plans. Trusted value.
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          Accept payments that will scale and adapt to your business needs.
        </p>
      </Reveal>

      {/* 2. Billing & currency band */}
      <Reveal delay={100} class="flex flex-col sm:flex-row items-center justify-between gap-4 p-3 px-6 rounded-full border border-slate-200 bg-white mb-12 shadow-sm max-w-4xl mx-auto">
        <div class="flex items-center gap-4">
          <div class="flex items-center rounded-full bg-slate-100 p-1" id="billing-toggle">
            <button type="button" data-billing="monthly" class="rounded-full bg-brand px-5 py-1.5 text-xs font-semibold text-white shadow-sm">
              Pay monthly
            </button>
            <button type="button" data-billing="yearly" class="rounded-full px-5 py-1.5 text-xs font-semibold text-slate-600 hover:text-slate-900">
              Pay yearly
            </button>
          </div>
          <span class="text-xs font-semibold text-brand">Save up to 15% off</span>
        </div>

        <div class="flex items-center gap-4 text-xs font-bold text-slate-700">
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="radio" name="currency" checked class="text-brand focus:ring-brand" /> USD ($)
          </label>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="radio" name="currency" class="text-brand focus:ring-brand" /> EUR (€)
          </label>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="radio" name="currency" class="text-brand focus:ring-brand" /> GBP (£)
          </label>
        </div>
      </Reveal>

      {/* 3. Tier cards */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24 items-stretch">
        {plans.map((p, idx) => (
          <Reveal delay={idx * 80}>
            <div class={`rounded-3xl border bg-white p-8 shadow-sm transition-all h-full flex flex-col justify-between relative ${p.popular ? 'border-brand ring-2 ring-brand/20 shadow-xl' : 'border-slate-200'}`}>
              {p.popular && (
                <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-brand px-4 py-1 text-xs font-semibold uppercase tracking-wider text-white shadow-md">
                  Popular Choice
                </span>
              )}
              <div>
                <span class="font-bold text-lg text-slate-900 font-heading block mb-2">{p.name}</span>
                <div class="flex items-baseline gap-1 mb-3">
                  <span
                    class="text-4xl font-bold text-slate-900 font-heading js-price"
                    data-monthly={p.price}
                    data-yearly={p.yearly}
                  >{p.price}</span>
                  <span class="text-xs font-medium text-slate-500">{p.period}</span>
                </div>
                <p class="text-slate-500 text-xs leading-relaxed mb-6 font-normal">{p.desc}</p>

                <a
                  href={p.href}
                  class={`w-full inline-flex h-11 items-center justify-center rounded-full text-xs font-semibold tracking-tight transition-colors shadow-sm mb-6 ${p.popular ? 'bg-brand text-white hover:bg-brand-hover' : 'border border-slate-200 text-slate-900 hover:bg-slate-900 hover:text-white'}`}
                >
                  {p.cta}
                </a>

                <ul class="space-y-3 pt-6 border-t border-slate-100">
                  {p.features.map((f) => (
                    <li class="flex items-center gap-2.5 text-xs text-slate-700 font-medium">
                      <Icon name="lucide:check" class="w-4 h-4 text-brand shrink-0" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>

                <p class="mt-6 pt-4 border-t border-slate-100 text-xs text-slate-500 font-medium">
                  <span class="font-semibold text-slate-900">Best for:</span> {p.bestFor}
                </p>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      {/* 4. Comparison table */}
      <Reveal class="mb-20 overflow-x-auto">
        <div class="min-w-[640px] rounded-3xl border border-slate-200 bg-white overflow-hidden">
          <div class="grid grid-cols-12 border-b border-slate-200 bg-slate-50">
            <div class="col-span-6 px-8 py-4"></div>
            {plans.map((p) => (
              <div class="col-span-2 px-4 py-4 text-center text-xs font-bold uppercase tracking-wider text-slate-900">
                {p.name}
              </div>
            ))}
          </div>
          {comparisonRows.map((row) => (
            <div class="grid grid-cols-12 border-b border-slate-100 last:border-b-0">
              <div class="col-span-6 px-8 py-5 text-sm font-semibold text-slate-900">{row}</div>
              {plans.map(() => (
                <div class="col-span-2 px-4 py-5 flex justify-center items-center">
                  <span class="w-5 h-5 rounded-full bg-brand text-white flex items-center justify-center">
                    <Icon name="lucide:check" class="w-3 h-3" />
                  </span>
                </div>
              ))}
            </div>
          ))}
        </div>
      </Reveal>

      {/* 5. Trusted by */}
      <Reveal class="mb-24 text-center">
        <p class="text-lg text-slate-500">
          Trusted by <span class="font-semibold text-slate-900">10,000+</span> businesses worldwide
        </p>
      </Reveal>

      {/* 6. FAQ */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-24">
        <Reveal class="lg:col-span-5">
          <span class="inline-block border border-dashed border-slate-300 px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-5">
            Our faq
          </span>
          <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight mb-3">
            Frequently Asked Questions
          </h2>
          <p class="text-slate-600 leading-relaxed mb-8">
            Connect Analytics with your favourite tools to streamline workflows and keep everything running smoothly.
          </p>
          <a href="/contact" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-slate-900 px-8 text-sm font-semibold text-white hover:bg-brand transition-colors shadow-md">
            Contact us <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </Reveal>

        <div class="lg:col-span-7 space-y-3">
          {faqs.map((f, idx) => (
            <Reveal delay={idx * 60}>
              <details class="group rounded-3xl border border-slate-200 bg-white px-7 py-5 shadow-sm">
                <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
                  <span class="text-base font-semibold text-slate-900 font-heading">{f.q}</span>
                  <span class="shrink-0 w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center text-slate-500 group-open:bg-slate-900 group-open:text-white transition-colors">
                    <Icon name="lucide:plus" class="w-4 h-4 group-open:hidden" />
                    <Icon name="lucide:minus" class="w-4 h-4 hidden group-open:block" />
                  </span>
                </summary>
                <p class="pt-4 text-sm text-slate-600 leading-relaxed">{f.a}</p>
              </details>
            </Reveal>
          ))}
        </div>
      </div>

      {/* 7. Closing CTA */}
      <Reveal class="rounded-3xl bg-slate-900 px-8 py-16 text-center">
        <h2 class="text-3xl sm:text-5xl font-bold text-white font-heading tracking-tight mb-4 leading-tight">
          Start planning smarter and more meaningful user experiences
        </h2>
        <p class="text-slate-300 leading-relaxed max-w-2xl mx-auto mb-10">
          Zylo delivers an exceptional UX design, providing users with a smooth experience through outstanding visual and interactive effects all in one platform.
        </p>
        <form class="flex flex-wrap justify-center gap-3">
          <input
            type="email"
            placeholder="Enter your email.."
            class="h-12 w-full max-w-[300px] rounded-full border border-transparent bg-white px-6 text-sm text-slate-900 focus:border-brand focus:outline-none"
          />
          <button type="submit" class="h-12 inline-flex items-center justify-center rounded-full bg-brand px-8 text-sm font-semibold text-white hover:bg-brand-hover transition-colors">
            Subscribe now
          </button>
        </form>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const toggle = document.getElementById('billing-toggle');
  if (toggle) {
    const buttons = toggle.querySelectorAll<HTMLButtonElement>('button[data-billing]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.billing;
        buttons.forEach((b) => {
          const active = b === btn;
          b.className = active
            ? 'rounded-full bg-brand px-5 py-1.5 text-xs font-semibold text-white shadow-sm'
            : 'rounded-full px-5 py-1.5 text-xs font-semibold text-slate-600 hover:text-slate-900';
        });
        document.querySelectorAll<HTMLElement>('.js-price').forEach((el) => {
          const value = mode === 'yearly' ? el.dataset.yearly : el.dataset.monthly;
          if (value) el.textContent = value;
        });
      });
    });
  }
</script>
