---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const cards = Array.from({ length: 5 }, () => ({
  title: 'Zylo for Desktop',
  subtitle: 'Mack and windows',
  builds: [
    { name: 'macOS', variant: '[ Apple Silicon ]' },
    { name: 'macOS', variant: '[ Intel ]' },
  ],
}));
---

<Layout title="Download App — Get the Zylo App" description="Download the Zylo desktop app for macOS Apple Silicon and Intel.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-surface-soft">
    <div class="container-page max-w-6xl mx-auto px-4">
      {/* 1. Header Banner */}
      <Reveal class="text-center max-w-3xl mx-auto mb-16">
        <div class="w-16 h-16 rounded-full bg-canvas shadow-[var(--shadow-subtle)] border border-hairline flex items-center justify-center mx-auto mb-6">
          <Icon name="lucide:message-circle" class="w-7 h-7 text-brand" />
        </div>
        <h1 class="text-4xl sm:text-6xl font-semibold text-ink font-heading tracking-tight">
          The smart companion powering your conversations
        </h1>
      </Reveal>

      {/* 2. Download cards */}
      <div class="max-w-3xl mx-auto space-y-5">
        {cards.map((c, idx) => (
          <Reveal delay={idx * 60}>
            <div class="rounded-lg border border-hairline bg-canvas px-6 py-6 md:px-10 md:py-8 shadow-[var(--shadow-subtle)] hover:border-brand/40 hover:shadow-[var(--shadow-subtle)] transition-all flex flex-wrap gap-6 items-center justify-between">
              <div>
                <h2 class="text-2xl font-semibold text-ink font-heading mb-1">{c.title}</h2>
                <p class="text-sm text-steel">{c.subtitle}</p>
              </div>
              <div class="flex flex-wrap gap-3">
                {c.builds.map((b) => (
                  <div class="rounded-md border border-hairline bg-surface-soft px-5 py-3 text-center">
                    <div class="text-sm font-semibold text-ink font-heading mb-2">
                      {b.name} <span class="text-stone font-normal">{b.variant}</span>
                    </div>
                    <a
                      href="#"
                      class="inline-flex h-9 items-center justify-center gap-2 rounded-full bg-canvas-dark px-5 text-xs font-semibold text-on-dark hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]"
                    >
                      <span>Downloads</span>
                      <Icon name="lucide:download" class="w-4 h-4" />
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
