---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const perks = [
  {
    icon: 'lucide:zap',
    title: 'Runs in the background',
    desc: 'Your workflows keep running while the app sits quietly in the menu bar.',
  },
  {
    icon: 'lucide:refresh-cw',
    title: 'Automatic updates',
    desc: 'New builds install themselves, so every machine stays on the same version.',
  },
  {
    icon: 'lucide:keyboard',
    title: 'Global shortcut',
    desc: 'Open Zylo from anywhere and hand a task to an agent without switching apps.',
  },
  {
    icon: 'lucide:wifi-off',
    title: 'Works offline',
    desc: 'Drafts and notes stay local and sync back once you are connected again.',
  },
];

const builds = [
  { name: 'macOS', variant: '[ Apple Silicon ]', note: 'For M-series Macs' },
  { name: 'macOS', variant: '[ Intel ]', note: 'For Intel-based Macs' },
];
---

<Layout title="Download App — Get the Zylo App" description="Download the Zylo desktop app for macOS Apple Silicon and Intel.">
  <Navbar />

  <main id="main" class="bg-canvas">
    {/* 1. Compact centered hero */}
    <section class="pt-24 md:pt-[120px] pb-16">
      <div class="container-page">
        <Reveal class="mx-auto max-w-3xl text-center">
          <span class="eyebrow mb-4 block">Downloads</span>
          <h1 class="h1 mb-5">The smart companion powering your workflows</h1>
          <p class="subtitle mx-auto max-w-xl">
            Install the Zylo desktop app and keep your automations, notes and agents one shortcut away.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="#builds" class="btn-primary btn-lg">
              Downloads <Icon name="lucide:download" class="h-4 w-4" />
            </a>
            <a href="/support" class="btn-secondary btn-lg">Installation help</a>
          </div>
        </Reveal>
      </div>
    </section>

    {/* 2. Perk grid */}
    <section class="pb-20">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {perks.map((p, idx) => (
            <Reveal delay={idx * 60}>
              <div class="h-full rounded-lg border border-hairline bg-canvas p-6">
                <span class="icon-tile mb-4">
                  <Icon name={p.icon} class="h-4 w-4" />
                </span>
                <h2 class="h5 mb-2">{p.title}</h2>
                <p class="p-sm">{p.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 3. Build cards */}
    <section id="builds" class="pb-24">
      <div class="container-page">
        <Reveal class="mb-8 max-w-2xl">
          <h2 class="h3 mb-2">Zylo for Desktop</h2>
          <p class="p-rg">macOS and Windows</p>
        </Reveal>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {builds.map((b, idx) => (
            <Reveal delay={idx * 60}>
              <div class="flex h-full flex-wrap items-center justify-between gap-4 rounded-lg border border-hairline bg-canvas p-6">
                <div>
                  <h3 class="h5 mb-1">
                    {b.name} <span class="font-normal text-stone">{b.variant}</span>
                  </h3>
                  <p class="p-sm">{b.note}</p>
                </div>
                <a href="#" class="btn-primary btn-md">
                  <span>Downloads</span>
                  <Icon name="lucide:download" class="h-4 w-4" />
                </a>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </section>

    {/* 4. Closing CTA band */}
    <section class="bg-surface-soft py-16 md:py-20">
      <div class="container-page">
        <Reveal class="mx-auto max-w-2xl text-center">
          <h2 class="h3 mb-4">Prefer to stay in the browser?</h2>
          <p class="p-rg mb-8">
            Every workflow in the desktop app runs the same way on the web. Sign in and pick up where you left off.
          </p>
          <a href="/sign-in" class="btn-primary btn-lg">Open Zylo on the web</a>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
