---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}
---

<Layout title="Affiliate terms & conditions | Zylo" description="Terms and payout guidelines governing Zylo's affiliate referral program.">
  <Navbar />

  <main id="main" class="pt-32 pb-24 bg-slate-50/50">
    <div class="container-page max-w-4xl mx-auto px-4">
      <Reveal class="mb-12 text-center">
        <span class="inline-block border border-slate-200 bg-white px-4 py-1.5 rounded-full text-xs font-semibold text-slate-800 uppercase tracking-wider mb-6 shadow-sm">
          Partner Terms
        </span>
        <h1 class="text-4xl font-bold text-slate-900 font-heading mb-4">Affiliate terms &amp; conditions</h1>
        <p class="text-base text-slate-600 max-w-2xl mx-auto">
          Join Zylo&apos;s Affiliate Program! Please review these terms carefully to understand
          how our program operates and what is required of you.
        </p>
      </Reveal>

      <Reveal delay={100} class="rounded-3xl border border-slate-200 bg-white p-8 md:p-12 shadow-sm space-y-10 text-slate-600 leading-relaxed text-base">
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">Understanding the Process</h2>
          <p>
            As a Zylo affiliate, you become an essential part of our sales team. For every customer
            you refer who makes a purchase, you&apos;ll earn a commission. The more customers you bring
            in, the more you earn with no limits!
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">How Will I Be Notified of a Successful Referral?</h2>
          <p>
            You&apos;ll get notified whenever a customer you referred completes a purchase.
            Plus, you can monitor your sales and commissions in real-time directly
            from your affiliate dashboard.
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">Receiving Your Earning</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Payments are securely handled through PayPal.</li>
            <li>Make sure your PayPal details are up-to-date in your affiliate profile.</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-slate-900 font-heading">How Often Are Payments Made?</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Payments are issued at the end of every month.</li>
            <li>The minimum amount required for a payout is $100.</li>
            <li>All commissions are reviewed and verified before being released.</li>
            <li>For instance, any commissions earned in May will be paid by June 30.</li>
          </ul>
        </section>
      </Reveal>
    </div>
  </main>

  <Footer />
</Layout>
