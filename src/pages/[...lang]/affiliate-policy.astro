---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';

export function getStaticPaths() {
  return generatePaths();
}

// Table of contents derived from the document's own clause headings.
const toc = [
  { id: 'understanding-the-process', title: 'Understanding the Process' },
  { id: 'how-will-i-be-notified-of-a-successful-referral', title: 'How Will I Be Notified of a Successful Referral?' },
  { id: 'receiving-your-earning', title: 'Receiving Your Earning' },
  { id: 'how-often-are-payments-made', title: 'How Often Are Payments Made?' },
];
---

<Layout title="Affiliate terms & conditions | Zylo" description="Terms and payout guidelines governing Zylo's affiliate referral program.">
  <Navbar />

  <main id="main" class="bg-canvas pt-24 md:pt-[120px]">
    {/* Compact hero */}
    <section class="border-b border-hairline-soft pb-10">
      <div class="container-page">
        <Reveal class="max-w-[720px]">
          <p class="eyebrow mb-4">Partner Terms</p>
          <h1 class="h1 mb-4">Affiliate terms &amp; conditions</h1>
          <p class="p-lt">
            Join Zylo&apos;s Affiliate Program! Please review these terms carefully to understand
            how our program operates and what is required of you.
          </p>
        </Reveal>
      </div>
    </section>

    {/* 2-column legal document body */}
    <section class="py-12 md:py-16">
      <div class="container-page">
        <div class="flex gap-12">
          <aside class="hidden w-[240px] shrink-0 lg:block">
            <nav class="sticky top-28 flex flex-col gap-2" aria-label="On this page">
              <p class="eyebrow mb-2">On this page</p>
              {toc.map((item) => (
                <a href={`#${item.id}`} data-toc-link class="p-sm text-steel hover:text-ink">{item.title}</a>
              ))}
            </nav>
          </aside>

          <div class="w-full max-w-[720px]">
            <section id="understanding-the-process" class="scroll-mt-28 border-b border-hairline-soft pb-12">
              <h2 class="h3 mb-5">Understanding the Process</h2>
              <p class="p-rg">
                As a Zylo affiliate, you become an essential part of our sales team. For every customer
                you refer who makes a purchase, you&apos;ll earn a commission. The more customers you bring
                in, the more you earn with no limits!
              </p>
            </section>

            <section id="how-will-i-be-notified-of-a-successful-referral" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">How Will I Be Notified of a Successful Referral?</h2>
              <p class="p-rg">
                You&apos;ll get notified whenever a customer you referred completes a purchase.
                Plus, you can monitor your sales and commissions in real-time directly
                from your affiliate dashboard.
              </p>
            </section>

            <section id="receiving-your-earning" class="scroll-mt-28 border-b border-hairline-soft py-12">
              <h2 class="h3 mb-5">Receiving Your Earning</h2>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Payments are securely handled through PayPal.</li>
                <li class="p-rg">Make sure your PayPal details are up-to-date in your affiliate profile.</li>
              </ul>
            </section>

            <section id="how-often-are-payments-made" class="scroll-mt-28 pt-12">
              <h2 class="h3 mb-5">How Often Are Payments Made?</h2>
              <ul class="list-disc space-y-2 pl-5 text-steel">
                <li class="p-rg">Payments are issued at the end of every month.</li>
                <li class="p-rg">The minimum amount required for a payout is $100.</li>
                <li class="p-rg">All commissions are reviewed and verified before being released.</li>
                <li class="p-rg">For instance, any commissions earned in May will be paid by June 30.</li>
              </ul>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const setActive = (id: string) => {
      links.forEach((l) => {
        const on = l.getAttribute('href') === `#${id}`;
        l.classList.toggle('text-ink', on);
        l.classList.toggle('text-steel', !on);
      });
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        });
      },
      { rootMargin: '-120px 0px -70% 0px' }
    );
    links.forEach((l) => {
      const target = document.querySelector(l.getAttribute('href') || '');
      if (target) observer.observe(target);
    });
  }
</script>
