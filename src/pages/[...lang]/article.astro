---
import Layout from '@/layouts/Base.astro';
import Navbar from '@/components/global/header/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import Reveal from '@/components/widgets/Reveal.astro';
import { generatePaths } from '@/lib/utils/i18nUtils';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return generatePaths();
}

const shareLinks = [
  { label: 'Facebook', icon: 'lucide:facebook' },
  { label: 'X', icon: 'lucide:twitter' },
  { label: 'LinkedIn', icon: 'lucide:linkedin' },
  { label: 'Vimeo', icon: 'lucide:video' },
];

const selectorList = [
  'Type selector (e.g p, span, etc.)',
  'Class selector (e.g .element, .sidebar, etc.)',
  'ID selector (e.g #header)',
];

const tags = ['Blog', 'Creative', 'Portfolio', 'Theme', 'WordPress'];

const comments = [
  {
    author: 'By James Taylor',
    date: 'January 2, 2024',
    body: "I love this theme. Sometimes it's difficult to work with some themes, because even if they are created with Elementor, you can't edit all the things with Elementor.",
  },
  {
    author: 'By Oliver Williams',
    date: 'January 2, 2024',
    body: 'They have really taken their time to work on the appearance of the theme, also, they have a very interactive client assistance service, I like it!',
  },
];

// Table of contents derived from the headings rendered on this page
const toc = [
  { label: 'Using a Query', id: 'using-a-query', active: true },
  { label: 'On the specificity of selectors', id: 'specificity-of-selectors' },
  { label: 'About Author', id: 'about-author' },
  { label: 'Next Post', id: 'next-post' },
  { label: 'Comments(02)', id: 'comments' },
  { label: 'Leave a Reply', id: 'leave-a-reply' },
];
---

<Layout title="Control your online banking while earning rewards — Zylo Blog" description="Resources article from Zylo on online banking, rewards, and modern product engineering.">
  <Navbar />

  <main id="main" class="pt-24 md:pt-[120px] pb-24 bg-canvas">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-[240px_minmax(0,1fr)] xl:grid-cols-[240px_minmax(0,1fr)_200px] xl:gap-16">
        {/* Left rail: author, meta, share, tags */}
        <aside class="hidden lg:block">
          <div class="sticky top-28 flex max-h-[calc(100vh-8rem)] flex-col gap-8 overflow-y-auto pb-8">
            <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-steel transition-colors hover:text-ink">
              <Icon name="lucide:arrow-left" class="h-4 w-4" /> Back to blog
            </a>

            <div class="flex flex-col gap-3 border-b border-hairline-soft pb-6">
              <span class="eyebrow">Resources</span>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-on-primary font-semibold">
                  R
                </div>
                <div>
                  <p class="text-sm font-medium text-ink">Richard</p>
                  <p class="p-lt">Community Organiser</p>
                </div>
              </div>
            </div>

            <div class="flex flex-col gap-3 border-b border-hairline-soft pb-6">
              <span class="eyebrow">Share</span>
              <div class="flex items-center gap-1.5">
                {shareLinks.map((s) => (
                  <a
                    href="#"
                    aria-label={s.label}
                    class="flex h-8 w-8 items-center justify-center rounded-sm border border-hairline bg-canvas text-steel transition-colors hover:bg-surface hover:text-ink"
                  >
                    <Icon name={s.icon} class="h-4 w-4" />
                  </a>
                ))}
              </div>
            </div>

            <div class="flex flex-col gap-3">
              <span class="eyebrow">Tagged with:</span>
              <div class="flex flex-wrap gap-1.5">
                {tags.map((t) => (
                  <a
                    href="#"
                    class="rounded-sm bg-brand-tag/15 px-2 py-0.5 text-[13px] font-semibold text-brand-tag"
                  >
                    {t}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </aside>

        {/* Center: prose column */}
        <article class="w-full max-w-[720px]">
          <Reveal class="mb-10 border-b border-hairline pb-8">
            <a href="/blog" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-steel transition-colors hover:text-ink lg:hidden">
              <Icon name="lucide:arrow-left" class="h-4 w-4" /> Back to blog
            </a>
            <span class="eyebrow mb-4 block">Resources</span>
            <h1 class="h1">Control your online banking while earning rewards.</h1>
          </Reveal>

          <Reveal delay={80}>
            <img
              src="/placeholder.png"
              alt="Control your online banking while earning rewards."
              loading="lazy"
              class="mb-10 aspect-[16/9] w-full rounded-lg border border-hairline-soft bg-surface object-contain p-4"
            />
          </Reveal>

          {/* Mobile author + share */}
          <div class="mb-10 flex flex-wrap items-center justify-between gap-6 border-b border-hairline pb-8 lg:hidden">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-on-primary font-semibold">
                R
              </div>
              <div>
                <p class="text-sm font-medium text-ink">Richard</p>
                <p class="p-lt">Community Organiser</p>
              </div>
            </div>
            <div class="flex items-center gap-1.5">
              {shareLinks.map((s) => (
                <a
                  href="#"
                  aria-label={s.label}
                  class="flex h-8 w-8 items-center justify-center rounded-sm border border-hairline bg-canvas text-steel transition-colors hover:bg-surface hover:text-ink"
                >
                  <Icon name={s.icon} class="h-4 w-4" />
                </a>
              ))}
            </div>
          </div>

          {/* Article body */}
          <Reveal delay={120} class="flex flex-col gap-6">
            <p class="p-rg">
              We love to bring designs to life as a developer, and I aim to do this using whatever front end tools
              are necessary. My preferred tools are more modern javascript libraries like React.js but I like to use
              whatever is best for the websites needs. There are several reasons why a business would consider
              a rebrand and it doesn&rsquo;t necessarily mean the business has been unsuccessful.
            </p>
            <p class="p-rg">
              But in order that you may see whence all this born error of those who accuse pleasure and praise
              pain, I will open the whole matter, and explain the very things which were said by that discoverer of
              truth and, as it were, the architect of a happy life.
            </p>

            <section id="using-a-query" class="mt-8 flex scroll-mt-28 flex-col gap-6 border-t border-hairline-soft pt-8">
              <h2 class="h3">Using a Query</h2>
              <p class="p-rg">
                We love to bring designs to life as a developer, and I aim to do this using whatever front end tools are
                necessary. My preferred tools are more modern javascript libraries like React.js but I like to use
                whatever is best for the websites needs. There are several reasons why a business would consider a
                rebrand and it doesn&rsquo;t necessarily mean the business has been unsuccessful.
              </p>
              <p class="p-rg">
                Vestibulum ante ipsum primis in faucibus enim. In aliquam tempus porta. Mauris vel finibus risus.
                Maecenas egestas mi sed neque finibus, nec faucibus ipsum aliquet. Duis scelerisque at odio vel
                tempus. Morbi a tincidunt nunc, id rutrum erat. Fusce egestas quam vel facilisis tempor. Morbi non
                orci elementum, sollicitudin mauris laoreet, luctus est. Donec in mi lorem.
              </p>

              <figure class="flex items-start gap-6">
                <Icon name="lucide:quote" class="h-8 w-8 flex-none text-brand" />
                <div class="flex flex-col gap-3">
                  <blockquote class="h3">
                    &ldquo;Success is the result of perfection, hard work, learning from failure, loyalty, &amp;
                    persistence&rdquo;
                  </blockquote>
                  <figcaption class="p-sm font-medium text-stone">Phil Martinez</figcaption>
                </div>
              </figure>

              <p class="p-rg">
                Vestibulum ante ipsum primis in faucibus enim. In aliquam tempus porta. Mauris vel finibus risus.
                Maecenas egestas mi sed neque finibus, nec faucibus ipsum aliquet. Duis scelerisque at odio vel
                tempus. Morbi a tincidunt nunc, id rutrum erat. Fusce egestas quam vel facilisis tempor. Morbi non
                orci elementum, sollicitudin mauris laoreet, luctus est. Donec in mi lorem.
              </p>
            </section>

            <section id="specificity-of-selectors" class="mt-8 flex scroll-mt-28 flex-col gap-6 border-t border-hairline-soft pt-8">
              <h2 class="h3">On the specificity of selectors</h2>
              <p class="p-rg">
                The specificity of the : <code class="rounded-xs border border-hairline bg-surface px-1.5 font-mono text-[13px] font-medium text-charcoal">not()</code> pseudo-class is the
                specificity of its argument. The :not() pseudo-class does not add to the selector specificity, unlike
                other pseudo-classes.
              </p>
              <p class="p-rg">
                The <code class="rounded-xs border border-hairline bg-surface px-1.5 font-mono text-[13px] font-medium text-charcoal">simple selector</code> that:
                <code class="rounded-xs border border-hairline bg-surface px-1.5 font-mono text-[13px] font-medium text-charcoal">not()</code> takes as an argument can be any of the following:
              </p>
              <ul class="flex flex-col gap-2.5">
                {selectorList.map((item) => (
                  <li class="flex items-start gap-2">
                    <Icon name="lucide:check" class="mt-1 h-4 w-4 flex-none text-brand" />
                    <span class="p-rg">{item}</span>
                  </li>
                ))}
                <li class="flex items-start gap-2">
                  <Icon name="lucide:check" class="mt-1 h-4 w-4 flex-none text-brand" />
                  <span class="p-rg">
                    Pseudo-class selector e.g: <code class="rounded-xs border border-hairline bg-surface px-1.5 font-mono text-[13px] font-medium text-charcoal">first-child, :last-of-type</code>
                  </span>
                </li>
              </ul>

              {/* Code block */}
              <div class="overflow-hidden rounded-md bg-surface-code">
                <div class="flex items-center justify-between border-b border-hairline-dark px-4 py-2">
                  <span class="font-mono text-[13px] text-on-dark-muted">css</span>
                  <button
                    type="button"
                    class="inline-flex items-center gap-1.5 rounded-sm border border-hairline-dark px-2 py-1 text-[13px] text-on-dark-muted transition-colors hover:text-on-dark"
                  >
                    <Icon name="lucide:copy" class="h-3.5 w-3.5" /> Copy
                  </button>
                </div>
                <pre class="overflow-x-auto p-4 font-mono text-sm leading-[1.5] text-on-dark"><code>{'li:not(.old)::after {\n    content: "New!";\n    color: deepPink;\n}'}</code></pre>
              </div>

              <p class="p-rg">
                The specificity of the : <code class="rounded-xs border border-hairline bg-surface px-1.5 font-mono text-[13px] font-medium text-charcoal">not()</code> pseudo-class is the
                specificity of its argument. The :not() pseudo-class does not add to the selector specificity, unlike
                other pseudo-classes.
              </p>
            </section>
          </Reveal>

          {/* Tags — mobile */}
          <div class="mt-10 flex flex-wrap items-center gap-2 lg:hidden">
            <span class="p-sm font-medium text-ink">Tagged with:</span>
            {tags.map((t) => (
              <a href="#" class="rounded-sm bg-brand-tag/15 px-2 py-0.5 text-[13px] font-semibold text-brand-tag">
                {t}
              </a>
            ))}
          </div>

          {/* About Author */}
          <Reveal delay={160} id="about-author" class="mt-12 scroll-mt-28">
            <div class="flex flex-col items-center gap-6 rounded-lg bg-canvas-dark p-8 text-center sm:flex-row sm:items-start sm:text-left">
              <div class="flex h-16 w-16 flex-none items-center justify-center rounded-full bg-surface-code text-on-dark font-semibold">
                PB
              </div>
              <div class="flex flex-col gap-3">
                <div>
                  <span class="eyebrow text-on-dark-muted">About Author</span>
                  <h3 class="h5 mt-1 text-on-dark">Peter Bowman</h3>
                </div>
                <p class="p-rg text-on-dark-muted">
                  Phasellus et ipsum justo. Aenean fringilla a fermentum mauris non venenatis. Praesent at nulla
                  aliquam ligula.
                </p>
                <div class="mt-1 flex items-center justify-center gap-4 text-on-dark-muted sm:justify-start">
                  {shareLinks.map((s) => (
                    <a href="#" aria-label={s.label} class="transition-colors hover:text-on-dark">
                      <Icon name={s.icon} class="h-4 w-4" />
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </Reveal>

          {/* Next Post */}
          <Reveal delay={180} id="next-post" class="mt-12 scroll-mt-28">
            <a
              href="/article"
              class="group block rounded-lg border border-hairline bg-canvas p-6 transition-colors hover:bg-surface-soft"
            >
              <span class="eyebrow mb-2 inline-flex items-center gap-2">
                Next Post <Icon name="lucide:arrow-right" class="h-4 w-4" />
              </span>
              <h3 class="h4">Tips for thriving in our virtual world</h3>
            </a>
          </Reveal>

          {/* Comments */}
          <Reveal delay={200} id="comments" class="mt-12 scroll-mt-28 border-t border-hairline-soft pt-10">
            <h3 class="h4 mb-6">Comments(02)</h3>
            <div class="flex flex-col gap-4">
              {comments.map((c) => (
                <div class="card">
                  <div class="mb-2 flex flex-wrap items-center gap-3">
                    <h4 class="h6">{c.author}</h4>
                    <span class="p-lt">{c.date}</span>
                  </div>
                  <p class="p-rg mb-4">{c.body}</p>
                  <a href="#" class="inline-flex items-center gap-2 text-sm font-medium text-ink transition-colors hover:text-brand">
                    Reply <Icon name="lucide:corner-down-left" class="h-4 w-4" />
                  </a>
                </div>
              ))}
            </div>
          </Reveal>

          {/* Leave a Reply */}
          <Reveal delay={220} id="leave-a-reply" class="mt-12 scroll-mt-28 border-t border-hairline-soft pt-10">
            <div class="mb-8">
              <h2 class="h3 mb-2">Leave a Reply</h2>
              <p class="p-sm">Your email address will not be published. Required fields are marked *</p>
            </div>

            <form class="flex flex-col gap-6">
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="flex flex-col gap-2">
                  <label for="name" class="text-sm font-medium text-ink">Name *</label>
                  <input
                    type="text"
                    id="name"
                    required
                    class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink transition-colors focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                  />
                </div>
                <div class="flex flex-col gap-2">
                  <label for="email" class="text-sm font-medium text-ink">Email*</label>
                  <input
                    type="email"
                    id="email"
                    required
                    class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink transition-colors focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                  />
                </div>
              </div>

              <div class="flex flex-col gap-2">
                <label for="website" class="text-sm font-medium text-ink">Website</label>
                <input
                  type="url"
                  id="website"
                  class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink transition-colors focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label for="comment" class="text-sm font-medium text-ink">Comment *</label>
                <textarea
                  id="comment"
                  rows="6"
                  required
                  class="w-full resize-none rounded-md border border-hairline bg-canvas px-3 py-2.5 text-sm text-ink transition-colors focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input id="checkbox" type="checkbox" class="mt-0.5 h-4 w-4 rounded-xs border-hairline text-brand focus:ring-brand" />
                <label for="checkbox" class="p-sm cursor-pointer">
                  Save my name, email, and website in this browser for the next time I comment.
                </label>
              </div>

              <div class="pt-2">
                <button type="submit" class="btn-primary btn-md">
                  Post comment <Icon name="lucide:send" class="h-4 w-4" />
                </button>
              </div>
            </form>
          </Reveal>
        </article>

        {/* Right rail: table of contents */}
        <aside class="hidden xl:block">
          <nav class="sticky top-28 flex max-h-[calc(100vh-8rem)] flex-col gap-3 overflow-y-auto pb-8">
            <span class="eyebrow">On this page</span>
            <ul class="flex flex-col">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class={`p-sm block py-1 transition-colors hover:text-ink ${
                      item.active ? 'font-medium text-ink' : ''
                    }`}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
