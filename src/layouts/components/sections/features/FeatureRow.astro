---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

export interface Props {
  eyebrow: string;
  heading: string;
  description: string;
  points: string[];
  placeholderImage: string;
  bgColor?: string;
  reverse?: boolean;
}

const { eyebrow, heading, description, points, placeholderImage, bgColor = '#f1f5f9', reverse = false } = Astro.props;
---

<section class="bg-white rounded-[32px] border border-[#e2e8f0] p-10 overflow-hidden flex flex-col items-start w-full max-w-[1200px] mx-auto">
  <div class={`flex flex-col lg:flex-row items-center gap-10 lg:gap-[40px] w-full ${reverse ? 'lg:flex-row-reverse' : ''}`}>
    
    <!-- Content -->
    <Reveal class="flex-1 w-full text-left">
      <span class="inline-flex items-center justify-center bg-[#4f46e5] text-white px-4 py-2 rounded-[20px] text-[14px] font-light mb-6 tracking-tight">{eyebrow}</span>
      <h2 class="text-4xl lg:text-[44px] font-bold text-[#0f172b] leading-[1.25] mb-6 font-heading tracking-tight">
        {heading}
      </h2>
      <p class="text-lg text-slate-600 mb-10 leading-relaxed max-w-lg">
        {description}
      </p>
      
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
        {points.map((point, idx) => (
          <Reveal delay={150 + (idx * 50)}>
            <li class="flex items-start gap-3 text-[14px] font-light text-slate-600">
              <Icon name="lucide:circle-check" class="w-5 h-5 shrink-0 text-[#4f46e5]" stroke-width="2" aria-hidden="true" />
              <span class="leading-snug">{point}</span>
            </li>
          </Reveal>
        ))}
      </ul>
    </Reveal>

    <!-- Image -->
    <Reveal delay={100} class="flex-1 w-full flex justify-center lg:max-w-[458px]">
      <div class="w-full h-[458px] rounded-[20px] overflow-hidden relative group" style={`background-color: ${bgColor}`}>
        <img 
          src={placeholderImage} 
          alt={heading} 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
        />
      </div>
    </Reveal>

  </div>
</section>
