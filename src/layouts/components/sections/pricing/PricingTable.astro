---
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Free',
    description: 'Perfect for getting started.',
    monthlyPrice: 0,
    annualPrice: 0,
    buttonText: 'Start Free',
    buttonClass: 'btn-secondary',
    highlight: false,
    popular: false,
  },
  {
    name: 'Hobby',
    description: 'Great for personal projects.',
    monthlyPrice: 19,
    annualPrice: 190,
    buttonText: 'Start Hobby',
    buttonClass: 'btn-secondary hover:bg-surface hover:text-ink',
    highlight: false,
    popular: false,
  },
  {
    name: 'Growth',
    description: 'For growing modern teams.',
    monthlyPrice: 49,
    annualPrice: 490,
    buttonText: 'Start Growth',
    buttonClass: 'btn-primary',
    highlight: true,
    popular: true,
  },
  {
    name: 'Business',
    description: 'Advanced features for scaling.',
    monthlyPrice: 99,
    annualPrice: 990,
    buttonText: 'Start Business',
    buttonClass: 'btn-secondary hover:bg-surface hover:text-ink',
    highlight: false,
    popular: false,
  },
];

const usageFeatures = [
  { name: 'workspaces', values: ['1', '1', '3', '10'] },
  { name: 'Agents per workspace', values: ['1', '3', 'Unlimited', 'Unlimited'] },
  { name: 'Agent runs / month', values: ['100', '1,000', 'Unlimited', 'Unlimited'] },
  { name: 'Team members', values: ['1', '2', '5', '15'] },
  { name: 'AI model calls / month', values: ['500', '5,000', 'Unlimited', 'Unlimited'] },
];

const featureCategories = [
  {
    name: 'Builder & Runtime',
    features: [
      { name: 'Visual agent builder', values: [true, true, true, true] },
      { name: 'Multi-step workflows', values: [true, true, true, true] },
      { name: 'Live test runs', values: [true, true, true, true] },
      { name: 'Scheduling & triggers', values: [true, true, true, true] },
      { name: 'Webhooks', values: [true, true, true, true] },
      { name: 'Run logs & history', values: [true, true, true, true] },
      { name: 'Retries & error handling', values: [true, true, true, true] },
      { name: 'Version control for agents', values: [true, true, true, true] },
      { name: 'Human approvals', values: [false, true, true, true] },
      { name: 'Custom guardrails', values: [false, true, true, true] },
      { name: 'Remove Zylo badge', values: [false, 'Optional', true, true] },
    ]
  },
  {
    name: 'AI Models',
    features: [
      { name: 'GPT models', values: [true, true, true, true] },
      { name: 'Claude models', values: [true, true, true, true] },
      { name: 'Open models', values: [true, true, true, true] },
      { name: 'Model routing', values: [false, true, true, true] },
      { name: 'Bring your own AI key', values: [true, true, true, true] },
    ]
  },
  {
    name: 'Team & Governance',
    features: [
      { name: 'Team collaboration', values: [true, true, true, true] },
      { name: 'Roles & permissions', values: [false, true, true, true] },
      { name: 'Audit logs', values: [false, false, true, true] },
      { name: 'SSO / SAML', values: [false, false, false, true] },
    ]
  },
  {
    name: 'Integrations & Analytics',
    features: [
      { name: 'GitHub sync', values: [false, true, true, true] },
      { name: 'Slack, email & CRM connectors', values: [false, true, true, true] },
      { name: 'Usage analytics', values: [false, false, true, true] },
      { name: 'Cost analytics', values: [false, false, true, true] },
      { name: 'API access', values: [false, false, false, true] },
    ]
  },
  {
    name: 'Support',
    features: [
      { name: 'In-app onboarding & docs', values: [true, true, true, true] },
      { name: 'Community support', values: [true, true, true, true] },
      { name: 'Priority support', values: [false, false, true, true] },
    ]
  }
];
---

<section id="plans" class="scroll-mt-28 pb-24">
  <div class="container-page">

    <!-- Billing Toggle -->
    <div class="flex justify-center mb-16">
      <div class="inline-flex items-center gap-3 rounded-full bg-canvas p-1.5 border border-hairline">
        <button id="toggle-monthly" class="rounded-full px-6 py-2.5 text-sm font-semibold transition-all duration-200 bg-primary text-on-primary shadow-[var(--shadow-subtle)] ring-1 ring-brand">Monthly</button>
        <button id="toggle-annual" class="rounded-full px-6 py-2.5 text-sm font-medium transition-all duration-200 text-steel hover:text-ink">
          Annually
        </button>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-0 mb-16 items-stretch">
      {plans.map((plan, i) => (
        <div
          class={`relative flex flex-col rounded-md border bg-canvas p-8 transition-colors duration-300 ${i > 0 ? '-mt-px lg:mt-0 lg:-ml-px' : ''} ${plan.highlight ? 'border-brand z-10' : 'border-hairline'}`}
          style={plan.highlight ? 'background: radial-gradient(46.71% 46.71% at 50% 100%, rgba(79, 70, 229, 0.20) 0%, rgba(255, 202, 205, 0.20) 42.23%, rgba(255, 255, 255, 0.20) 100%), #FFF;' : undefined}
        >
          <div class="mb-6 relative">
            <h3 class="h5 inline-block relative">
              {plan.name}
              {plan.popular && (
                <span
                  class="absolute left-full top-0 rounded-full bg-[#ffe8ef] px-3 py-1 text-[12px] font-normal uppercase tracking-[0.6px] text-[#4c0017] whitespace-nowrap"
                  style="transform: rotate(-30deg); transform-origin: center;"
                >
                  Popular
                </span>
              )}
            </h3>
            <p class="mt-2 text-sm text-stone">{plan.description}</p>
          </div>

          <div class="mb-6 flex items-end">
            <span class="font-heading text-5xl font-semibold leading-none tracking-tight text-brand">$</span>
            <span class="font-heading text-5xl font-semibold leading-none tracking-tight text-brand" data-price-monthly={plan.monthlyPrice} data-price-annual={plan.annualPrice}>{plan.monthlyPrice}</span>
            <span class="ml-1 mb-0.5 text-sm font-normal text-ink" data-price-period>/mo</span>
          </div>

          <ul class="mb-8 flex flex-1 flex-col border-b border-black/[0.08]">
            {usageFeatures.map((feature) => (
              <li class="flex items-center gap-2 border-t border-black/[0.08] py-[9px]">
                <Icon name="lucide:circle-check" class="h-5 w-5 text-brand shrink-0" />
                <span class="text-sm font-normal text-ink">
                  {feature.values[i]} {feature.name}
                </span>
              </li>
            ))}
          </ul>

          <a href="#" class={`btn btn-lg w-full ${plan.highlight ? 'btn-primary' : 'btn-secondary'}`}>
            {plan.buttonText}
          </a>
        </div>
      ))}
    </div>

    <!-- Detailed Feature Table -->
    <div class="hidden lg:block pb-8">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr>
            <th class="w-1/3 p-4 border-b border-hairline sticky top-24 bg-canvas/95 backdrop-blur-sm z-40"></th>
            {plans.map((plan) => (
              <th class="w-1/6 p-4 border-b border-hairline sticky top-24 bg-canvas/95 backdrop-blur-sm z-40 text-center">
                <div class="h5 mb-1">{plan.name}</div>
                <div class="text-sm text-stone font-medium">
                   $<span data-table-price-monthly={plan.monthlyPrice} data-table-price-annual={plan.annualPrice}>{plan.monthlyPrice}</span><span data-table-price-period>/mo</span>
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {featureCategories.map((category) => (
            <>
              <tr>
                <th colspan="5" class="bg-[#f9f7ff] py-4 px-4 h6 text-brand border-b border-hairline">
                  {category.name}
                </th>
              </tr>
              {category.features.map((feature) => (
                <tr class="group hover:bg-surface-soft transition-colors">
                  <td class="py-4 px-4 text-sm font-medium text-steel border-b border-hairline-soft group-hover:text-ink transition-colors">
                    {feature.name}
                  </td>
                  {feature.values.map((val) => (
                    <td class="py-4 px-4 text-center border-b border-hairline-soft">
                      {val === true ? (
                        <Icon name="lucide:circle-check" class="h-5 w-5 text-brand mx-auto" />
                      ) : val === false ? (
                        <span class="text-on-dark-muted">&mdash;</span>
                      ) : (
                        <span class="text-sm font-medium text-steel">{val}</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
      <div class="mt-8 flex flex-col gap-2 text-center text-sm text-stone bg-surface/50 py-4 px-6 rounded-md border border-brand/10">
        <p>
          <span class="font-medium text-steel">A run</span> is one full execution of an agent, start to finish.
          <span class="font-medium text-steel">An AI model call</span> is a single request to an AI model within a run.
        </p>
        <p>
          <Icon name="lucide:info" class="inline-block h-4 w-4 mr-1 -mt-0.5 text-brand" /> More connectors ship every month. Annual plans include 2 months free.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const btnMonthly = document.getElementById('toggle-monthly');
  const btnAnnual = document.getElementById('toggle-annual');
  const prices = document.querySelectorAll('[data-price-monthly]');
  const periods = document.querySelectorAll('[data-price-period]');
  const tablePrices = document.querySelectorAll('[data-table-price-monthly]');
  const tablePeriods = document.querySelectorAll('[data-table-price-period]');

  let isAnnual = false;

  function updatePricing() {
    // Update main cards
    prices.forEach((el) => {
      const price = isAnnual ? el.getAttribute('data-price-annual') : el.getAttribute('data-price-monthly');
      el.textContent = price;
    });
    periods.forEach((el) => {
      el.textContent = isAnnual ? '/yr' : '/mo';
    });
    
    // Update table headers
    tablePrices.forEach((el) => {
      const price = isAnnual ? el.getAttribute('data-table-price-annual') : el.getAttribute('data-table-price-monthly');
      el.textContent = price;
    });
    tablePeriods.forEach((el) => {
      el.textContent = isAnnual ? '/yr' : '/mo';
    });

    if (!btnMonthly || !btnAnnual) return;

    if (isAnnual) {
      btnAnnual.classList.add('bg-primary', 'text-on-primary', 'shadow-[var(--shadow-subtle)]', 'ring-1', 'ring-primary', 'font-semibold');
      btnAnnual.classList.remove('text-steel', 'hover:text-ink', 'font-medium');
      btnMonthly.classList.remove('bg-primary', 'text-on-primary', 'shadow-[var(--shadow-subtle)]', 'ring-1', 'ring-primary', 'font-semibold');
      btnMonthly.classList.add('text-steel', 'hover:text-ink', 'font-medium');
    } else {
      btnMonthly.classList.add('bg-primary', 'text-on-primary', 'shadow-[var(--shadow-subtle)]', 'ring-1', 'ring-primary', 'font-semibold');
      btnMonthly.classList.remove('text-steel', 'hover:text-ink', 'font-medium');
      btnAnnual.classList.remove('bg-primary', 'text-on-primary', 'shadow-[var(--shadow-subtle)]', 'ring-1', 'ring-primary', 'font-semibold');
      btnAnnual.classList.add('text-steel', 'hover:text-ink', 'font-medium');
    }
  }

  if (btnMonthly && btnAnnual) {
    btnMonthly.addEventListener('click', () => {
      isAnnual = false;
      updatePricing();
    });
    btnAnnual.addEventListener('click', () => {
      isAnnual = true;
      updatePricing();
    });
  }
</script>
