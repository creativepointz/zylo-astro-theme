---
import { Icon } from 'astro-icon/components';
---

<section
  class="relative overflow-hidden pt-24 pb-8 text-center flex flex-col"
  style="background: radial-gradient(46.71% 46.71% at 50% 0%, rgba(79, 70, 229, 0.20) 0%, rgba(255, 202, 205, 0.20) 42.23%, rgba(255, 255, 255, 0.20) 100%), #FFF;"
>
  <div class="container-page relative z-10 pt-20 md:pt-24" data-reveal>
    <h1 class="h1 text-slate-900 leading-tight mb-6 max-w-4xl mx-auto">
      Simple, Transparent Pricing
    </h1>
    <p class="p-xl mx-auto mt-6 mb-8 max-w-3xl">
      Choose the plan that's right for you. No hidden fees. Cancel anytime. <br class="hidden md:block"/>
      Save 2 months with annual billing.
    </p>
    <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="#plans" class="btn-primary btn-lg">
        Start Free <Icon name="lucide:arrow-right" class="h-[18px] w-[18px]" />
      </a>
      <a href="/contact" class="btn-secondary btn-lg">
        Talk to sales
      </a>
    </div>
  </div>
</section>
