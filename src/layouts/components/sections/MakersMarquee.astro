---
// Generic placeholder "trusted by" wordmarks. Swap these for your own
// customer/partner logos (SVG or PNG) when you use this theme —
// see README.md for guidance.
const makers = [
  'Northwind',
  'Lumen Labs',
  'Vertex',
  'Solace',
  'Meridian',
  'Halo Systems',
  'Crestline',
  'Zenith',
  'Orbital',
  'Nimbus',
];
const loop = [...makers, ...makers, ...makers];
---

<section id="makers-marquee" class="bg-white border-b border-slate-100 py-8 overflow-hidden">
  <div class="container-page">
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 text-center mb-6">
      Trusted by teams at
    </p>
    <div class="relative w-full overflow-hidden flex items-center">
      {/* Left fade */}
      <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-24 bg-gradient-to-r from-white to-transparent"></div>
      {/* Right fade */}
      <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-24 bg-gradient-to-l from-white to-transparent"></div>

      <div class="flex gap-16 items-center whitespace-nowrap animate-marquee">
        {loop.map((name) => (
          <span
            class="font-heading text-lg md:text-xl font-semibold text-slate-400 opacity-70 transition-opacity duration-300 hover:opacity-100 hover:text-slate-900 cursor-default select-none"
          >
            {name}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
