---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

{/* logo-wall — DESIGN.md §Signature Components: transparent cells, steel wordmarks on canvas */}
<section class="overflow-hidden border-b border-hairline bg-canvas py-16 md:py-24">
  <div class="container-page">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8 items-center">
      {/* Left Column: Heading and CTA */}
      <div class="lg:col-span-4 flex flex-col justify-between h-full py-2">
        <Reveal>
          <h2 class="text-2xl md:text-3xl font-normal text-charcoal leading-snug tracking-tight mb-8">
            Join <span class="font-semibold text-ink">20,000+</span> of the world's most ambitious companies building for agents.
          </h2>
          <a
            href="/customer"
            class="btn-primary btn-md inline-flex items-center gap-2 rounded-full w-fit"
          >
            Read customer stories <Icon name="lucide:chevron-right" class="h-4 w-4" />
          </a>
        </Reveal>
      </div>

      {/* Right Column: Grid of 8 Logo Cards */}
      <div class="lg:col-span-8">
        <Reveal delay={100}>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {/* Microsoft Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-6" viewBox="0 0 120 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="0" y="3" width="10" height="10" fill="#F25022"/>
                <rect x="11" y="3" width="10" height="10" fill="#7FBA00"/>
                <rect x="0" y="14" width="10" height="10" fill="#00A4EF"/>
                <rect x="11" y="14" width="10" height="10" fill="#FFB900"/>
                <text x="28" y="21" font-family="system-ui, -apple-system, sans-serif" font-weight="600" font-size="16px" fill="#737373" letter-spacing="-0.02em">Microsoft</text>
              </svg>
            </div>

            {/* Anthropic Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-5" viewBox="0 0 140 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <text x="0" y="21" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="17px" fill="#191919" letter-spacing="0.08em">ANTHROP\C</text>
              </svg>
            </div>

            {/* Amazon Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-6" viewBox="0 0 80 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <text x="0" y="18" font-family="system-ui, -apple-system, sans-serif" font-weight="800" font-size="16px" fill="#000" letter-spacing="-0.03em">amazon</text>
                <path d="M5 21C25 26 55 26 73 21" stroke="#FF9900" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                <path d="M70 19.5L74 21.5L71.5 24.5" stroke="#FF9900" stroke-width="2" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>

            {/* Coinbase Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-5" viewBox="0 0 95 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <text x="0" y="20" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="17px" fill="#0052FF" letter-spacing="-0.02em">coinbase</text>
              </svg>
            </div>

            {/* Cognition Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-6" viewBox="0 0 110 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="6" cy="14" r="2" fill="#000" />
                <circle cx="12" cy="9" r="2.5" fill="#000" />
                <circle cx="12" cy="19" r="2.5" fill="#000" />
                <circle cx="18" cy="6" r="3" fill="#000" />
                <circle cx="18" cy="14" r="3" fill="#000" />
                <circle cx="18" cy="22" r="3" fill="#000" />
                <text x="28" y="20" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="15px" fill="#000">Cognition</text>
              </svg>
            </div>

            {/* Solana Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-5" viewBox="0 0 110 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g>
                  <path d="M2 7.5L5 5H18L15 7.5H2Z" fill="url(#solana-grad)"/>
                  <path d="M15 12.5L18 10H5L2 12.5H15Z" fill="url(#solana-grad)"/>
                  <path d="M2 17.5L5 15H18L15 17.5H2Z" fill="url(#solana-grad)"/>
                </g>
                <text x="24" y="16.5" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="11px" fill="#000" letter-spacing="0.2em">SOLANA</text>
                <defs>
                  <linearGradient id="solana-grad" x1="2" y1="5" x2="18" y2="17.5" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#00FFA3" />
                    <stop offset="50%" stop-color="#854CFF" />
                    <stop offset="100%" stop-color="#DC1FFF" />
                  </linearGradient>
                </defs>
              </svg>
            </div>

            {/* AT&T Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-6" viewBox="0 0 90 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="14" r="10" fill="#00A0DD"/>
                <path d="M3 10H21" stroke="#FFF" stroke-width="1.5"/>
                <path d="M2.5 14H21.5" stroke="#FFF" stroke-width="1.8"/>
                <path d="M3.5 18H20.5" stroke="#FFF" stroke-width="1.5"/>
                <path d="M5.5 6H18.5" stroke="#FFF" stroke-width="1"/>
                <path d="M5.5 22H18.5" stroke="#FFF" stroke-width="1"/>
                <text x="28" y="21" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="16px" fill="#000" letter-spacing="0.05em">AT&T</text>
              </svg>
            </div>

            {/* Rivian Card */}
            <div class="flex items-center justify-center p-6 h-24 rounded-lg border border-hairline-soft bg-surface-soft transition-colors hover:bg-canvas">
              <svg class="h-5" viewBox="0 0 100 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g transform="translate(0, 4)">
                  <path d="M8 0L15 7L8 14L1 7L8 0Z" fill="none" stroke="#FFB800" stroke-width="2"/>
                  <path d="M8 3.5L11.5 7L8 10.5L4.5 7L8 3.5Z" fill="#FFB800"/>
                </g>
                <text x="22" y="18" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="13px" fill="#000" letter-spacing="0.25em">RIVIAN</text>
              </svg>
            </div>
          </div>
        </Reveal>
      </div>
    </div>

    {/* Bottom Bar: Stats Row */}
    <div class="border-t border-hairline-soft mt-12 pt-8">
      <Reveal delay={150}>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
          <div class="font-semibold text-ink text-sm tracking-tight shrink-0">Agents at work today</div>
          <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
            {/* Stat 1 */}
            <div class="flex items-center gap-2">
              <span class="text-[13px] font-medium text-stone">Feedback provided</span>
              <span class="rounded bg-brand/10 border border-brand/20 px-2 py-0.5 font-mono text-[13px] font-semibold text-brand-annotate">3,380</span>
            </div>
            {/* Stat 2 */}
            <div class="flex items-center gap-2">
              <span class="text-[13px] font-medium text-stone">Content updates</span>
              <span class="rounded bg-brand/10 border border-brand/20 px-2 py-0.5 font-mono text-[13px] font-semibold text-brand-annotate">22,122</span>
            </div>
            {/* Stat 3 */}
            <div class="flex items-center gap-2">
              <span class="text-[13px] font-medium text-stone">Pages read</span>
              <span class="rounded bg-brand/10 border border-brand/20 px-2 py-0.5 font-mono text-[13px] font-semibold text-brand-annotate">10,765,091</span>
            </div>
            {/* Stat 4 */}
            <div class="flex items-center gap-2">
              <span class="text-[13px] font-medium text-stone">Search requests</span>
              <span class="rounded bg-brand/10 border border-brand/20 px-2 py-0.5 font-mono text-[13px] font-semibold text-brand-annotate">132,257</span>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
