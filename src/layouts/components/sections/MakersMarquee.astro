---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX', 'HyperLogistics'];
---

{/* logo-wall — DESIGN.md §Signature Components: transparent cells, steel wordmarks on canvas */}
<section class="overflow-hidden border-b border-hairline bg-canvas py-16 md:py-24">
  <div class="container-page text-center">
    <Reveal>
      <h2 class="h3 mb-3">
        Trusted by <span class="text-brand">10,000+</span> businesses worldwide
      </h2>
      <a
        href="/customer"
        class="mb-10 inline-flex items-center gap-1.5 text-sm font-medium text-ink hover:text-brand"
      >
        Read their stories <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-14">
        {brands.map((b) => (
          <span class="px-2 py-2 text-base font-medium tracking-tight text-steel transition-colors hover:text-ink md:text-lg">
            {b}
          </span>
        ))}
      </div>
    </Reveal>
  </div>
</section>
