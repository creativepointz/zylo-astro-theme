---
import Reveal from '@/components/widgets/Reveal.astro';

const brands = ['CloudScale', 'DataPivot', 'VentureLab', 'SaaSify', 'SecureBank', 'FintechX', 'HyperLogistics'];
---

<section class="bg-brand text-white py-12 overflow-hidden relative shadow-inner">
  <div class="container-page max-w-6xl mx-auto px-4 text-center">
    <Reveal>
      <p class="text-xs md:text-sm font-semibold uppercase tracking-widest text-indigo-100/90 mb-6">
        Trusted by <span class="text-white font-bold underline">10,000+</span> businesses worldwide
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14 opacity-90">
        {brands.map((b) => (
          <span class="text-lg md:text-2xl font-bold font-heading tracking-tight text-white/90 hover:text-white transition-colors cursor-default">
            {b}
          </span>
        ))}
      </div>
    </Reveal>
  </div>
</section>
