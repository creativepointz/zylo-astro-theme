---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const trust = ['Free plan', 'No credit card required', 'Bring your own AI key'];
---

<section
  id="top"
  class="relative overflow-hidden pt-24 min-h-screen flex flex-col justify-between"
  style={{ backgroundImage: 'url(/home/hero_bg.png)', backgroundSize: 'cover', backgroundPosition: 'center center' }}
>
  <div class="container-page relative z-10 pt-20 text-center md:pt-24">
    <Reveal class="mx-auto max-w-3xl">
      <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand/30 bg-white/70 backdrop-blur-sm px-3 py-1 text-sm font-medium text-brand">
        <Icon name="lucide:sparkles" class="w-4 h-4" /> AI-native documentation
      </span>
      <h1 class="h1 text-slate-900 leading-tight">
        Beautiful Docs.
        <br />
        <span class="text-brand">Written by Anyone.</span>
      </h1>
      <p class="p-xl mx-auto mt-6 max-w-xl">
        Create, update, and publish beautiful documentation with AI. No code, no hassle.
      </p>
    </Reveal>

    {/* Primary CTA Button */}
    <Reveal delay={120} class="mx-auto mt-10">
      <div class="flex flex-col items-center justify-center gap-4">
        <a
          href="/pricing"
          class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-brand px-8 text-base font-semibold text-white hover:bg-brand-hover shadow-lg hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5 active:scale-[0.98]"
        >
          Start Free <Icon name="lucide:arrow-right" class="w-[18px] h-[18px]" />
        </a>
        <ul class="mt-4 flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
          {trust.map((t) => (
            <li class="p-lt flex items-center gap-1.5 text-slate-600">
              <Icon name="lucide:check" class="w-4 h-4 text-brand" /> {t}
            </li>
          ))}
        </ul>
      </div>
    </Reveal>

    {/* Product preview screenshot */}
    <Reveal delay={120} class="mt-16 md:mt-24 relative z-10">
      <div class="mx-auto max-w-5xl overflow-hidden rounded-t-xl border-t border-x border-b-0 border-slate-200/60 shadow-2xl">
        <img
          src="/home/zylo-hero.png"
          alt="Zylo dashboard — manage docs, articles, and feedback in one place"
          width={1320}
          height={880}
          class="w-full block"
          loading="eager"
        />
      </div>
    </Reveal>
  </div>
</section>
