---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

{/* hero-band-sky — DESIGN.md §Signature Components: full-bleed sky-to-cream gradient, 120px rhythm */}
<section
  id="top"
  class="relative overflow-hidden border-b border-hairline pt-24 pb-16 md:pt-[120px] md:pb-[120px]"
  style="background: linear-gradient(180deg, var(--color-hero-sky-from) 0%, var(--color-hero-sky-to) 100%);"
>
  <div class="container-page relative">
    {/* Headline & Email Form */}
    <div class="flex justify-center text-center">
      <div class="mx-auto max-w-4xl">
        <Reveal>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-1.5 text-sm font-medium text-ink">
            <span class="rounded-full bg-brand px-2.5 py-0.5 text-[13px] font-semibold text-primary">New</span>
            <span>Smart task management</span>
          </div>
          <h1 class="hero-display mb-6">
            Where teams move faster &amp; work gets done
          </h1>
          <p class="subtitle mx-auto mb-8 max-w-2xl text-charcoal">
            Map out tasks, work together effortlessly, and follow progress all from one beautifully unified tool.
          </p>
        </Reveal>

        {/* Email Subscription Bar */}
        <Reveal delay={100} class="mx-auto mb-16 max-w-xl">
          <form class="relative flex flex-col items-center gap-2 rounded-full border border-hairline bg-canvas p-2 focus-within:border-brand sm:flex-row">
            <input
              type="email"
              placeholder="Business email address"
              required
              class="w-full bg-transparent px-5 py-3 text-base text-ink placeholder-stone focus:outline-none"
            />
            <button type="submit" class="btn-accent btn-lg w-full shrink-0 sm:w-auto">
              Subscribe now <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </button>
          </form>
        </Reveal>
      </div>
    </div>

    {/* 3-Column Preview Grid */}
    <div class="mt-4 grid grid-cols-1 items-end gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {/* Column 1: Progress Card + Preview */}
      <Reveal delay={120} class="space-y-6">
        <div class="rounded-lg border border-hairline-soft bg-canvas p-6">
          <div class="mb-8 flex items-center gap-4">
            <div class="icon-tile h-12 w-12 rounded-md bg-primary text-on-primary">
              <Icon name="lucide:layers" class="h-6 w-6 text-brand" />
            </div>
            <div>
              <h3 class="h5">Design branding</h3>
              <p class="p-lt">Teacher: Jack Wins</p>
            </div>
          </div>
          <div class="mb-2 flex items-center justify-between text-[13px] font-medium text-ink">
            <span>Progress</span>
            <span class="text-brand">38%</span>
          </div>
          <div class="h-2 w-full overflow-hidden rounded-full bg-surface">
            <div class="h-full w-[38%] rounded-full bg-brand transition-all duration-1000"></div>
          </div>
        </div>

        <div class="rounded-lg border border-hairline-soft bg-canvas p-2">
          <img src="/placeholder.png" alt="Zylo preview" class="block h-48 w-full rounded-md object-contain p-4" />
        </div>
      </Reveal>

      {/* Column 2: Center Main Dashboard Card — hero-product-mockup */}
      <Reveal delay={160} class="lg:col-span-1">
        <div class="overflow-hidden rounded-lg border border-hairline-soft bg-canvas p-2 shadow-[var(--shadow-mockup)]">
          <div class="mb-2 rounded-md bg-canvas-dark p-6 text-on-dark">
            <div class="mb-4 flex items-center justify-between text-[13px] text-on-dark-muted">
              <span class="rounded-full bg-brand/15 px-3 py-1 font-medium text-brand">Active Workflow</span>
              <span>Live Monitor</span>
            </div>
            <div class="mb-1 text-[22px] font-semibold leading-[1.3] text-on-dark">AI Automation Pipeline</div>
            <div class="text-[13px] text-on-dark-muted">Executing 1,482 daily tasks autonomously</div>
          </div>
          <img src="/placeholder.png" alt="Main Dashboard Showcase" class="block h-64 w-full rounded-md object-contain p-4" />
        </div>
      </Reveal>

      {/* Column 3: Analytics & Tasks Cards */}
      <Reveal delay={200} class="space-y-6">
        <div class="space-y-3 rounded-lg border border-hairline-soft bg-canvas p-6">
          <div class="flex items-center justify-between">
            <span class="eyebrow">Completed Tasks</span>
            <span class="rounded-full bg-brand/15 px-2.5 py-0.5 text-[13px] font-semibold text-brand-annotate">+103 Done</span>
          </div>
          <div class="h3">99.8%</div>
          <div class="p-lt">On-time automation delivery SLA</div>
        </div>

        <div class="rounded-lg border border-hairline-soft bg-canvas p-2">
          <img src="/placeholder.png" alt="Analytics Preview" class="block h-48 w-full rounded-md object-contain p-4" />
        </div>
      </Reveal>
    </div>

  </div>
</section>
