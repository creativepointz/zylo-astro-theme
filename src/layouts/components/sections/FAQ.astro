---
import { Icon } from 'astro-icon/components';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

const defaultFaqs = [
  { q: 'Do I need to know how to code?', a: 'No. Zylo uses a visual builder anyone can use. Describe what you want and Zylo builds the agent — no code required.' },
  { q: 'Can I use my own AI provider?', a: 'Yes. Bring your own AI key on any plan for full control over cost and privacy.' },
  { q: 'Is Zylo really free?', a: 'Yes. There is a free plan with no expiry and no credit card required.' },
  { q: 'Which tools can Zylo connect to?', a: 'Slack, email, CRMs, databases, and more — plus webhooks and API access for anything custom.' },
  { q: 'Which AI models does Zylo support?', a: 'Zylo works with GPT, Claude, and open models. Swap models anytime without rebuilding your agents.' },
  { q: 'What happens to my data if I cancel?', a: 'Your data stays yours. You can export everything anytime.' },
];

interface Faq {
  q: string;
  a: string;
}

interface Props {
  faqs?: Faq[];
  title?: string;
}

const { faqs = defaultFaqs, title = "Frequently Asked Questions" }: Props = Astro.props;
---

<section id="faq" class="section bg-white">
  <div class="container-page">
    <SectionHeading title={title} />
    <dl class="mx-auto max-w-3xl divide-y divide-slate-200 border-y border-slate-200" data-faq>
      {faqs.map((item, i) => (
        <div>
          <dt>
            <button
              type="button"
              aria-expanded={i === 0 ? 'true' : 'false'}
              data-faq-btn
              class="flex w-full items-center justify-between gap-4 py-5 text-left transition-colors hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
            >
              <span class="h6 text-slate-900">{item.q}</span>
              <Icon
                name="lucide:chevron-down"
                class={`w-6 h-6 shrink-0 text-slate-400 transition-transform duration-200 ${i === 0 ? 'rotate-180 text-brand' : ''}`}
                data-faq-chevron
              />
            </button>
          </dt>
          <dd
            data-faq-panel
            class={`grid overflow-hidden transition-all duration-200 ease-out ${i === 0 ? 'grid-rows-[1fr] pb-5 opacity-100' : 'grid-rows-[0fr] opacity-0'}`}
          >
            <p class="p-rg min-h-0 pr-10 text-slate-600">{item.a}</p>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<script>
  const root = document.querySelector('[data-faq]');
  if (root) {
    const btns = Array.from(root.querySelectorAll('[data-faq-btn]')) as HTMLElement[];

    const setItem = (btn: HTMLElement, open: boolean) => {
      const panel = btn.parentElement?.nextElementSibling;
      const chevron = btn.querySelector('[data-faq-chevron]');
      if (!panel || !chevron) return;
      btn.setAttribute('aria-expanded', String(open));
      panel.classList.toggle('grid-rows-[1fr]', open);
      panel.classList.toggle('pb-5', open);
      panel.classList.toggle('opacity-100', open);
      panel.classList.toggle('grid-rows-[0fr]', !open);
      panel.classList.toggle('opacity-0', !open);
      chevron.classList.toggle('rotate-180', open);
      chevron.classList.toggle('text-brand', open);
    };

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        btns.forEach((b) => setItem(b, false));
        if (!isOpen) setItem(btn, true);
      });
    });
  }
</script>
