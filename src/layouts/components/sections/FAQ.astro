---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const answer =
  'Yes — there are several mobile apps designed for task management so you can manage work on the go. Many popular task management SaaS platforms offer.';

const bullets = [
  'Create, assign & update tasks on the go',
  'Flexible view & quick accessibility',
  'Real-time notifications & sync',
];

const faqs = [
  { q: 'What automation features reduce manual work?', a: answer, bullets },
  { q: 'Is there a mobile app for managing tasks on the go?', a: answer, bullets },
  { q: 'Can AI help prioritize tasks or analyze workload?', a: answer, bullets },
  { q: 'Do you provide real-time reporting and performance insights?', a: answer, bullets },
  { q: 'How does your platform help teams collaborate better?', a: answer, bullets },
];
---

<section id="faq-section" class="py-24 bg-canvas border-b border-hairline-soft">
  <div class="container-page max-w-4xl mx-auto px-4">
    <Reveal class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-stone uppercase tracking-wider mb-2">Our faq</span>
      <h2 class="text-3xl sm:text-5xl font-semibold text-ink font-heading tracking-tight mb-4 leading-tight">
        What client asking?
      </h2>
      <p class="text-base text-steel leading-relaxed font-normal">
        Connect Zylo with your favourite tools to streamline workflows and keep everything running smoothly.
      </p>
    </Reveal>

    <div class="space-y-4 mb-14">
      {faqs.map((f, idx) => (
        <Reveal delay={idx * 60}>
          <details class="group rounded-lg border border-hairline bg-surface-soft p-6 shadow-[var(--shadow-subtle)] cursor-pointer transition-all hover:bg-canvas hover:shadow-[var(--shadow-subtle)] [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex items-center justify-between font-semibold text-ink font-heading text-lg">
              <span>{f.q}</span>
              <span class="w-8 h-8 rounded-full bg-canvas border border-hairline flex items-center justify-center shrink-0 group-open:rotate-180 transition-transform shadow-[var(--shadow-subtle)]">
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-steel" />
              </span>
            </summary>
            <div class="mt-4 border-t border-hairline pt-4">
              <p class="text-steel text-sm leading-relaxed font-normal">{f.a}</p>
              <ul class="mt-4 space-y-2">
                {f.bullets.map((b) => (
                  <li class="flex items-center gap-2.5 text-sm text-steel font-medium">
                    <Icon name="lucide:check" class="w-4 h-4 text-brand shrink-0" />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        </Reveal>
      ))}
    </div>

    <Reveal class="text-center">
      <a href="/contact" class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-primary px-7 text-sm font-medium text-on-primary hover:bg-charcoal transition-colors shadow-[var(--shadow-subtle)]">
        Contact us <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </Reveal>
  </div>
</section>
