---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

{/* Dark inversion band — DESIGN.md §Colors: canvas-dark surface, hairline-dark rules, on-dark type */}
<section id="features" class="section border-y border-hairline-dark bg-canvas-dark text-on-dark">
  <div class="container-page">
    <Reveal class="mx-auto mb-16 max-w-3xl text-center">
      <span class="mb-4 inline-block rounded-full border border-hairline-dark px-4 py-1.5 text-[11px] font-semibold uppercase leading-[1.4] tracking-[0.5px] text-on-dark-muted">
        Features
      </span>
      <h2 class="h2 mb-4 text-on-dark">
        Features built for real work
      </h2>
      <p class="subtitle text-on-dark-muted">
        Experience features that take your productivity to the next level.
      </p>
    </Reveal>

    {/* Top Row: 2 Big Feature Cards */}
    <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-2">
      <Reveal delay={100}>
        <div class="flex h-full flex-col justify-between rounded-lg border border-hairline-dark bg-charcoal p-8">
          <div>
            <h3 class="h4 mb-3 text-on-dark">Custom workspace</h3>
            <p class="p-rg mb-6 text-on-dark-muted">
              A dedicated environment in Zylo that brings together all your workflows, AI key configurations, and team members in one place.
            </p>
          </div>
          <div class="rounded-md border border-hairline-dark bg-canvas-dark p-3">
            <img src="/home/zylo-hero.png" alt="Custom Workspace" class="block h-44 w-full rounded-sm object-cover" />
          </div>
        </div>
      </Reveal>

      <Reveal delay={150}>
        <div class="flex h-full flex-col justify-between rounded-lg border border-hairline-dark bg-charcoal p-8">
          <div>
            <h3 class="h4 mb-3 text-on-dark">Progress tracking</h3>
            <p class="p-rg mb-6 text-on-dark-muted">
              Real-time monitoring for your active agent workflows. Track execution times, error rates, and automated task status live.
            </p>
          </div>
          <div class="rounded-md border border-hairline-dark bg-canvas-dark p-3">
            <img src="/home/zylo-hero.png" alt="Progress Tracking" class="block h-44 w-full rounded-sm object-cover" />
          </div>
        </div>
      </Reveal>
    </div>

    {/* Bottom Row: 3 Feature Cards */}
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {/* Card 1: Team Collaboration */}
      <Reveal delay={200}>
        <div class="flex h-full flex-col justify-between rounded-lg border border-hairline-dark bg-charcoal p-8">
          <div>
            <h3 class="h5 mb-3 text-on-dark">Collaborate with your team</h3>
            <p class="p-sm mb-6 text-on-dark-muted">
              Invite teammates or partners to share projects and work together, seamlessly organized.
            </p>
          </div>
          <div class="flex flex-col items-center justify-center rounded-md border border-hairline-dark bg-canvas-dark p-6 text-center">
            <div class="mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-brand text-sm font-semibold text-primary">
              Zylo
            </div>
            <span class="text-[13px] font-medium text-on-dark-muted">Unified Team Access</span>
          </div>
        </div>
      </Reveal>

      {/* Card 2: Track Your Success */}
      <Reveal delay={240}>
        <div class="flex h-full flex-col justify-between rounded-lg border border-hairline-dark bg-charcoal p-8">
          <div>
            <span class="mb-4 inline-block rounded-full bg-brand/15 px-3 py-1 text-[13px] font-semibold text-brand">
              103 Tasks Completed
            </span>
            <h3 class="h5 mb-2 text-on-dark">Track your success</h3>
            <p class="p-sm mb-6 text-on-dark-muted">
              Maintaining a good work-life balance and a positive attitude is important for mental well-being.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-2 border-t border-hairline-dark pt-4 text-center">
            <div>
              <div class="text-base font-semibold text-on-dark">99%</div>
              <div class="text-xs font-medium text-on-dark-muted">On time</div>
            </div>
            <div>
              <div class="text-base font-semibold text-on-dark">18 hrs</div>
              <div class="text-xs font-medium text-on-dark-muted">Time saved</div>
            </div>
            <div>
              <div class="text-base font-semibold text-on-dark">100%</div>
              <div class="text-xs font-medium text-on-dark-muted">Priority met</div>
            </div>
          </div>
        </div>
      </Reveal>

      {/* Card 3: Action Needed */}
      <Reveal delay={280}>
        <div class="flex h-full flex-col justify-between rounded-lg border border-hairline-dark bg-charcoal p-8">
          <div>
            <h3 class="h5 mb-3 text-on-dark">Your action needed</h3>
            <p class="p-sm mb-6 text-on-dark-muted">
              We've reviewed your application, and there are a few things you'll need to adjust before it can be approved.
            </p>
          </div>
          <div class="flex items-center justify-between rounded-md border border-hairline-dark bg-canvas-dark p-4 text-[13px] font-medium text-on-dark">
            <span class="flex items-center gap-2">
              <Icon name="lucide:alert-circle" class="h-4 w-4 text-brand-warn" /> Human Review Required
            </span>
            <Icon name="lucide:chevron-right" class="h-4 w-4 text-on-dark-muted" />
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
