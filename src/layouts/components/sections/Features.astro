---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

<section id="features" class="py-24 bg-slate-900 text-white relative overflow-hidden">
  {/* Glow Accents */}
  <div class="absolute inset-0 pointer-events-none select-none">
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand/20 blur-[150px] rounded-full"></div>
  </div>

  <div class="container-page max-w-6xl mx-auto px-4 relative z-10">
    <Reveal class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block border border-white/20 bg-white/10 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider text-indigo-200 mb-4 backdrop-blur-md">
        Features
      </span>
      <h2 class="text-3xl sm:text-5xl font-bold font-heading tracking-tight mb-4 leading-tight">
        Features built for real work
      </h2>
      <p class="text-base sm:text-lg text-slate-300 leading-relaxed font-normal">
        Experience features that take your productivity to the next level.
      </p>
    </Reveal>

    {/* Top Row: 2 Big Feature Cards */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <Reveal delay={100}>
        <div class="rounded-3xl bg-white/5 border border-white/10 p-8 hover:bg-white/10 transition-colors h-full flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold font-heading mb-3 text-white">Custom workspace</h3>
            <p class="text-slate-300 text-sm leading-relaxed mb-6">
              A dedicated environment in Zylo that brings together all your workflows, AI key configurations, and team members in one place.
            </p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-slate-950 p-4">
            <img src="/home/zylo-hero.png" alt="Custom Workspace" class="w-full rounded-xl block object-cover h-44" />
          </div>
        </div>
      </Reveal>

      <Reveal delay={150}>
        <div class="rounded-3xl bg-white/5 border border-white/10 p-8 hover:bg-white/10 transition-colors h-full flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold font-heading mb-3 text-white">Progress tracking</h3>
            <p class="text-slate-300 text-sm leading-relaxed mb-6">
              Real-time monitoring for your active agent workflows. Track execution times, error rates, and automated task status live.
            </p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-slate-950 p-4">
            <img src="/home/zylo-hero.png" alt="Progress Tracking" class="w-full rounded-xl block object-cover h-44" />
          </div>
        </div>
      </Reveal>
    </div>

    {/* Bottom Row: 3 Feature Cards */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {/* Card 1: Team Collaboration */}
      <Reveal delay={200}>
        <div class="rounded-3xl bg-white/5 border border-white/10 p-8 hover:bg-white/10 transition-colors h-full flex flex-col justify-between">
          <div>
            <h3 class="text-xl font-bold font-heading mb-3 text-white">Collaborate with your team</h3>
            <p class="text-slate-300 text-xs leading-relaxed mb-6">
              Invite teammates or partners to share projects and work together, seamlessly organized.
            </p>
          </div>
          <div class="rounded-2xl bg-brand/20 border border-brand/30 p-6 text-center flex flex-col items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-brand text-white flex items-center justify-center font-bold text-xl mb-3 shadow-lg">
              Zylo
            </div>
            <span class="text-xs font-semibold text-indigo-200">Unified Team Access</span>
          </div>
        </div>
      </Reveal>

      {/* Card 2: Track Your Success */}
      <Reveal delay={240}>
        <div class="rounded-3xl bg-white/5 border border-white/10 p-8 hover:bg-white/10 transition-colors h-full flex flex-col justify-between">
          <div>
            <span class="inline-block rounded-full bg-emerald-500/20 text-emerald-300 px-3 py-1 text-xs font-bold mb-4">
              103 Tasks Completed
            </span>
            <h3 class="text-xl font-bold font-heading mb-2 text-white">Track your success</h3>
            <p class="text-slate-300 text-xs leading-relaxed mb-6">
              Maintaining a good work-life balance and a positive attitude is important for mental well-being.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-2 pt-4 border-t border-white/10 text-center">
            <div>
              <div class="text-lg font-bold font-heading text-brand">99%</div>
              <div class="text-[10px] text-slate-400 font-medium">On time</div>
            </div>
            <div>
              <div class="text-lg font-bold font-heading text-brand">18 hrs</div>
              <div class="text-[10px] text-slate-400 font-medium">Time saved</div>
            </div>
            <div>
              <div class="text-lg font-bold font-heading text-brand">100%</div>
              <div class="text-[10px] text-slate-400 font-medium">Priority met</div>
            </div>
          </div>
        </div>
      </Reveal>

      {/* Card 3: Action Needed */}
      <Reveal delay={280}>
        <div class="rounded-3xl bg-white/5 border border-white/10 p-8 hover:bg-white/10 transition-colors h-full flex flex-col justify-between">
          <div>
            <h3 class="text-xl font-bold font-heading mb-3 text-white">Your action needed</h3>
            <p class="text-slate-300 text-xs leading-relaxed mb-6">
              We've reviewed your application, and there are a few things you'll need to adjust before it can be approved.
            </p>
          </div>
          <div class="rounded-2xl bg-amber-500/10 border border-amber-500/30 p-4 text-amber-300 text-xs font-semibold flex items-center justify-between">
            <span class="flex items-center gap-2">
              <Icon name="lucide:alert-circle" class="w-4 h-4 text-amber-400" /> Human Review Required
            </span>
            <Icon name="lucide:chevron-right" class="w-4 h-4" />
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
