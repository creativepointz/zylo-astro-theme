---
import Reveal from '@/components/widgets/Reveal.astro';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

const personas = [
  { image: '/features/Page Analytics.png', label: 'Ops & RevOps', use: 'Enrich leads, sync your tools, and kill manual data entry.' },
  { image: '/features/Roles and Permissions.png', label: 'Support & Success', use: 'Auto-answer tickets and route the rest to the right person.' },
  { image: '/features/Write together, ship together..png', label: 'Founders & small teams', use: "Automate the busywork you can't afford to hire for." },
];
---

<section id="audience" class="section bg-surface-soft">
  <div class="container-page">
    <SectionHeading
      title="Built for Lean Teams That Do More With Less"
      intro="Zylo is made for the ops, support, and founding teams who keep everything running — and want AI to take the repetitive work off their plate. No developers, no scripts required."
    />
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {personas.map(({ image, label, use }, i) => (
        <Reveal
          delay={i * 80}
          class="group flex flex-col overflow-hidden rounded-lg border border-hairline bg-canvas transition duration-200 ease-out hover:shadow-[var(--shadow-card)]"
        >
          <div class="flex h-44 w-full items-center justify-center overflow-hidden border-b border-hairline-soft bg-surface-soft p-6 md:h-52">
            <img
              src={image}
              alt={label}
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div class="mt-auto flex flex-col p-6">
            <h3 class="h4 mb-3">{label}</h3>
            <p class="p-rg">{use}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
