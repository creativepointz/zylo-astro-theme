---
import Reveal from '@/components/widgets/Reveal.astro';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

const personas = [
  { image: '/features/Page Analytics.png', label: 'Ops & RevOps', use: 'Enrich leads, sync your tools, and kill manual data entry.' },
  { image: '/features/Roles and Permissions.png', label: 'Support & Success', use: 'Auto-answer tickets and route the rest to the right person.' },
  { image: '/features/Write together, ship together..png', label: 'Founders & small teams', use: "Automate the busywork you can't afford to hire for." },
];
---

<section id="audience" class="py-24 bg-[#efefff]">
  <div class="container-page">
    <SectionHeading
      title="Built for Lean Teams That Do More With Less"
      intro="Zylo is made for the ops, support, and founding teams who keep everything running — and want AI to take the repetitive work off their plate. No developers, no scripts required."
    />
    <div class="grid grid-cols-1 gap-0 md:grid-cols-3">
      {personas.map(({ image, label, use }, i) => (
        <Reveal
          delay={i * 80}
          class="group flex flex-col overflow-hidden rounded-[20px] border border-[#e2e8f0] bg-white transition duration-300 ease-out hover:z-10 hover:shadow-lg"
        >
          <div class="flex h-44 w-full items-center justify-center overflow-hidden p-6 md:h-52">
            <img
              src={image}
              alt={label}
              class="max-h-full max-w-full object-contain opacity-90 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100"
            />
          </div>
          <div class="mt-auto flex flex-col p-6 md:p-8">
            <h3 class="mb-3 font-heading text-xl font-semibold leading-tight text-[#0f172b] md:text-2xl">{label}</h3>
            <p class="text-base leading-relaxed text-[#45556c]">{use}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
