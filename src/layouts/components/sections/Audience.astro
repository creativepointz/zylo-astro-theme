---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

const personas = [
  { icon: 'lucide:package', label: 'Product teams' },
  { icon: 'lucide:megaphone', label: 'Marketing teams' },
  { icon: 'lucide:rocket', label: 'Founders & support teams' },
];
---

<section id="audience" class="section bg-[#f8f8f8] border-y border-slate-100">
  <div class="container-page">
    <SectionHeading
      title="Built for Teams Without a Docs Team"
      intro="You don't need developers. You don't need markdown. Just your ideas. Zylo is made for people who need great documentation but don't write code, like:"
    />
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 sm:grid-cols-3">
      {personas.map(({ icon, label }, i) => (
        <Reveal
          delay={i * 80}
          class="flex flex-col items-center gap-4 rounded-xl border border-slate-200/80 bg-white p-8 text-center transition duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md hover:border-brand/20"
        >
          <span class="icon-tile h-14 w-14 rounded-full">
            <Icon name={icon} class="w-7 h-7" aria-hidden="true" />
          </span>
          <span class="h6 text-slate-900">{label}</span>
        </Reveal>
      ))}
    </div>
  </div>
</section>
