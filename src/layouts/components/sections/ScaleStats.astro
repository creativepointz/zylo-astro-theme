---
import Reveal from '@/components/widgets/Reveal.astro';

/* 3-up scale figures. Theme placeholder values. */
const stats = [
  { value: '10,000+', label: 'Businesses building on Zylo' },
  { value: '2B+', label: 'Automated tasks executed' },
  { value: '99.99%', label: 'Platform uptime' },
];
---

<section class="section border-b border-hairline bg-canvas">
  <div class="container-page">
    <Reveal class="mx-auto mb-14 max-w-2xl text-center">
      <h2 class="h2">Built to run at production scale</h2>
    </Reveal>

    <div class="grid grid-cols-1 gap-10 text-center md:grid-cols-3">
      {stats.map((s, idx) => (
        <Reveal delay={idx * 60}>
          <div class="display-lg mb-2">{s.value}</div>
          <div class="p-rg">{s.label}</div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
