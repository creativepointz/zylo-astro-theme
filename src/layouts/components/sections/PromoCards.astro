---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

<section id="promo-cards" class="py-16 bg-canvas">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-[32px]">
      {/* Left Card: Team Plan */}
      <Reveal
        delay={40}
        class="flex flex-col justify-between rounded-[16px] border border-[#e2e8f0]/80 bg-canvas p-8 md:p-[41px] transition duration-300 hover:shadow-[var(--shadow-card)] hover:-translate-y-1 text-left min-h-[380px] lg:min-h-[431px]"
      >
        <div class="space-y-6">
          <div>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#eef2ff] px-[12px] py-[4px] text-[12px] font-semibold text-[#4f46e5]">
              <Icon name="lucide:sparkles" class="w-3 h-3 fill-[#4f46e5] text-[#4f46e5]" /> Team Plan
            </span>
          </div>
          <h2 class="text-[40px] lg:text-[52px] font-semibold text-[#0f172b] leading-[1.2] font-heading tracking-tight">
            Your AI edge for <br />every workflow.
          </h2>
          <p class="text-[16px] lg:text-[18px] text-[#45556c] leading-[1.6] max-w-md">
            Zylo unites a visual agent builder and AI automation tools in one workspace — so your team ships more without hiring more.
          </p>
        </div>
        <div class="mt-8 lg:mt-12">
          <a
            href="/pricing"
            class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary h-[48px] px-[24px] rounded-full text-[16px] font-medium hover:bg-charcoal transition duration-200"
          >
            Try for free <Icon name="lucide:arrow-right" class="w-[18px] h-[18px]" />
          </a>
        </div>
      </Reveal>

      {/* Right Card: Enterprise */}
      <Reveal
        delay={120}
        class="flex flex-col justify-between rounded-[16px] border border-white/5 p-8 md:p-[41px] transition duration-300 hover:shadow-[var(--shadow-card)]  hover:-translate-y-1 text-left min-h-[380px] lg:min-h-[431px]"
        style={{ backgroundImage: 'linear-gradient(213.417deg, rgb(79, 70, 229) -10%, rgb(15, 23, 43) 45%)' }}
      >
        <div class="space-y-6">
          <div>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-canvas/10 px-[12px] py-[4px] text-[12px] font-semibold text-[#cad5e2]">
              <Icon name="lucide:shield-check" class="w-3 h-3 text-[#cad5e2]" /> Enterprise
            </span>
          </div>
          <h2 class="text-[40px] lg:text-[52px] font-semibold text-on-dark leading-[1.2] font-heading tracking-tight">
            Bigger scale. <br />Smarter agents.
          </h2>
          <p class="text-[16px] lg:text-[18px] text-[#90a1b9] leading-[1.6] max-w-md">
            Zylo for Enterprise means AI automation at company scale. Private deployments, granular controls, and single sign-on for all your global teams.
          </p>
        </div>
        <div class="mt-8 lg:mt-12">
          <a
            href="#start"
            class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary h-[48px] px-[24px] rounded-full text-[16px] font-medium hover:bg-charcoal transition duration-200"
          >
            Book a demo <Icon name="lucide:arrow-right" class="w-[18px] h-[18px]" />
          </a>
        </div>
      </Reveal>
    </div>
  </div>
</section>
