---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

/* 5-up capability list. Copy reused from the theme's existing step + feature content. */
const items = [
  { icon: 'lucide:user-plus', title: 'Create free account', desc: 'Set up your team workspace in two minutes.' },
  { icon: 'lucide:users-round', title: 'Invite team members', desc: 'Role-based access for collaborative automation building.' },
  { icon: 'lucide:zap', title: 'Instantly improve workflow', desc: 'Connect 100+ tools and deploy agents that clear manual tasks.' },
  { icon: 'lucide:bar-chart-2', title: 'Track progress', desc: 'Monitor execution health and cost savings live.' },
  { icon: 'lucide:shield-check', title: 'Keep control', desc: 'Permissions, audit logs and human review where it matters.' },
];
---

<section id="platform" class="section border-b border-hairline bg-canvas">
  <div class="container-page">
    <Reveal class="mx-auto mb-14 max-w-3xl text-center">
      <span class="eyebrow mb-3 block">The platform</span>
      <h2 class="h2 mb-4">Everything the work needs, in one workspace</h2>
      <p class="subtitle">Transform your team's potential into performance, from first workflow to daily operations.</p>
    </Reveal>

    <div class="grid grid-cols-2 gap-x-8 gap-y-10 md:grid-cols-3 lg:grid-cols-5">
      {items.map((it, idx) => (
        <Reveal delay={idx * 50}>
          <div class="icon-tile mb-4">
            <Icon name={it.icon} class="h-5 w-5" />
          </div>
          <h3 class="h6 mb-1.5">{it.title}</h3>
          <p class="p-sm">{it.desc}</p>
        </Reveal>
      ))}
    </div>
  </div>
</section>
