---
import Reveal from '@/components/widgets/Reveal.astro';

/* Live activity strip — 6-up realtime counters. Values are theme placeholders. */
const metrics = [
  { value: '1,482', label: 'Tasks executed today' },
  { value: '38,910', label: 'Workflow runs this week' },
  { value: '104k', label: 'API requests routed' },
  { value: '2,760', label: 'Approvals handled' },
  { value: '18 hrs', label: 'Time saved per member' },
  { value: '99.8%', label: 'On-time delivery' },
];
---

<section class="border-b border-hairline bg-surface-soft py-12">
  <div class="container-page">
    <Reveal class="mb-8 flex items-center justify-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
      </span>
      <span class="eyebrow">Live on Zylo right now</span>
    </Reveal>

    <div class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-6">
      {metrics.map((m, idx) => (
        <Reveal delay={idx * 40} class="text-center">
          <div class="text-[22px] font-semibold leading-[1.3] text-ink md:text-[28px]">{m.value}</div>
          <div class="p-lt mt-1">{m.label}</div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
