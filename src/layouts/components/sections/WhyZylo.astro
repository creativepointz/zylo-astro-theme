---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

const bentoItems = [
  {
    icon: 'lucide:code-2',
    title: 'No Code Needed',
    body: 'A visual editor anyone can use. Write docs like you write a note.',
    className: 'col-span-1 md:col-span-2 lg:col-start-1 lg:col-span-2 lg:row-start-1 bg-white',
  },
  {
    icon: 'lucide:palette',
    title: 'Beautiful Output',
    body: 'Every site looks pro by default. No theme tweaking, no CSS.',
    className: 'col-span-1 md:col-span-1 lg:col-start-3 lg:col-span-1 lg:row-start-1 bg-white',
  },
  {
    icon: 'lucide:key-round',
    title: 'AI on Your Terms',
    body: 'Use our AI or bring your own key. You stay in control of cost and privacy.',
    className: 'col-span-1 md:col-span-1 lg:col-start-1 lg:col-span-1 lg:row-start-2 bg-white',
  },
  {
    icon: 'lucide:tag',
    title: 'A Price That Fits',
    body: 'Start free. Paid plans from <span class="font-semibold tabular-nums text-[#0f172b]">$19/mo</span>, not $300.',
    className: 'col-span-1 md:col-span-2 lg:col-start-1 lg:col-span-1 lg:row-start-3 bg-white',
  },
];
---

<section id="why" class="section bg-[#f8fafc]">
  <div class="container-page">
    <SectionHeading
      title="Why Zylo?"
      intro="Most doc tools are built for developers or cost a fortune. Zylo is built for everyone, at a price that makes sense."
    />

    {/* Bento Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16">
      {bentoItems.map(({ icon, title, body, className }, i) => (
        <Reveal
          delay={(i % 3) * 80}
          class={`rounded-[16px] border border-[#e2e8f0] p-8 transition duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col ${className}`}
        >
          <span class="inline-flex items-center justify-center h-[48px] w-[48px] rounded-xl bg-[#eef2ff] text-brand mb-8">
            <Icon name={icon} class="w-6 h-6" aria-hidden="true" />
          </span>
          <div class="mt-auto">
            <h3 class="text-[24px] font-semibold text-[#0f172b] mb-3 font-heading leading-tight">{title}</h3>
            <p class="text-[18px] text-[#45556c] leading-[27px]" set:html={body}></p>
          </div>
        </Reveal>
      ))}

      {/* Featured: Backed by a trusted team */}
      <Reveal
        delay={80}
        class="col-span-1 md:col-span-2 lg:col-start-2 lg:col-span-2 lg:row-start-2 lg:row-span-2 rounded-[16px] text-white p-8 md:p-10 transition duration-300 hover:shadow-xl hover:-translate-y-1 relative overflow-hidden group flex flex-col"
        style={{ backgroundImage: 'linear-gradient(212deg, rgb(79, 70, 229) -10%, rgb(15, 23, 43) 45%)' }}
      >
        <div class="relative z-10 flex-1 flex flex-col">
          <div class="flex items-center mb-6">
            <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg bg-white/10">
              <Icon name="lucide:shield-check" class="w-[18px] h-[18px] text-white" aria-hidden="true" />
            </span>
          </div>
          <div class="mb-10">
            <h3 class="text-[36px] font-semibold text-white mb-2 font-heading leading-tight">Backed by a Trusted Team</h3>
            <p class="text-[20px] text-[#cad5e2] max-w-xl leading-[30px]">
              <span class="font-bold text-white">200K+</span> users and{' '}
              <span class="font-bold text-white">10+</span> years of shipping. Zylo is
              built on a foundation you can trust.
            </p>
          </div>

          {/* Purple Stats Grid */}
          <div class="mt-auto bg-[#2c277f] rounded-[16px] px-8 py-6 grid grid-cols-2 gap-y-8 gap-x-8 max-w-[514px]">
            <div>
              <h4 class="text-[36px] font-semibold text-white mb-1 font-heading leading-tight">520k+</h4>
              <p class="text-[18px] text-[#cad5e2]">Businesses Empowered</p>
            </div>
            <div>
              <h4 class="text-[36px] font-semibold text-white mb-1 font-heading leading-tight">70k+</h4>
              <p class="text-[18px] text-[#cad5e2]">Active Installs</p>
            </div>
            <div>
              <h4 class="text-[36px] font-semibold text-white mb-1 font-heading leading-tight">99%</h4>
              <p class="text-[18px] text-[#cad5e2]">Uptime</p>
            </div>
            <div>
              <h4 class="text-[36px] font-semibold text-white mb-1 font-heading leading-tight">160+</h4>
              <p class="text-[18px] text-[#cad5e2]">Countries Served</p>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
