---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const reviews = [
  {
    author: 'Richard',
    role: 'Community Organiser',
    company: 'CloudScale',
    quote: 'This platform completely changed how our support team operates. From intelligent workflows to real-time analytics, everything is designed to scale. We now handle more than double the number of tickets with the same team without compromising service quality.',
  },
  {
    author: 'Rudra Ghosh',
    role: 'Product Lead',
    company: 'Fintech Flow',
    quote: 'Connecting custom LLM endpoints and databases took literally minutes. The reliability and low latency execution have made Zylo an indispensable part of our core product infrastructure.',
  },
  {
    author: 'Sarah Jenkins',
    role: 'VP of Operations',
    company: 'HyperLogistics',
    quote: 'We saved over 150 hours per team member per month. The visual workflow canvas makes it effortless for anyone on our team to build automated AI pipelines.',
  },
];
---

<section id="testimonials" class="py-24 bg-white border-b border-slate-200/60 overflow-hidden">
  <div class="container-page max-w-6xl mx-auto px-4">
    <Reveal class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2 block">Testimonials</span>
        <h2 class="text-3xl sm:text-5xl font-bold text-slate-900 font-heading tracking-tight leading-tight">
          Experiences shared by <br class="hidden sm:inline" /> our customers
        </h2>
      </div>
      <a href="/testimonial" class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-slate-900 px-6 text-sm font-semibold text-white hover:bg-brand transition-colors shadow-sm shrink-0">
        See all testimonials <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </Reveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((r, idx) => (
        <Reveal delay={idx * 80}>
          <div class="rounded-3xl border border-slate-200 bg-slate-50/50 p-8 hover:bg-white hover:shadow-xl transition-all h-full flex flex-col justify-between">
            <div class="mb-8">
              <div class="flex items-center gap-1 text-amber-400 mb-6">
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              </div>
              <p class="text-slate-700 text-sm leading-relaxed font-normal italic">
                "{r.quote}"
              </p>
            </div>

            <div class="pt-6 border-t border-slate-200/80 flex items-center gap-4">
              <div class="w-11 h-11 rounded-full bg-brand text-white font-bold flex items-center justify-center font-heading text-sm shadow-md">
                {r.author[0]}
              </div>
              <div>
                <h4 class="font-bold text-slate-900 text-sm font-heading">{r.author}</h4>
                <p class="text-xs text-slate-500">{r.role}, <span class="font-semibold text-slate-800">{r.company}</span></p>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
