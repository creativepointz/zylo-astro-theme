---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const reviews = [
  {
    author: 'Richard',
    role: 'Community Organiser',
    company: 'CloudScale',
    quote: 'This platform completely changed how our support team operates. From intelligent workflows to real-time analytics, everything is designed to scale. We now handle more than double the number of tickets with the same team without compromising service quality.',
  },
  {
    author: 'Rudra Ghosh',
    role: 'Product Lead',
    company: 'Fintech Flow',
    quote: 'Connecting custom LLM endpoints and databases took literally minutes. The reliability and low latency execution have made Zylo an indispensable part of our core product infrastructure.',
  },
  {
    author: 'Sarah Jenkins',
    role: 'VP of Operations',
    company: 'HyperLogistics',
    quote: 'We saved over 150 hours per team member per month. The visual workflow canvas makes it effortless for anyone on our team to build automated AI pipelines.',
  },
  {
    author: 'Marta Silva',
    role: 'Head of Support',
    company: 'SaaSify',
    quote: 'Onboarding a new teammate used to take a week of shadowing. They now ship their first working automation on day one.',
  },
];
---

<section id="testimonials" class="section overflow-hidden border-b border-hairline bg-surface-soft">
  <div class="container-page">
    <Reveal class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <span class="eyebrow mb-3 block">Testimonials</span>
        <h2 class="h2">
          Experiences shared by <br class="hidden sm:inline" /> our customers
        </h2>
      </div>
      <a href="/testimonial" class="btn-secondary btn-md shrink-0">
        See all testimonials <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </Reveal>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {reviews.map((r, idx) => (
        <Reveal delay={idx * 80}>
          <div class="flex h-full flex-col justify-between rounded-lg border border-hairline bg-canvas p-6 transition-colors hover:bg-surface-soft">
            <div class="mb-6">
              <div class="mb-5 flex items-center gap-0.5 text-brand">
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              </div>
              <p class="p-sm text-charcoal">
                "{r.quote}"
              </p>
            </div>

            <div class="pt-6 border-t border-hairline flex items-center gap-4">
              <img
                src="/placeholder.png"
                alt={r.author}
                loading="lazy"
                class="h-11 w-11 shrink-0 rounded-full border border-hairline bg-surface object-cover"
              />
              <div>
                <h4 class="text-sm font-medium text-ink">{r.author}</h4>
                <p class="text-xs text-stone">{r.role}, <span class="font-semibold text-ink">{r.company}</span></p>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
