---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

// Outcome-first proof band. Numbers are illustrative placeholders — swap for
// your real metrics. Kept consistent with the trust stats in WhyZylo.
const outcomes = [
  { icon: 'lucide:timer', value: '3 hrs', label: 'saved per person, every week' },
  { icon: 'lucide:rocket', value: '10 min', label: 'to build your first agent' },
  { icon: 'lucide:repeat', value: '4M+', label: 'agent runs every month' },
  { icon: 'lucide:shield-check', value: '99.9%', label: 'run reliability' },
];
---

<section id="outcomes" class="bg-canvas py-14 border-b border-hairline-soft">
  <div class="container-page">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
      {outcomes.map((o, i) => (
        <Reveal delay={i * 70} class="flex flex-col items-center gap-2 text-center">
          <span class="mb-1 inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface text-brand">
            <Icon name={o.icon} class="h-5 w-5" aria-hidden="true" />
          </span>
          <span class="font-heading text-4xl font-semibold tracking-tight text-ink md:text-5xl">{o.value}</span>
          <span class="max-w-[180px] text-sm text-stone md:text-base">{o.label}</span>
        </Reveal>
      ))}
    </div>
  </div>
</section>
