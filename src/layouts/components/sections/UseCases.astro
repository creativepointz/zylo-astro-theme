---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
import SectionHeading from '@/components/widgets/SectionHeading.astro';

// Concrete, trigger → action agents so buyers can picture themselves.
const useCases = [
  {
    icon: 'lucide:inbox',
    title: 'Inbox Triage',
    trigger: 'New email arrives',
    action: 'Sorts, labels, and drafts a reply for your review.',
  },
  {
    icon: 'lucide:life-buoy',
    title: 'Support Autoresponder',
    trigger: 'New ticket comes in',
    action: 'Answers from your help docs and escalates the edge cases.',
  },
  {
    icon: 'lucide:user-plus',
    title: 'Lead Enrichment',
    trigger: 'Someone signs up',
    action: 'Enriches the record, scores it, and pushes it to your CRM.',
  },
  {
    icon: 'lucide:bar-chart-3',
    title: 'Weekly Reports',
    trigger: 'Every Monday, 9am',
    action: 'Pulls your metrics, writes a summary, and posts it to Slack.',
  },
  {
    icon: 'lucide:mic',
    title: 'Meeting Notes → CRM',
    trigger: 'A call wraps up',
    action: 'Summarizes it, logs it to the CRM, and assigns the follow-ups.',
  },
  {
    icon: 'lucide:receipt',
    title: 'Invoice Processing',
    trigger: 'An invoice lands',
    action: 'Extracts the data, matches the PO, and files it for approval.',
  },
];
---

<section id="use-cases" class="py-24 bg-[#efefff]">
  <div class="container-page">
    <SectionHeading
      eyebrow="What can you build?"
      title="Agents That Do Real Work, Day One"
      intro="Start from a template or describe your own. Here are a few of the jobs teams hand to Zylo."
    />

    <div class="grid grid-cols-1 gap-0 sm:grid-cols-2 lg:grid-cols-3">
      {useCases.map((u, i) => (
        <Reveal
          delay={(i % 3) * 80}
          class="group flex flex-col rounded-[20px] border border-[#e2e8f0] bg-canvas p-8 text-left transition duration-300 ease-out hover:z-10 hover:shadow-[var(--shadow-subtle)]"
        >
          <span class="icon-tile mb-6 h-12 w-12">
            <Icon name={u.icon} class="h-6 w-6" aria-hidden="true" />
          </span>
          <h3 class="text-xl md:text-2xl font-semibold text-[#0f172b] mb-4 font-heading leading-tight">{u.title}</h3>
          <div class="mt-auto flex flex-col gap-3">
            <p class="flex items-start gap-2.5 text-base text-[#45556c] leading-relaxed">
              <span class="mt-0.5 inline-flex shrink-0 items-center gap-1 rounded-full bg-surface px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-stone">
                <Icon name="lucide:zap" class="h-3 w-3 text-brand" /> When
              </span>
              <span class="pt-0.5">{u.trigger}</span>
            </p>
            <p class="flex items-start gap-2.5 text-base text-[#45556c] leading-relaxed">
              <span class="mt-0.5 inline-flex shrink-0 items-center gap-1 rounded-full bg-surface px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-brand">
                <Icon name="lucide:arrow-right" class="h-3 w-3" /> Zylo
              </span>
              <span class="pt-0.5">{u.action}</span>
            </p>
          </div>
        </Reveal>
      ))}
    </div>

    <Reveal delay={160} class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="/pricing" class="btn-primary btn-lg">
        Start Free <Icon name="lucide:arrow-right" class="h-[18px] w-[18px]" />
      </a>
      <a href="/features" class="btn-secondary btn-lg">
        Browse all templates
      </a>
    </Reveal>
  </div>
</section>
