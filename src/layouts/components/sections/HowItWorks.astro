---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const steps = [
  { icon: 'lucide:user-plus', title: 'Create free account', desc: 'Elevate your efficiency and streamline your workflow by setting up your team workspace in 2 minutes.' },
  { icon: 'lucide:users-round', title: 'Invite team members', desc: 'Bring your team together and grant role-based access for collaborative automation building.' },
  { icon: 'lucide:zap', title: 'Instantly improve workflow', desc: 'Connect 100+ tools and deploy autonomous AI agents to eliminate manual tasks instantly.' },
  { icon: 'lucide:bar-chart-2', title: 'Track progress', desc: 'Monitor execution health, cost savings, and task performance live from your dashboard.' },
];
---

<section id="process" class="section border-b border-hairline bg-canvas">
  <div class="container-page">
    <Reveal class="mx-auto mb-16 max-w-3xl text-center">
      <h2 class="h2 mb-4">
        Start improving productivity with just 4 steps
      </h2>
      <p class="subtitle">
        Transform your team's potential into performance. Witness the real results that our tool brings to the table, amplifying collaboration and productivity.
      </p>
    </Reveal>

    <div class="mb-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((s, idx) => (
        <Reveal delay={idx * 80}>
          <div class="card h-full transition-shadow duration-200 hover:shadow-[var(--shadow-card)]">
            <div class="icon-tile mb-6">
              <Icon name={s.icon} class="h-5 w-5" />
            </div>
            <h3 class="h5 mb-2">{s.title}</h3>
            <p class="p-sm">{s.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>

    <Reveal class="text-center">
      <a href="/process" class="btn-primary btn-lg">
        See all process <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </Reveal>
  </div>
</section>
