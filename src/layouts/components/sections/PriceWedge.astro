---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';
---

<section id="price-wedge" class="section bg-[#f8fafc]">
  <div class="container-page">
    <Reveal
      class="relative overflow-hidden rounded-[24px] p-10 md:p-16 text-center"
      style={{ backgroundImage: 'linear-gradient(213deg, rgb(79, 70, 229) -10%, rgb(15, 23, 43) 55%)' }}
    >
      <div class="relative z-10 mx-auto max-w-3xl">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-indigo-100">
          <Icon name="lucide:tag" class="h-3.5 w-3.5" /> Fair pricing
        </span>
        <h2 class="mt-6 font-heading text-[34px] font-semibold leading-[1.15] tracking-tight text-white md:text-[52px]">
          Enterprise-grade AI agents.<br />
          <span class="text-indigo-300">From $19/mo, not $300.</span>
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-lg text-indigo-100/90">
          Most AI automation tools are built for engineers or priced for enterprises. Zylo gives small teams
          real agents, your own models, and no lock-in — at a price that actually makes sense.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/pricing" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-white px-7 text-base font-semibold text-[#0f172b] transition-all duration-150 hover:bg-indigo-50 active:scale-[0.98]">
            See pricing <Icon name="lucide:arrow-right" class="h-[18px] w-[18px]" />
          </a>
          <a href="#use-cases" class="inline-flex h-12 items-center justify-center gap-2 rounded-full border border-white/25 px-7 text-base font-semibold text-white transition-colors duration-150 hover:bg-white/10">
            See it in action
          </a>
        </div>
      </div>
    </Reveal>
  </div>
</section>
