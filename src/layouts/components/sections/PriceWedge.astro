---
import { Icon } from 'astro-icon/components';
import Reveal from '@/components/widgets/Reveal.astro';

const plans = [
  {
    name: 'Starter',
    price: '€89',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Real-time collaboration',
      'Unlimited projects & tasks',
      'Advanced task automation',
      'Team roles & permission control',
      'AI-Powered task assistant',
    ],
    bestFor: 'personal use, students',
    cta: 'Start for free',
    popular: false,
  },
  {
    name: 'Growth',
    price: '€199',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Gantt charts & timeline view',
      'Time tracking & productivity reports',
      'Kanban, calendar & list views',
      'File sharing & cloud storage',
      'Integrations with popular tools',
    ],
    bestFor: 'freelancers, small businesses',
    cta: 'Choose growth',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: '€999',
    period: '/month',
    desc: 'For growing startups that are starting to track and grow their task manage',
    features: [
      'Custom branding & label options',
      'Dedicated account manager',
      'Unlimited team members',
      'Two factor authentication (2FA)',
      '(SLA) Based priority support',
    ],
    bestFor: 'large teams, agencies',
    cta: 'Contact sale',
    popular: false,
  },
];
---

<section id="pricing-section" class="py-24 bg-surface-soft border-b border-hairline-soft">
  <div class="container-page max-w-6xl mx-auto px-4">
    <Reveal class="text-center max-w-3xl mx-auto mb-14">
      <span class="inline-block text-sm font-semibold text-stone uppercase tracking-wider mb-2">Innovation that scales</span>
      <h2 class="text-3xl sm:text-5xl font-semibold text-ink font-heading tracking-tight mb-4 leading-tight">
        Transparent plans. Trusted value.
      </h2>
    </Reveal>

    {/* Toggle & Currency Selector Band */}
    <Reveal delay={100} class="flex flex-col sm:flex-row items-center justify-between gap-4 p-3 px-6 rounded-full border border-hairline bg-canvas mb-12 shadow-[var(--shadow-subtle)] max-w-4xl mx-auto">
      <div class="flex items-center gap-4">
        <div class="flex items-center rounded-full bg-surface p-1">
          <button type="button" class="rounded-full bg-primary px-5 py-1.5 text-xs font-semibold text-on-primary shadow-[var(--shadow-subtle)]">
            Pay monthly
          </button>
          <button type="button" class="rounded-full px-5 py-1.5 text-xs font-semibold text-steel hover:text-ink">
            Pay yearly
          </button>
        </div>
        <span class="text-xs font-semibold text-brand">Save up to 15% off</span>
      </div>

      <div class="flex items-center gap-4 text-xs font-semibold text-steel">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="radio" name="currency" checked class="text-brand focus:ring-brand" /> USD ($)
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="radio" name="currency" class="text-brand focus:ring-brand" /> EUR (€)
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="radio" name="currency" class="text-brand focus:ring-brand" /> GBP (£)
        </label>
      </div>
    </Reveal>

    {/* 3 Tier Cards */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {plans.map((p, idx) => (
        <Reveal delay={idx * 80}>
          <div class={`rounded-lg border bg-canvas p-8 shadow-[var(--shadow-subtle)] transition-all h-full flex flex-col justify-between relative ${p.popular ? 'border-brand ring-2 ring-brand/20 shadow-[var(--shadow-card)]' : 'border-hairline'}`}>
            {p.popular && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-semibold uppercase tracking-wider text-on-primary shadow-[var(--shadow-subtle)]">
                Popular Choice
              </span>
            )}
            <div>
              <span class="font-semibold text-lg text-ink font-heading block mb-2">{p.name}</span>
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-4xl font-semibold text-ink font-heading">{p.price}</span>
                <span class="text-xs font-medium text-stone">{p.period}</span>
              </div>
              <p class="text-stone text-xs leading-relaxed mb-6 font-normal">{p.desc}</p>
              
              <a
                href={p.name === 'Enterprise' ? '/contact' : '/pricing'}
                class={`w-full inline-flex h-11 items-center justify-center rounded-full text-xs font-semibold tracking-tight transition-colors shadow-[var(--shadow-subtle)] mb-6 ${p.popular ? 'bg-primary text-on-primary hover:bg-charcoal' : 'border border-hairline text-ink hover:bg-canvas-dark hover:text-on-dark'}`}
              >
                {p.cta}
              </a>

              <ul class="space-y-3 pt-6 border-t border-hairline-soft">
                {p.features.map((f) => (
                  <li class="flex items-center gap-2.5 text-xs text-steel font-medium">
                    <Icon name="lucide:check" class="w-4 h-4 text-brand shrink-0" />
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              <p class="mt-6 pt-4 border-t border-hairline-soft text-xs text-stone font-medium">
                <span class="font-semibold text-ink">Best for:</span> {p.bestFor}
              </p>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
