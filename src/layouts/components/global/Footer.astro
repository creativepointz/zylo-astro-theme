---
import { Icon } from 'astro-icon/components';

const {
  ctaTitle = 'Start Automating Today',
  ctaSubtitle = 'Your first AI agent is 10 minutes away.',
  ctaPrimary = 'Subscribe now',
} = Astro.props;

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Platform & Features',
    links: [
      { label: 'Features Overview', href: '/features' },
      { label: 'Analytics', href: '/analytics' },
      { label: 'Integrations', href: '/integrations' },
      { label: 'Process', href: '/process' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Downloads', href: '/downloads' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: '/about-us' },
      { label: 'Careers', href: '/career' },
      { label: 'Our Team', href: '/team' },
      { label: 'Services', href: '/service' },
      { label: 'Testimonials', href: '/testimonial' },
      { label: 'Customers', href: '/customer' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'Case Studies', href: '/case-studies' },
      { label: 'Whitepaper', href: '/whitepaper' },
      { label: 'Glossary', href: '/glossary' },
      { label: 'Brandkit', href: '/brandkit' },
      { label: 'Changelog', href: '/changelog' },
    ],
  },
  {
    title: 'Support & Legal',
    links: [
      { label: 'Help & Support', href: '/support' },
      { label: 'FAQs', href: '/faq' },
      { label: 'Contact Us', href: '/contact' },
      { label: 'Affiliate Program', href: '/affiliate' },
      { label: 'Privacy Policy', href: '/privacy-policy' },
      { label: 'Terms of Service', href: '/terms-of-service' },
    ],
  },
];
---

{/* Closing CTA band — surface-tinted, black pill primary + mint accent secondary */}
<section id="start" class="border-t border-hairline bg-surface-soft">
  <div class="container-page flex flex-col items-center py-24 text-center md:py-[96px]">
    <h2 class="display-lg max-w-3xl">{ctaTitle}</h2>
    <p class="subtitle mt-5 max-w-xl">{ctaSubtitle}</p>

    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/pricing" class="btn-primary btn-lg">{ctaPrimary}</a>
      <a href="/contact" class="btn-secondary btn-lg">Book a demo</a>
    </div>
  </div>
</section>

<footer class="border-t border-hairline bg-canvas">
  <div class="container-page py-16">
    <div class="grid grid-cols-2 gap-x-8 gap-y-12 md:grid-cols-6">
      {/* Brand column */}
      <div class="col-span-2 space-y-4">
        <a href="/" class="inline-block">
          <img src="/zylo.svg" alt="Zylo" width="133" height="32" class="h-7 w-auto" />
        </a>
        <p class="p-sm max-w-xs">
          Bring your website idea to life by guided SaaS assistance
        </p>
        <ul class="space-y-1">
          <li><a href="tel:+80600008899" class="p-sm transition-colors hover:text-ink">+806 (000) 88 99</a></li>
          <li><a href="mailto:contact@zylo.co" class="p-sm transition-colors hover:text-ink">contact@zylo.co</a></li>
        </ul>
        <div class="flex items-center gap-2 pt-2">
          <a href="#" aria-label="Instagram" class="icon-tile transition-colors hover:bg-surface">
            <Icon name="lucide:instagram" class="h-4 w-4" />
          </a>
          <a href="#" aria-label="YouTube" class="icon-tile transition-colors hover:bg-surface">
            <Icon name="lucide:play" class="h-4 w-4" />
          </a>
        </div>
      </div>

      {/* Link columns */}
      {columns.map((col) => (
        <nav aria-label={col.title} class="col-span-1">
          <h5 class="mb-4 text-sm font-medium text-ink">{col.title}</h5>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-steel transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <div class="border-t border-hairline-soft">
    <div class="container-page flex flex-col items-center justify-between gap-4 py-6 text-[13px] text-stone sm:flex-row">
      <p>© {year} Zylo.co. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/terms-of-service" class="transition-colors hover:text-ink">Terms of Service</a>
        <a href="/privacy-policy" class="transition-colors hover:text-ink">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
